# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/infra/cloudflare/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# NotebookLM / Repomix packs (regenerate with npm run notebooklm:export*)
/notebooklm-dist/

# runtime artifacts (generated by the app — not source)
# Existing fixtures committed before this rule stay tracked; new files are ignored.
/runtime/cache/
/runtime/workspace/
/runtime/r2-sync-state.json
/runtime/jobs.json
/runtime/uploads/
/runtime/outputs/

# Build-time-generated auth hashes (emitted by scripts/emit-auth-hashes.cjs).
# Plaintext lives in .env / GitHub Secrets; the runtime .ts file is never
# committed. The companion .d.ts ships alongside source for tsc.
/src/server/runtime/auth-passwords.generated.ts

# Claude Code personal scratch / per-checkout working memory
CLAUDE.local.md
.claude/ISSUES.local.md
.claude/settings.local.json
runtime/jobs.json
