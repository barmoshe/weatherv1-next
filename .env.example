# Required: OpenAI API key (Whisper transcription + GPT picker)
OPENAI_API_KEY=

# Optional: enables Gemini 2.5 Flash as the vision backend for the
# segment-and-describe pipeline. If unset, the pipeline falls back to
# GPT-4o-mini vision using OPENAI_API_KEY.
GEMINI_API_KEY=

# Optional overrides. Defaults below are correct for the Dockerfile.
# PORT=3000
# HOSTNAME=0.0.0.0
# FFMPEG_PATH=/usr/bin/ffmpeg
# FFPROBE_PATH=/usr/bin/ffprobe
#
# Dev (`next dev`): catalog + videos default to ./runtime/workspace/ (not ../v1Drive).
# Production `next start` / Docker: default remains ../v1Drive/weather unless set.
# WEATHER_WORKSPACE_DIR=./runtime/workspace
#
# Optional Cloudflare R2 (same Worker + bucket as production when using these values).
# R2 Worker Basic Auth = (R2_APP_USERNAME, EDITOR_PASSWORD). EDITOR_PASSWORD below
# is the single source of truth — no separate R2_APP_PASSWORD.
# R2_SYNC_ENABLED=1
# R2_GATEWAY_URL=https://weatherv1-r2-gateway.barprojectsandbuilds.workers.dev
# R2_TENANT_ID=default
# R2_BUCKET_NAME=weatherv1-media
#
# Optional: switch /api/plan to the ver2 retrieve-then-pick pipeline (planner
# emits desired_concepts, retrieval shortlists top-K=15 per scene with seeded
# tier-shuffle, single picker call, no editorial validator). When unset or 0,
# the original validator-based pipeline runs. Each job gets its own
# render_seed; pass `render_seed` in the /api/plan body to reproduce or remix.
# PLAN_PIPELINE_VER2=1

# Required at build time: editor + admin gate passwords (plaintext) plus
# the canonical R2 Worker username. Hashed/baked into
# src/server/runtime/auth-passwords.generated.ts by the `prebuild` step
# (scripts/emit-auth-hashes.cjs). The build hard-fails if any is missing
# or empty — there is no fallback. In CI these come from GitHub Secrets;
# locally they live in your gitignored .env.
#
# The packaged desktop app uses (R2_APP_USERNAME, EDITOR_PASSWORD) as
# Cloudflare R2 Worker Basic Auth, so the editor login is the only login
# screen the user sees. The Worker's Basic Auth config must accept that
# same pair.
EDITOR_PASSWORD=
ADMIN_PASSWORD=
R2_APP_USERNAME=v1editor
