        bullets: ["לקישורים חזרו ל־#intro או #download-hero", "מחקו את פרקי pitch-test כשמתחיל פרודקשן"],
        visual: "numberedSample",
        sampleNumber: 8,
        theme: { paper: "#fff0ee", accent: "#d9432b" }
