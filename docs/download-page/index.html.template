      }
    }

    @media (max-width: 960px) {
      .intro-pipeline-diagram.intro-pipeline-excal {
        grid-template-columns: repeat(3, minmax(0, 1fr));
        grid-template-rows: clamp(34px, 6vw, 42px) auto auto;
      }

      .intro-pipeline-edge-layer {
        grid-row: 1;
      }

      .intro-pipeline-node-slot--1,
      .intro-pipeline-node-slot--2,
      .intro-pipeline-node-slot--3 {
        grid-row: 2;
      }

      .intro-pipeline-node-slot--4,
      .intro-pipeline-node-slot--5,
      .intro-pipeline-node-slot--6 {
        grid-row: 3;
      }

      /* RTL: cols 3,2,1 then 6,5,4 for two-row reading */
      .intro-pipeline-node-slot--1 {
        grid-column: 1;
      }

      .intro-pipeline-node-slot--2 {
        grid-column: 2;
      }

      .intro-pipeline-node-slot--3 {
        grid-column: 3;
      }

      .intro-pipeline-node-slot--4 {
        grid-column: 1;
      }

      .intro-pipeline-node-slot--5 {
        grid-column: 2;
      }

      .intro-pipeline-node-slot--6 {
        grid-column: 3;
      }

      .intro-pipeline-edge-layer .intro-pipeline-edge {
        opacity: 0.35;
        animation-duration: 4.25s;
      }
    }

    #intro .hero-downloads {
