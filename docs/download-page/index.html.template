<!doctype html>
<html lang="he" dir="rtl">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>WeatherV1 Next - מצגת מונפשת</title>
  <style>
    :root {
      color-scheme: light;
      --v1-red: #FF0000;
      --v1-coral: #F9543E;
      --v1-coral-soft: #FCE9E4;
      --v1-cream: #F4F3EF;
      --v1-paper: #FFFFFF;
      --v1-ink: #000000;
      --v1-ink-muted: #313131;
      --v1-yellow: #F2C231;
      --v1-success: #1FA871;
      --v1-warning: #F5A623;
      --v1-danger: #C8202B;
      --shadow: 8px 8px 0 var(--v1-ink);
      --radius: 18px;
    }

    * { box-sizing: border-box; }
    html, body { min-height: 100%; }
    body {
      margin: 0;
      overflow: hidden;
      background:
        linear-gradient(90deg, rgb(0 0 0 / .035) 1px, transparent 1px) 0 0 / 28px 28px,
        linear-gradient(0deg, rgb(0 0 0 / .03) 1px, transparent 1px) 0 0 / 28px 28px,
        radial-gradient(circle at 12% 18%, rgb(242 194 49 / .26), transparent 30rem),
        radial-gradient(circle at 82% 72%, rgb(249 84 62 / .18), transparent 36rem),
        var(--v1-cream);
      color: var(--v1-ink);
      font: 15px/1.45 Heebo, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    button, textarea { font: inherit; }
    button {
      min-height: 38px;
      padding: 0 12px;
      border: 1.5px solid var(--v1-ink);
      border-radius: 12px;
      background: rgb(255 255 255 / .76);
      color: var(--v1-ink);
      box-shadow: 2px 2px 0 var(--v1-ink);
      cursor: pointer;
      font-weight: 800;
      transition: transform 160ms ease, background 160ms ease, box-shadow 160ms ease;
    }
    button:hover { background: var(--v1-yellow); transform: translateY(-2px); box-shadow: 3px 3px 0 var(--v1-ink); }
    button.primary { background: var(--v1-red); color: #fff; }
    button[aria-pressed="true"] { background: var(--v1-coral-soft); }

    .app {
      height: 100svh;
      display: grid;
      grid-template-rows: auto 1fr auto;
      gap: 14px;
      padding: 14px;
    }

    .topbar, .bottombar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      min-width: 0;
    }

    .topbar {
      background: var(--v1-coral);
      border: 2px solid var(--v1-ink);
      border-radius: 16px;
      padding: 10px 12px;
      box-shadow: 4px 4px 0 var(--v1-ink);
    }

    .brand, .controls {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
    }

    .brand-mark {
      width: 38px;
      height: 38px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 4px;
      background: var(--v1-red);
      color: #fff;
      box-shadow: 3px 3px 0 var(--v1-ink);
      font-weight: 900;
    }

    .wordmark {
      display: inline-flex;
      align-items: baseline;
      gap: .45rem;
      flex-wrap: wrap;
      font-weight: 900;
      letter-spacing: 0;
    }
    .wordmark-sub { opacity: .72; font-weight: 750; }

    .shell {
      min-height: 0;
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(240px, 320px);
      gap: 14px;
    }

    .stage-wrap {
      min-width: 0;
      min-height: 0;
      display: grid;
      place-items: center;
      perspective: 1600px;
    }

    .stage {
      width: min(100%, calc((100svh - 128px) * 16 / 9));
      aspect-ratio: 16 / 9;
      position: relative;
      overflow: hidden;
      border: 2px solid var(--v1-ink);
      border-radius: var(--radius);
      background: var(--slide-paper, var(--v1-paper));
      color: var(--slide-ink, var(--v1-ink));
      box-shadow: var(--shadow);
      isolation: isolate;
      transform-style: preserve-3d;
    }

    .paper-grid {
      position: absolute;
      inset: 0;
      opacity: .25;
      background:
        linear-gradient(90deg, rgb(0 0 0 / .055) 1px, transparent 1px) 0 0 / 36px 36px,
        linear-gradient(0deg, rgb(0 0 0 / .04) 1px, transparent 1px) 0 0 / 36px 36px;
      pointer-events: none;
      z-index: 1;
    }

    .slide-copy {
      position: absolute;
      right: clamp(28px, 5vw, 74px);
      top: clamp(30px, 6vw, 78px);
      z-index: 5;
      width: min(45%, 530px);
      text-align: right;
    }

    .kicker {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 14px;
      color: var(--slide-accent, var(--v1-coral));
      font-size: clamp(11px, 1.25vw, 15px);
      font-weight: 900;
      letter-spacing: .06em;
      text-transform: uppercase;
    }
    .kicker::before {
      content: "";
      width: 24px;
      height: 3px;
      border-radius: 999px;
      background: currentColor;
    }

    h1 {
      margin: 0;
      max-width: 12ch;
      font-size: clamp(36px, 5.7vw, 78px);
      line-height: .98;
      letter-spacing: 0;
    }

    .subtitle {
      max-width: 35ch;
      margin: 18px 0 0;
      color: var(--v1-ink-muted);
      font-size: clamp(15px, 1.65vw, 22px);
      font-weight: 500;
    }

    .bullets {
      margin: 26px 0 0;
      padding: 0;
      display: grid;
      gap: 10px;
      list-style: none;
      color: var(--v1-ink);
      font-weight: 750;
    }
    .bullets li {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      opacity: 0;
      transform: translateY(12px);
    }
    .bullets li::before {
      content: "";
      flex: 0 0 auto;
      width: 9px;
      height: 9px;
      margin-top: 7px;
      border-radius: 999px;
      background: var(--slide-accent, var(--v1-coral));
      box-shadow: 0 0 0 5px rgb(249 84 62 / .14);
    }

    .link-actions {
      margin: 28px 0 0;
      display: grid;
      gap: 10px;
      max-width: 34rem;
    }

    .link-actions a {
      display: inline-flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      min-height: 46px;
      padding: 0 16px;
      border: 2px solid var(--v1-ink);
      border-radius: 12px;
      background: rgb(255 255 255 / .82);
      color: var(--v1-ink);
      box-shadow: 3px 3px 0 var(--v1-ink);
      text-decoration: none;
      font-weight: 900;
      opacity: 0;
      transform: translateY(12px);
    }

    .link-actions a.primary-link {
      background: var(--v1-red);
      color: #fff;
    }

    .link-actions a::after {
      content: "↗";
      direction: ltr;
      unicode-bidi: isolate;
      font-weight: 900;
    }

    .sketch {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      z-index: 3;
      overflow: visible;
    }
    .sketch-camera, .sketch-item {
      transform-box: fill-box;
      transform-origin: center;
    }
    .drawn {
      stroke-dasharray: var(--dash, 1200);
      stroke-dashoffset: var(--dash, 1200);
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    .slide-number {
      position: absolute;
      left: 28px;
      bottom: 22px;
      z-index: 6;
      color: rgb(49 49 49 / .64);
      font-weight: 900;
      font-variant-numeric: tabular-nums;
      direction: ltr;
    }

    .notes {
      min-height: 0;
      display: grid;
      grid-template-rows: auto 1fr;
      overflow: hidden;
      border: 2px solid var(--v1-ink);
      border-radius: 14px;
      background: rgb(255 255 255 / .74);
      box-shadow: var(--shadow);
    }
    .notes header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      padding: 12px 14px;
      color: var(--v1-ink-muted);
      border-bottom: 1px solid rgb(0 0 0 / .08);
      font-weight: 900;
    }
    .notes textarea {
      width: 100%;
      height: 100%;
      min-height: 0;
      padding: 14px;
      resize: none;
      border: 0;
      outline: 0;
      background: transparent;
      color: var(--v1-ink);
      direction: rtl;
    }
    .notes[hidden] { display: none; }

    .progress {
      flex: 1;
      min-width: 120px;
      height: 8px;
      overflow: hidden;
      border-radius: 999px;
      background: var(--v1-coral-soft);
    }
    .progress span {
      display: block;
      width: var(--progress);
      height: 100%;
      background: linear-gradient(90deg, var(--v1-yellow), var(--v1-red));
      transition: width 240ms ease;
    }
    .status {
      direction: ltr;
      color: var(--v1-ink-muted);
      font-variant-numeric: tabular-nums;
      white-space: nowrap;
    }

    .overview {
      position: fixed;
      inset: 0;
      z-index: 20;
      display: none;
      overflow: auto;
      padding: 36px;
      background: rgb(244 243 239 / .92);
      backdrop-filter: blur(18px);
    }
    .overview.is-open { display: block; }
    .overview-head {
      display: flex;
      justify-content: space-between;
      gap: 16px;
      align-items: center;
      margin-bottom: 24px;
    }
    .overview-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 18px;
    }
    .thumb {
      min-height: 156px;
      padding: 16px;
      text-align: right;
      border: 2px solid transparent;
      border-radius: 14px;
      background: var(--v1-paper);
      box-shadow: 4px 4px 0 var(--v1-ink);
    }
    .thumb.is-current { border-color: var(--v1-red); }
    .thumb small {
      display: block;
      margin-bottom: 10px;
      color: var(--v1-coral);
      font-weight: 900;
    }
    .thumb strong {
      display: block;
      margin-bottom: 8px;
      font-size: 24px;
      line-height: 1;
    }

    .file-input {
      position: absolute;
      inline-size: 1px;
      block-size: 1px;
      opacity: 0;
      pointer-events: none;
    }
    .toast {
      position: fixed;
      left: 50%;
      bottom: 72px;
      z-index: 30;
      translate: -50% 20px;
      opacity: 0;
      pointer-events: none;
      padding: 10px 14px;
      border: 2px solid var(--v1-ink);
      border-radius: 999px;
      background: rgb(255 255 255 / .92);
      transition: opacity 180ms ease, translate 180ms ease;
    }
    .toast.is-visible {
      opacity: 1;
      translate: -50% 0;
    }
    .builder-credit {
      direction: ltr;
      unicode-bidi: isolate;
      position: fixed;
      left: .875rem;
      bottom: .875rem;
      z-index: 60;
      display: inline-flex;
      gap: .25rem;
      align-items: center;
      padding: .22rem .5rem;
      border: 1.5px solid var(--v1-ink);
      border-radius: 999px;
      background: rgb(255 255 255 / .72);
      color: var(--v1-ink);
      box-shadow: 1.5px 1.5px 0 var(--v1-ink);
      text-decoration: none;
      font-size: .68rem;
      font-weight: 800;
      line-height: 1;
      white-space: nowrap;
    }
    .builder-credit__label {
      font-size: .58rem;
      font-weight: 700;
      letter-spacing: .08em;
      text-transform: uppercase;
      opacity: .72;
    }
    .builder-credit__name { font-weight: 900; }

    @media (max-width: 900px) {
      body { overflow: auto; }
      .app { min-height: 100svh; height: auto; }
      .shell { grid-template-columns: 1fr; }
      .stage { width: 100%; }
      .slide-copy { width: 54%; right: 26px; top: 28px; }
      .notes { min-height: 220px; }
    }
    @media (max-width: 620px) {
      .topbar, .bottombar { align-items: flex-start; flex-direction: column; }
      .slide-copy { width: calc(100% - 52px); }
      .subtitle, .bullets { max-width: 30ch; }
      .sketch { opacity: .38; transform: translateX(-20%); }
    }
    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 1ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 1ms !important;
        scroll-behavior: auto !important;
      }
      .drawn { stroke-dashoffset: 0 !important; }
      .sketch-camera, .sketch-item, .bullets li, .link-actions a { transform: none !important; opacity: 1 !important; }
    }
  </style>
</head>
<body>
  <div class="app">
    <header class="topbar">
      <div class="brand">
        <span class="brand-mark" aria-hidden="true">V1</span>
        <span class="wordmark">
          <strong>WeatherV1 Next</strong>
          <span class="wordmark-sub">מצגת מוצר מונפשת</span>
        </span>
      </div>
      <div class="controls" aria-label="פקדי מצגת">
        <button id="prevBtn" title="שקף קודם">קודם</button>
        <button id="nextBtn" class="primary" title="שקף הבא">הבא</button>
        <button id="overviewBtn" title="סקירת שקופיות">סקירה</button>
        <button id="notesBtn" aria-pressed="true" title="הצגת הערות">הערות</button>
        <button id="fullBtn" title="מסך מלא">מלא</button>
      </div>
    </header>

    <main class="shell">
      <section class="stage-wrap" aria-label="במת שקופית">
        <article id="stage" class="stage" tabindex="0"></article>
      </section>
      <aside id="notesPanel" class="notes" aria-label="הערות דובר">
        <header>
          <span>הערות דובר</span>
          <span id="notesMeta">שקף 1</span>
        </header>
        <textarea id="notesText" spellcheck="true"></textarea>
      </aside>
    </main>

    <footer class="bottombar">
      <div class="progress" aria-hidden="true"><span id="progressFill"></span></div>
      <div class="status" id="statusText">1 / 15</div>
      <div class="controls" aria-label="פקדי ייצוא">
        <button id="pngBtn">PNG</button>
        <button id="jsonBtn">ייצוא JSON</button>
        <button id="excalidrawBtn">ייצוא Excalidraw</button>
      </div>
    </footer>
  </div>

  <section id="overview" class="overview" aria-label="סקירת שקופיות" aria-hidden="true">
    <div class="overview-head">
      <div>
        <h2 style="margin:0">סקירה</h2>
        <p style="margin:.25rem 0 0;color:var(--v1-ink-muted)">בחרו שקף או לחצו Escape.</p>
      </div>
      <button id="closeOverview">סגור</button>
    </div>
    <div id="overviewGrid" class="overview-grid"></div>
  </section>

  <div id="toast" class="toast" role="status" aria-live="polite"></div>
  <a class="builder-credit" dir="ltr" href="https://barmoshe.github.io/bar-portfolio/" target="_blank" rel="noreferrer">
    <span class="builder-credit__label">Builder</span>
    <span aria-hidden="true">·</span>
    <strong class="builder-credit__name">Bar Moshe</strong>
  </a>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <script>
    const SIZE = { w: 1280, h: 720 };
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const hasGsap = Boolean(window.gsap) && !reduceMotion;

    const THEMES = {
      product: { paper: "#FFFFFF", ink: "#000000", accent: "#F9543E" },
      soft: { paper: "#FCE9E4", ink: "#000000", accent: "#FF0000" },
      tech: { paper: "#FFFFFF", ink: "#000000", accent: "#1FA871" },
      cream: { paper: "#F4F3EF", ink: "#000000", accent: "#C8202B" },
      decision: { paper: "#F2C231", ink: "#000000", accent: "#FF0000" }
    };

    const slides = [
      {
        id: "hero",
        frameName: "פתיחה",
        kicker: "WeatherV1 Next",
