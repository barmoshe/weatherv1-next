    /**
     * Author-only — no visitor controls.
     * - AUTHOR_DESKTOP_STORY_AXIS "vertical" = desktop TTB stack + scroll snap (same idea as narrow/mobile).
     * - "horizontal" + AUTHOR_HORIZONTAL_SCROLL_DIRECTION:
     *   - "rtl" = גלילה מטה מקדמת את הסיפור כמו בעברית (מראה עם מראת הפס + מהפךTween; גיאומטריה של pin נשארת יציבה).
     *   - "ltr" = פיזיקת פס שמימין־שמאל (intro משמאל, גלילה חושפת פרקים לכיוון השני).
     * - Per-slide `transition` on `storySections`: "ttb" = כניסת TTB בולטת; "rtl" = מעבר צדדי; השמטה = TTB עדין (מגדיר `data-transition`).
     * - Optional `desktopCluster` (same string on 2+ consecutive slides): one horizontal lane; slides stack vertically inside with snap + trapped wheel until top/bottom, then horizontal scrub resumes.
     */
    const AUTHOR_DESKTOP_STORY_AXIS = "horizontal"; // "horizontal" | "vertical"
    const AUTHOR_HORIZONTAL_SCROLL_DIRECTION = "rtl"; // "rtl" | "ltr" — ignored when axis is vertical

    function authorStoryMotion() {
      const verticalDesktop = AUTHOR_DESKTOP_STORY_AXIS === "vertical";
      const rtlFlow =
        AUTHOR_DESKTOP_STORY_AXIS === "horizontal" &&
        AUTHOR_HORIZONTAL_SCROLL_DIRECTION === "rtl" &&
        !verticalDesktop;
      return { verticalDesktop, rtlFlow };
    }

    /** Slide entrance mode on `data-transition`: "rtl", "ttb-subtle", "ttb-showcase" (omit section.transition ⇒ subtle TTB). */
    function panelTransition(section) {
      if (section.transition === "rtl") return "rtl";
      if (section.transition === "ttb") return "ttb-showcase";
      return "ttb-subtle";
    }

    const storyTrackEl = document.getElementById("storyTrack");
    const trackRoll = document.getElementById("storyRoll");
    const progressFill = document.getElementById("progressFill");
    const reduceMotion = matchMedia("(prefers-reduced-motion: reduce)").matches;
    let passiveProgressCleanup = null;
    let mainScrollTrigger = null;
    let horizontalTween = null;
    /** GSAP timelines / tweens for horizontal-pin panel entrances (linked to horizontalTween). */
    let horizontalPanelRevealAnims = [];
    /** Trapped wheel on merged vertical stacks; cleaned before killing horizontal tween. */
    let verticalClusterWheelCleanups = [];

    function teardownPassiveProgress() {
      if (typeof passiveProgressCleanup === "function") {
        passiveProgressCleanup();
        passiveProgressCleanup = null;
      }
    }

    /** Match horizontal panel width / GSAP lane to `#storyTrack` (avoids 0-sized cqw on cold desktop load). */
    function syncStoryViewportWidthCss() {
      if (!storyTrackEl) return;
      const rect = storyTrackEl.getBoundingClientRect();
      const w = Math.max(
        1,
        Math.round(rect.width || storyTrackEl.clientWidth || window.innerWidth || 1)
      );
      document.documentElement.style.setProperty("--story-vw", `${w}px`);
    }

    function escapeHtml(value) {
      return String(value ?? "").replace(/[&<>"']/g, ch => ({
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#39;"
      }[ch]));
    }

    function downloadLinksMarkup(links) {
      return links.map(link => `
          <a class="${link.primary ? "primary" : ""}" href="${escapeHtml(link.href)}">
            <span>${escapeHtml(link.label)}</span>
          </a>
        `).join("");
    }

    function heroDownloadsBlock() {
      return `
          <div class="hero-downloads" id="download-hero" aria-labelledby="hero-download-heading">
            <p class="hero-downloads-title" id="hero-download-heading">הורדה</p>
