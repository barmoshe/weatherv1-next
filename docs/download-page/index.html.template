    const STORAGE_LAYOUT = "weatherV1Pitch.layout";
    const STORAGE_FLOW = "weatherV1Pitch.flow";

    function readMotionPrefs() {
      try {
        const layout = localStorage.getItem(STORAGE_LAYOUT) || "horizontal";
        const flow = localStorage.getItem(STORAGE_FLOW) || "rtl";
        return {
          verticalDesktop: layout === "vertical",
          rtlFlow: flow !== "ltr"
        };
      } catch (_) {
        return { verticalDesktop: false, rtlFlow: true };
      }
    }

    function persistMotionPrefs(next) {
      try {
        localStorage.setItem(STORAGE_LAYOUT, next.verticalDesktop ? "vertical" : "horizontal");
        localStorage.setItem(STORAGE_FLOW, next.rtlFlow ? "rtl" : "ltr");
      } catch (_) {}
    }

    const trackRoll = document.getElementById("storyRoll");
    const progressFill = document.getElementById("progressFill");
    const reduceMotion = matchMedia("(prefers-reduced-motion: reduce)").matches;
    let mainScrollTrigger = null;
    let horizontalTween = null;

    function wireMotionPrefsUi() {
      const root = document.getElementById("pitchMotionUi");
      if (!root) return;
      const p = readMotionPrefs();
      const layoutRadio = root.querySelector(`input[name="pitchLayout"][value="${p.verticalDesktop ? "vertical" : "horizontal"}"]`);
      const flowRadio = root.querySelector(`input[name="pitchFlow"][value="${p.rtlFlow ? "rtl" : "ltr"}"]`);
      if (layoutRadio) layoutRadio.checked = true;
      if (flowRadio) flowRadio.checked = true;
      root.addEventListener("change", ev => {
        const t = ev.target;
        if (!(t instanceof HTMLInputElement)) return;
        const cur = readMotionPrefs();
        if (t.name === "pitchLayout") {
          persistMotionPrefs({ verticalDesktop: t.value === "vertical", rtlFlow: cur.rtlFlow });
          location.reload();
          return;
        }
        if (t.name === "pitchFlow") {
          persistMotionPrefs({ verticalDesktop: cur.verticalDesktop, rtlFlow: t.value === "rtl" });
          location.reload();
        }
      });
    }

    function escapeHtml(value) {
      return String(value ?? "").replace(/[&<>"']/g, ch => ({
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#39;"
      }[ch]));
    }

    function downloadLinksMarkup(links) {
      return links.map(link => `
          <a class="${link.primary ? "primary" : ""}" href="${escapeHtml(link.href)}">
            <span>${escapeHtml(link.label)}</span>
          </a>
        `).join("");
    }

    function heroDownloadsBlock() {
      return `
          <div class="hero-downloads" id="download-hero" aria-labelledby="hero-download-heading">
            <p class="hero-downloads-title" id="hero-download-heading">הורדה</p>
            <div class="download-links download-links--hero">${downloadLinksMarkup(downloadLinks)}</div>
          </div>`;
    }

