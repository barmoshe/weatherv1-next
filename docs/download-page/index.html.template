    function downloadLinksMarkup(links) {
      const primary = links.filter(link => !link.secondary);
      const secondary = links.filter(link => link.secondary);
      const primaryHtml = primary
        .map(
          link => `
          <a class="${link.primary ? "primary" : ""}" href="${escapeHtml(link.href)}">
            <span>${escapeHtml(link.label)}</span>
          </a>
        `
        )
        .join("");
      const secondaryHtml =
        secondary.length === 0
          ? ""
          : `
          <div class="download-links download-links--hero-extra" aria-label="קישורים נוספים">
            ${secondary
              .map(
                link => `
          <a href="${escapeHtml(link.href)}">
            <span>${escapeHtml(link.label)}</span>
          </a>
        `
              )
              .join("")}
          </div>`;
      return `${primaryHtml}${secondaryHtml}`;
    }

