          <div class="timeline-row"><span class="timeline-dot">✓</span><span>פורמט מזוהה ואחיד</span></div>
          <div class="timeline-row"><span class="timeline-dot">✓</span><span>פחות עבודה טכנית ללקוח</span></div>
        </div>`;
      }
      if (type === "excalidrawDemo") {
        const src = "download-page/assets/pitch-sample-animated.svg";
        return `<div class="excal-embed-wrap">
          <div class="excal-drawbox" lang="en" dir="ltr">
            <object class="excal-embed" type="image/svg+xml" data="${escapeHtml(src)}" title="דוגמת שרטוט מהיר ללקוח" aria-label="דוגמת שרטוט מהיר ללקוח"></object>
          </div>
          <p class="excal-caption">ניתן להחליף ב־SVG שייצא מהכלי הציבורי <a href="https://dai-shi.github.io/excalidraw-animate" target="_blank" rel="noreferrer">excalidraw-animate</a> (<a href="https://github.com/dai-shi/excalidraw-animate" target="_blank" rel="noreferrer">מקור</a>).</p>
        </div>`;
      }
      if (type === "llmPricing") {
        return `<div class="pricing-board visual-board">
          <div class="pricing-head"><span>מודל</span><span class="mixed-ltr" lang="en" dir="ltr">$/1M טוקנים</span></div>
          <div class="pricing-row"><span class="mixed-ltr" lang="en" dir="ltr">NovaLite · מהיר</span><small class="mixed-ltr">$2.50 in / $5 out</small></div>
          <div class="pricing-row"><span class="mixed-ltr" lang="en" dir="ltr">NovaPro · איכות</span><small class="mixed-ltr">$12 in / $24 out</small></div>
          <div class="pricing-row"><span>ממוצע שימוש בשבוע (דמו)</span><small class="mixed-ltr">~420K in · 160K out</small></div>
          <div class="token-chip"><span>ארנק פרויקט</span><span class="mixed-ltr" lang="en" dir="ltr">-18% מתקרה</span></div>
        </div>`;
      }
      if (type === "tutorialDemo") {
        return `<div class="tutorial-panel">
          <ul class="tutorial-list">
            <li class="tutorial-item">
              <span class="tutorial-num mixed-ltr" lang="en" dir="ltr">1</span>
              <div class="tutorial-body"><strong>התחזית הראשונה</strong><span>גללו מטה בצעד רגוע וראו מתי מתחילה ריצת ההזזה האופקית.</span></div>
            </li>
            <li class="tutorial-item">
              <span class="tutorial-num mixed-ltr" lang="en" dir="ltr">2</span>
              <div class="tutorial-body"><strong>דילוג פרקים</strong><span>לחצו על “הורדה” בשורת הניווט — הקפיצה חוזרת לעמודת ההורדה בשקופית הפתיחה (#download-hero).</span></div>
            </li>
            <li class="tutorial-item">
              <span class="tutorial-num mixed-ltr" lang="en" dir="ltr">3</span>
              <div class="tutorial-body"><strong>נסו הפוך</strong><span>גללו למעלה שוב ובדקו ש־snap מחזיר אתכם בצורה ברורה בין פרקים.</span></div>
            </li>
          </ul>
          <p class="tutorial-tip"><span class="mixed-ltr" lang="en" dir="ltr">prefers-reduced-motion</span>: כבו אנימציה במערכת כדי לראות פריסה סטטית.</p>
        </div>`;
      }
      if (type === "numberedSample") {
        const raw = Number(section.sampleNumber);
        const n = Number.isFinite(raw) ? String(Math.trunc(raw)) : "?";
        return `<div class="numbered-sample-visual"><span class="numbered-sample-num mixed-ltr" lang="en" dir="ltr">${escapeHtml(n)}</span></div>`;
      }
      return `<div class="visual-board"><div class="mini-card"><span>${escapeHtml(section.title)}</span><small>Placeholder</small></div></div>`;
    }

    /** Normalise merge key for `desktopCluster`; empty = no cluster. */
    function normalizeDesktopCluster(section) {
      const v = section.desktopCluster;
      if (typeof v !== "string") return "";
      return v.trim();
    }

    /**
     * Cells for the horizontal scrub: singletons, or 2+ consecutive slides with the same `desktopCluster`
     * merged into one lane with an inner vertical scroll stack.
     */
    function buildStoryCells(sections) {
      const out = [];
      let i = 0;
      while (i < sections.length) {
        const cid = normalizeDesktopCluster(sections[i]);
        if (cid) {
          const grouped = [];
          while (i < sections.length && normalizeDesktopCluster(sections[i]) === cid) {
            grouped.push({ section: sections[i], globalIdx: i });
            i++;
          }
          if (grouped.length >= 2) {
            out.push({ type: "cluster", cid, grouped });
          } else {
            out.push({ type: "single", section: grouped[0].section, globalIdx: grouped[0].globalIdx });
          }
        } else {
          out.push({ type: "single", section: sections[i], globalIdx: i });
          i++;
        }
      }
      return out;
    }

    function singlePanelSectionHtml(section, globalIdx, rollIdx) {
      const bullets = section.bullets.map(item => `<li>${escapeHtml(item)}</li>`).join("");
      const heroDownloads = section.id === "intro" ? heroDownloadsBlock() : "";
      const visualAria = section.visual === "excalidrawDemo" ? "" : " aria-hidden=\"true\"";
      const heading =
        section.id === "intro"
          ? `<h1>${escapeHtml(section.title)}</h1>`
          : `<h2>${escapeHtml(section.title)}</h2>`;
      return `<section
        class="story-panel"
        id="${escapeHtml(section.id)}"
        style="--panel-paper:${section.theme.paper};--panel-accent:${section.theme.accent}"
        data-index="${globalIdx}"
        data-roll-index="${rollIdx}"
        data-transition="${escapeHtml(panelTransition(section))}"
      >
        <div class="panel-inner">
          <div class="panel-copy">
            <div class="kicker">${escapeHtml(section.kicker)}</div>
            ${heading}
            <p class="lead">${escapeHtml(section.lead)}</p>
            <ul class="bullets">${bullets}</ul>
            ${heroDownloads}
          </div>
          <div class="panel-visual"${visualAria}>${visualMarkup(section.visual, section)}</div>
        </div>
      </section>`;
    }

    /** One horizontal column containing vertically stacked `.story-subslide`s. */
    function clusteredPanelSectionHtml(cid, grouped, rollIdx) {
      const safeId = cid.replace(/[^a-zA-Z0-9_-]/g, "-");
      const first = grouped[0].section;
      const slides = grouped
        .map(({ section: sec, globalIdx }) => {
          const bullets = sec.bullets.map(item => `<li>${escapeHtml(item)}</li>`).join("");
          const visualAria = sec.visual === "excalidrawDemo" ? "" : " aria-hidden=\"true\"";
          return `
      <article
        class="story-subslide"
        id="${escapeHtml(sec.id)}"
        style="--panel-paper:${sec.theme.paper};--panel-accent:${sec.theme.accent}"
        data-section-index="${globalIdx}"
        data-transition="${escapeHtml(panelTransition(sec))}"
      >
        <div class="panel-inner">
          <div class="panel-copy">
            <div class="kicker">${escapeHtml(sec.kicker)}</div>
            <h2>${escapeHtml(sec.title)}</h2>
            <p class="lead">${escapeHtml(sec.lead)}</p>
            <ul class="bullets">${bullets}</ul>
          </div>
          <div class="panel-visual"${visualAria}>${visualMarkup(sec.visual, sec)}</div>
        </div>
      </article>`;
        })
        .join("");

      return `<section
        class="story-panel story-panel--vcluster"
        id="${escapeHtml("cluster-" + safeId)}"
        data-desktop-cluster="${escapeHtml(cid)}"
        data-index="${grouped[0].globalIdx}"
        data-roll-index="${rollIdx}"
        data-transition="${escapeHtml(panelTransition(first))}"
        aria-label="פרק עם גלילה אנכית פנימית"
      >
        <div class="story-vstack">
          ${slides}
        </div>
      </section>`;
    }

    function buildStoryRollHtml(sections) {
      const cells = buildStoryCells(sections);
      return cells
        .map((cell, rollIdx) => {
          if (cell.type === "cluster") return clusteredPanelSectionHtml(cell.cid, cell.grouped, rollIdx);
          return singlePanelSectionHtml(cell.section, cell.globalIdx, rollIdx);
        })
        .join("");
    }

    trackRoll.innerHTML = buildStoryRollHtml(storySections);

    function setProgress(value) {
      const clamped = Math.max(0, Math.min(1, value));
      progressFill.style.transform = `scaleX(${clamped})`;
    }

    function teardownHorizontalStory() {
      teardownVerticalClusterWheelCaptures();
      teardownHorizontalPanelReveals();
      if (horizontalTween) {
        horizontalTween.kill();
        horizontalTween = null;
      }
      mainScrollTrigger = null;
    }

    const PANEL_REVEAL_SEL = ".kicker, h1, h2, .lead, .bullets li, .hero-downloads, .panel-visual > *";

    /**
     * verticalStack = desktop TTB pitch; false = entrances during horizontal-pin (`ScrollTrigger.horizontal` + containerAnimation).
     * `panel.dataset.transition`: rtl | ttb-showcase | ttb-subtle
     */
    function panelRevealTweenVars(panel, verticalStack) {
      const mode = panel.dataset.transition || "ttb-subtle";
      const carousel = verticalStack !== true;

      if (mode === "rtl") {
        return {
          x: carousel ? 52 : 44,
          y: 0,
          duration: verticalStack ? 0.55 : 0.58,
          stagger: carousel ? 0.06 : 0.05,
          ease: verticalStack ? "power2.out" : "power3.out",
        };
      }

      const showcase = mode === "ttb-showcase";

      if (carousel) {
        return {
          x: 0,
          y: showcase ? 46 : 20,
          duration: showcase ? 0.7 : 0.48,
          stagger: showcase ? 0.095 : 0.035,
          ease: showcase ? "power3.out" : "power2.out",
        };
      }

      return {
        x: 0,
        y: showcase ? 50 : 32,
        duration: showcase ? 0.62 : 0.52,
        stagger: showcase ? 0.08 : 0.045,
        ease: showcase ? "power3.out" : "power2.out",
      };
    }

    function teardownHorizontalPanelReveals() {
      horizontalPanelRevealAnims.forEach(anim => {
        if (!anim) return;
        const st = anim.scrollTrigger;
        if (st) st.kill(false);
        anim.kill();
      });
      horizontalPanelRevealAnims = [];
    }

    function teardownVerticalClusterWheelCaptures() {
      verticalClusterWheelCleanups.forEach(fn => {
        try {
          fn();
        } catch (_) {}
      });
      verticalClusterWheelCleanups = [];
    }

    function clusterInnerWheelGuard(ev) {
      if (!document.body.classList.contains("is-scrollstory") || document.body.classList.contains("pitch-vertical")) return;
      if (window.matchMedia("(max-width: 860px)").matches) return;
      const sc = ev.currentTarget;
      if (!(sc instanceof HTMLElement)) return;

      const tol = 2;
      const dy = ev.deltaY;
      const st = sc.scrollTop;
      const max = Math.max(0, sc.scrollHeight - sc.clientHeight);
      const canDown = dy > 0 && st < max - tol;
      const canUp = dy < 0 && st > tol;
      if (canDown || canUp) ev.preventDefault();
      if (canDown || canUp) sc.scrollTop = Math.min(max, Math.max(0, st + dy));
    }

    function attachHorizontalVerticalClusters() {
      teardownVerticalClusterWheelCaptures();
      if (reduceMotion) return;
      document.querySelectorAll(".story-panel--vcluster .story-vstack").forEach(box => {
        box.addEventListener("wheel", clusterInnerWheelGuard, { passive: false });
        verticalClusterWheelCleanups.push(() => box.removeEventListener("wheel", clusterInnerWheelGuard));
      });
    }

    /** Panel `from(...)` entrances driven by scrub strip tween (requires `horizontal: true` + `containerAnimation`). */
    function initHorizontalPanelReveals(containerTween) {
      teardownHorizontalPanelReveals();
      if (!window.gsap || !window.ScrollTrigger || !containerTween || reduceMotion) return;

      gsap.utils.toArray("#storyRoll .story-panel").forEach(panel => {
        const revealRoot = panel.classList.contains("story-panel--vcluster")
          ? panel.querySelector(".story-subslide")
          : panel;
        if (!revealRoot) return;
        const targets = revealRoot.querySelectorAll(PANEL_REVEAL_SEL);
        if (!targets.length) return;
        const vars = panel.classList.contains("story-panel--vcluster")
          ? panelRevealTweenVars(revealRoot, false)
          : panelRevealTweenVars(panel, false);
        const anim = gsap.from(targets, {
          ...vars,
          immediateRender: false,
          scrollTrigger: {
            trigger: panel,
            horizontal: true,
            containerAnimation: containerTween,
            start: "left 92%",
            end: "left 38%",
            once: true,
            invalidateOnRefresh: true,
          },
        });
        horizontalPanelRevealAnims.push(anim);
      });
      ScrollTrigger.refresh();
    }

    let scrollTriggerSizingHooked = false;

    /** Re-measure after paint + window.load so pin/end match final scrollWidth (avoids empty slides). */
    function queueScrollTriggerSizingPass() {
      const run = () => {
        if (!window.ScrollTrigger) return;
        syncStoryViewportWidthCss();
        if (horizontalTween) horizontalTween.invalidate();
        ScrollTrigger.refresh(true);
        const st = horizontalTween && horizontalTween.scrollTrigger;
        const onlyIntroOrNoHash =
          !location.hash || location.hash === "#" || location.hash === "#intro";
        /** scrollY pinned at section start should map to ~progress 0; high progress ⇒ scrub state machine bug (often RTL + snap). */
        const pinnedAtStartBroken =
          st &&
          typeof st.start === "number" &&
          document.body.classList.contains("is-scrollstory") &&
          !document.body.classList.contains("pitch-vertical") &&
          onlyIntroOrNoHash &&
          window.scrollY <= st.start + 40 &&
          st.progress > 0.85;
        const stuckAtEndDesktop =
          st &&
          document.body.classList.contains("is-scrollstory") &&
          !document.body.classList.contains("pitch-vertical") &&
          !location.hash &&
          window.scrollY < 12 &&
          st.progress > 0.92;
        if (pinnedAtStartBroken || stuckAtEndDesktop) {
          window.scrollTo(0, 0);
          horizontalTween.invalidate();
          ScrollTrigger.refresh(true);
        }
      };
      requestAnimationFrame(() => {
        requestAnimationFrame(run);
      });
      if (scrollTriggerSizingHooked) return;
      scrollTriggerSizingHooked = true;
      const afterLoad = () => {
        requestAnimationFrame(() => {
          requestAnimationFrame(run);
        });
      };
      if (document.readyState === "complete") afterLoad();
      else window.addEventListener("load", afterLoad, { once: true });
    }

    function initVerticalPanelReveals() {
      gsap.registerPlugin(ScrollTrigger);
      gsap.utils.toArray(".story-panel").forEach(panel => {
        gsap.from(panel.querySelectorAll(PANEL_REVEAL_SEL), {
          ...panelRevealTweenVars(panel, true),
          immediateRender: false,
          scrollTrigger: {
            trigger: panel,
            start: "top 86%",
            once: true,
          },
        });
      });
    }

    function initScrollStory() {
      teardownHorizontalStory();
      teardownPassiveProgress();
      document.body.classList.remove("is-scrollstory", "scroll-rtlflow", "pitch-vertical");
      document.documentElement.classList.remove("pitch-vertical-desktop");

      const cfg = authorStoryMotion();
      const isDesktop = matchMedia("(min-width: 861px)").matches;
      const hasGsap = window.gsap && window.ScrollTrigger;

      if (!hasGsap || reduceMotion) {
        addPassiveProgress();
        return;
      }

      if (cfg.verticalDesktop && isDesktop) {
        document.body.classList.add("pitch-vertical");
        document.documentElement.classList.add("pitch-vertical-desktop");
        addPassiveProgress();
        initVerticalPanelReveals();
        return;
      }

      if (!isDesktop) {
        addPassiveProgress();
        return;
      }

      gsap.registerPlugin(ScrollTrigger);
      try {
        if ("scrollRestoration" in history) history.scrollRestoration = "manual";
      } catch (_) {}
      scrollTo(0, 0);

      syncStoryViewportWidthCss();
      document.body.classList.add("is-scrollstory");
      if (cfg.rtlFlow) document.body.classList.add("scroll-rtlflow");

      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          try {
            syncStoryViewportWidthCss();
            void trackRoll.offsetWidth;
            const panels = gsap.utils.toArray("#storyRoll .story-panel");
            const maxSpan = Math.max(1, panels.length - 1);
            /**
             * Vertical scroll distance for the pinned horizontal scrub.
             * Must stay in sync with real strip width: if this is too small, scrollY≈0 still maps to progress≈1
             * and only the last panel (e.g. pitch-test-08) fills the viewport.
             */
            const getLanePx = () => {
              void trackRoll.offsetWidth;
              if (storyTrackEl) {
                const r = storyTrackEl.getBoundingClientRect();
                const w = Math.round(r.width || storyTrackEl.clientWidth || 0);
                if (w > 0) return w;
              }
              return Math.max(1, Math.round(window.innerWidth || document.documentElement.clientWidth || 1));
            };
            const getMaxScroll = () => {
              syncStoryViewportWidthCss();
              void trackRoll.offsetWidth;
              const lane = getLanePx();
              let measured = trackRoll.scrollWidth - lane;
              if (!Number.isFinite(measured)) measured = 0;
              measured = Math.max(0, measured);
              /** Wide cold load often yields a tiny but non‑zero measured (e.g. 50px) → pin range shrinks → progress clamps to 1 → only final slide. Always take at least (n−1)·lane (GSAP horizontal-scroll pattern). */
              const fallback = maxSpan * lane;
              return Math.max(1, measured, fallback);
            };

            /*
              RTL mode (body.scroll-rtlflow) mirrors .story-mirror + each .story-panel (text un-mirrors).
              Horizontal scrub must stay x: 0 → -getMaxScroll(): if we "swap" from/to, progress 0 maps to
              translateX(-full) and the viewport lands on the last DOM panel first (pitch-test‑08 bug).
            */

            horizontalTween = gsap.fromTo(
              trackRoll,
              { x: 0 },
              {
                x: () => -getMaxScroll(),
                ease: "none",
                scrollTrigger: {
                  invalidateOnRefresh: true,
                  trigger: "#story",
                  pin: true,
                  scrub: 1,
                  /*
                    ScrollTrigger snap frequently mis-resolves during first refresh with RTL/page restore,
                    pinning scroll to the last segment while URL/#intro expects progress 0. Re-enable snap
                    only after a proven stable pattern if step snapping is needed.
                  */
                  snap: false,
                  end: () => "+=" + getMaxScroll(),
                  onUpdate: self => setProgress(self.progress),
                },
              }
            );

            mainScrollTrigger = horizontalTween.scrollTrigger;

            ScrollTrigger.refresh();
            window.scrollTo(0, 0);
            queueScrollTriggerSizingPass();
            requestAnimationFrame(() => {
              window.scrollTo(0, 0);
              ScrollTrigger.refresh();
              initHorizontalPanelReveals(horizontalTween);
              attachHorizontalVerticalClusters();
            });
          } catch (err) {
            console.warn("[scrollstory]", err);
          }
        });
      });
    }

    function addPassiveProgress() {
      teardownPassiveProgress();
      const update = () => {
        const max = Math.max(1, document.documentElement.scrollHeight - innerHeight);
        setProgress(scrollY / max);
      };
      window.addEventListener("scroll", update, { passive: true });
      passiveProgressCleanup = () => window.removeEventListener("scroll", update);
      update();
    }

    document.querySelectorAll('a[href^="#"]').forEach(link => {
      link.addEventListener("click", event => {
        const href = link.getAttribute("href");
        const targetId = href && href.startsWith("#") ? decodeURIComponent(href.slice(1)) : "";
        if (!href || href === "#" || !targetId) return;
        const targetElement = document.getElementById(targetId);
        if (!targetElement) return;
        event.preventDefault();
        const anchorPanel = targetElement.closest(".story-panel");
        if (mainScrollTrigger && document.body.classList.contains("is-scrollstory") && !document.body.classList.contains("pitch-vertical") && anchorPanel?.classList.contains("story-panel")) {
          const vst = anchorPanel.querySelector(":scope > .story-vstack");
          if (targetElement.classList.contains("story-subslide") && vst) {
            vst.scrollTo({ top: targetElement.offsetTop, behavior: "auto" });
          }
          const rollPanels = gsap.utils.toArray("#storyRoll > .story-panel");
          const denom = Math.max(1, rollPanels.length - 1);
          const rollIdx = Number(anchorPanel.dataset.rollIndex ?? anchorPanel.dataset.index ?? 0);
          const progress = denom ? rollIdx / denom : 0;
          const top = mainScrollTrigger.start + (mainScrollTrigger.end - mainScrollTrigger.start) * progress;
          scrollTo({ top, behavior: "auto" });
          return;
        }
        targetElement.scrollIntoView({ behavior: reduceMotion ? "auto" : "smooth", block: "start", inline: "start" });
      });
    });

    initScrollStory();

    syncStoryViewportWidthCss();
    window.addEventListener("resize", () => {
      syncStoryViewportWidthCss();
      if (window.ScrollTrigger) ScrollTrigger.refresh();
    });

    const desktopStoryMq = window.matchMedia("(min-width: 861px)");
    const onViewportStoryTierChange = () => {
      syncStoryViewportWidthCss();
      initScrollStory();
    };
    if (typeof desktopStoryMq.addEventListener === "function") {
      desktopStoryMq.addEventListener("change", onViewportStoryTierChange);
    } else if (typeof desktopStoryMq.addListener === "function") {
      desktopStoryMq.addListener(onViewportStoryTierChange);
    }
  </script>
</body>
</html>
