    /* Intro flow diagram: dotted board, wired SVG arcs, phased node pulses (RTL logical grid columns) */
    .intro-pipeline-wrap {
      margin: 0;
      width: 100%;
      max-width: min(100%, 44rem);
    }

    .intro-pipeline-diagram.intro-pipeline-excal {
      position: relative;
      margin: 0;
      padding: clamp(14px, 2.2vw, 22px) clamp(12px, 2.4vw, 20px) clamp(12px, 2vw, 18px);
      border: 2px solid var(--v1-ink);
      border-radius: 22px;
      background-color: rgb(255 255 255 / 0.96);
      background-image:
        radial-gradient(rgb(249 84 62 / 0.07) 1px, transparent 1px),
        linear-gradient(135deg, rgb(255 255 255 / 0.94), rgb(252 233 228 / 0.55));
      background-size:
        20px 20px,
        auto;
      box-shadow:
        0 14px 34px rgb(15 23 42 / 0.07),
        4px 4px 0 rgb(0 0 0 / 0.1);
      overflow: clip;
      display: grid;
      grid-template-columns: repeat(6, minmax(0, 1fr));
      grid-template-rows:
        clamp(34px, 5.5vw, 44px)
        auto;
      column-gap: clamp(6px, 1.25vw, 12px);
      row-gap: 10px;
      align-items: center;
      direction: rtl;
    }

    .intro-pipeline-edge-layer {
      grid-column: 1 / -1;
      grid-row: 1;
      width: 100%;
      height: 100%;
      min-height: clamp(34px, 5.5vw, 44px);
      display: block;
      overflow: visible;
      pointer-events: none;
      z-index: 0;
    }

    .intro-pipeline-diagram.intro-pipeline-excal:not(.intro-pipeline-diagram--inview) .intro-pipeline-edge {
      opacity: 0.75;
      animation-play-state: paused;
      stroke-dashoffset: 0.35;
    }

    .intro-pipeline-edge {
      stroke-dasharray: 0.2 0.8;
      animation: introPipelineDash 3.2s linear infinite;
      opacity: 0.96;
      will-change: stroke-dashoffset;
    }

    .intro-pipeline-diagram.intro-pipeline-excal.intro-pipeline-diagram--inview .intro-pipeline-edge {
      animation-play-state: running;
    }

    .intro-pipeline-edge--1 {
      animation-delay: -0s;
    }

    .intro-pipeline-edge--2 {
      animation-delay: -0.58s;
    }

    .intro-pipeline-edge--3 {
      animation-delay: -1.17s;
    }

    .intro-pipeline-edge--4 {
      animation-delay: -1.74s;
    }

    .intro-pipeline-edge--5 {
      animation-delay: -2.32s;
    }

    @keyframes introPipelineDash {
      to {
        stroke-dashoffset: -1;
      }
    }

    @keyframes introPipelineNodePulse {
      0%,
      58% {
        opacity: 0.8;
      }

      8% {
        opacity: 1;
      }

      12% {
        opacity: 0.88;
      }
    }

    .intro-pipeline-node-slot.intro-pipeline-node {
      grid-row: 2;
      justify-self: center;
      align-self: start;
      position: relative;
      z-index: 1;
      max-width: 100%;
    }

    .intro-pipeline-node-slot--1 {
      grid-column: 1;
    }

    .intro-pipeline-node-slot--2 {
      grid-column: 2;
    }

    .intro-pipeline-node-slot--3 {
      grid-column: 3;
    }

    .intro-pipeline-node-slot--4 {
      grid-column: 4;
    }

    .intro-pipeline-node-slot--5 {
      grid-column: 5;
    }

    .intro-pipeline-node-slot--6 {
      grid-column: 6;
    }

    .intro-pipeline-diagram.intro-pipeline-excal.intro-pipeline-diagram--inview .intro-pipeline-node.intro-pipeline-node--a {
      animation: introPipelineNodePulse 9.6s ease-in-out infinite;
      animation-delay: 0s;
    }

    .intro-pipeline-diagram.intro-pipeline-excal.intro-pipeline-diagram--inview .intro-pipeline-node.intro-pipeline-node--b {
      animation: introPipelineNodePulse 9.6s ease-in-out infinite;
      animation-delay: -1.6s;
    }

    .intro-pipeline-diagram.intro-pipeline-excal.intro-pipeline-diagram--inview .intro-pipeline-node.intro-pipeline-node--c {
      animation: introPipelineNodePulse 9.6s ease-in-out infinite;
      animation-delay: -3.2s;
    }

    .intro-pipeline-diagram.intro-pipeline-excal.intro-pipeline-diagram--inview .intro-pipeline-node.intro-pipeline-node--d {
      animation: introPipelineNodePulse 9.6s ease-in-out infinite;
      animation-delay: -4.8s;
    }

    .intro-pipeline-diagram.intro-pipeline-excal.intro-pipeline-diagram--inview .intro-pipeline-node.intro-pipeline-node--e {
      animation: introPipelineNodePulse 9.6s ease-in-out infinite;
      animation-delay: -6.4s;
    }

    .intro-pipeline-diagram.intro-pipeline-excal.intro-pipeline-diagram--inview .intro-pipeline-node.intro-pipeline-node--f {
      animation: introPipelineNodePulse 9.6s ease-in-out infinite;
      animation-delay: -8s;
    }

    .intro-pipeline-flow {
      display: none;
    }

    .intro-pipeline-arrow {
      display: none;
    }

    .intro-pipeline-node {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 10px 12px;
      border: 2px solid var(--v1-ink);
      border-radius: 16px 20px 14px 18px;
      background: rgb(255 255 255 / 0.95);
      box-shadow: 2px 2px 0 rgb(0 0 0 / 0.12);
      font-weight: 950;
      font-size: clamp(0.68rem, 0.22vw + 0.62rem, 0.92rem);
      line-height: 1.22;
      color: var(--v1-ink);
      hyphens: auto;
      box-sizing: border-box;
      transform-origin: center;
      transition:
        opacity 0.35s ease,
        box-shadow 0.35s ease;
    }

    .intro-pipeline-node--a {
      transform: rotate(-0.65deg);
    }

    .intro-pipeline-node--b {
      transform: rotate(0.55deg);
    }

    .intro-pipeline-node--c {
      transform: rotate(-0.45deg);
    }

    .intro-pipeline-node--d {
      transform: rotate(0.5deg);
    }

    .intro-pipeline-node--e {
      transform: rotate(-0.4deg);
    }

    .intro-pipeline-node--f {
      transform: rotate(0.42deg);
    }

    @media (prefers-reduced-motion: reduce) {
      .intro-pipeline-diagram.intro-pipeline-excal:not(.intro-pipeline-diagram--inview) .intro-pipeline-edge {
        opacity: 1;
      }

      .intro-pipeline-edge {
        animation: none !important;
        opacity: 1 !important;
        stroke-dashoffset: 0 !important;
        stroke-dasharray: none !important;
      }

      .intro-pipeline-node {
        animation: none !important;
      }

      .intro-pipeline-diagram.intro-pipeline-excal .intro-pipeline-node {
        opacity: 1;
      }
    }

    @media (max-width: 1110px) {
      .intro-pipeline-diagram.intro-pipeline-excal .intro-pipeline-node {
        font-size: clamp(0.62rem, 0.08vw + 0.54rem, 0.74rem);
