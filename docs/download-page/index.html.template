    let index = 0;
    let notesOpen = true;

    const els = {
      stage: document.getElementById("stage"),
      prev: document.getElementById("prevBtn"),
      next: document.getElementById("nextBtn"),
      overview: document.getElementById("overview"),
      overviewBtn: document.getElementById("overviewBtn"),
      overviewGrid: document.getElementById("overviewGrid"),
      closeOverview: document.getElementById("closeOverview"),
      notesBtn: document.getElementById("notesBtn"),
      notesPanel: document.getElementById("notesPanel"),
      notesText: document.getElementById("notesText"),
      notesMeta: document.getElementById("notesMeta"),
      fullBtn: document.getElementById("fullBtn"),
      progress: document.getElementById("progressFill"),
      status: document.getElementById("statusText"),
      png: document.getElementById("pngBtn"),
      json: document.getElementById("jsonBtn"),
      excalidraw: document.getElementById("excalidrawBtn"),
      toast: document.getElementById("toast")
    };

    function escapeHtml(value) {
      return String(value ?? "").replace(/[&<>"']/g, ch => ({
        "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;"
      }[ch]));
    }

    function seededNoise(seed) {
      const x = Math.sin(seed * 999) * 10000;
      return x - Math.floor(x);
    }
    function jitter(value, seed, amount = 4) {
      return value + (seededNoise(seed) - .5) * amount;
    }
    function roughRectPath(x, y, w, h, seed = 1) {
      const p = [
        [jitter(x, seed), jitter(y, seed + 1)],
        [jitter(x + w, seed + 2), jitter(y, seed + 3)],
        [jitter(x + w, seed + 4), jitter(y + h, seed + 5)],
        [jitter(x, seed + 6), jitter(y + h, seed + 7)]
      ];
      return `M ${p.map(pt => pt.join(" ")).join(" L ")} Z`;
    }
    function roughDiamondPath(x, y, w, h, seed = 1) {
      const p = [
        [jitter(x + w / 2, seed), jitter(y, seed + 1)],
        [jitter(x + w, seed + 2), jitter(y + h / 2, seed + 3)],
        [jitter(x + w / 2, seed + 4), jitter(y + h, seed + 5)],
        [jitter(x, seed + 6), jitter(y + h / 2, seed + 7)]
      ];
      return `M ${p.map(pt => pt.join(" ")).join(" L ")} Z`;
    }
    function linePath(x1, y1, x2, y2, seed = 1) {
      const mx = (x1 + x2) / 2;
      const my = (y1 + y2) / 2;
      return `M ${jitter(x1, seed)} ${jitter(y1, seed + 1)} Q ${jitter(mx, seed + 2, 18)} ${jitter(my, seed + 3, 18)} ${jitter(x2, seed + 4)} ${jitter(y2, seed + 5)}`;
    }
    function arrowHead(x1, y1, x2, y2) {
      const angle = Math.atan2(y2 - y1, x2 - x1);
      const size = 17;
      const p1 = [x2 + Math.cos(angle + Math.PI * .82) * size, y2 + Math.sin(angle + Math.PI * .82) * size];
      const p2 = [x2 + Math.cos(angle - Math.PI * .82) * size, y2 + Math.sin(angle - Math.PI * .82) * size];
      return `M ${p1[0]} ${p1[1]} L ${x2} ${y2} L ${p2[0]} ${p2[1]}`;
    }

    function sketchElement(el, i, accent) {
      const seed = i * 17 + 3;
      const label = el.label || "";
      const common = `class="drawn" style="--dash:1200" fill="none" stroke="${accent}" stroke-width="4"`;
      let shape = "";
      if (["box", "frame", "callout"].includes(el.type)) {
        const fill = el.type === "callout" ? "rgb(255 255 255 / .36)" : "rgb(255 255 255 / .18)";
        shape = `<path d="${roughRectPath(el.x, el.y, el.w, el.h, seed)}" fill="${fill}" stroke="${accent}" stroke-width="${el.type === "frame" ? 5 : 4}" class="drawn" style="--dash:1400"></path>`;
      } else if (el.type === "diamond") {
        shape = `<path d="${roughDiamondPath(el.x, el.y, el.w, el.h, seed)}" fill="rgb(255 255 255 / .18)" stroke="${accent}" stroke-width="4" class="drawn" style="--dash:1000"></path>`;
      } else if (el.type === "ellipse") {
        shape = `<ellipse cx="${el.x + el.w / 2}" cy="${el.y + el.h / 2}" rx="${el.w / 2}" ry="${el.h / 2}" fill="rgb(255 255 255 / .18)" stroke="${accent}" stroke-width="4" class="drawn" style="--dash:1000"></ellipse>`;
      } else if (el.type === "circle") {
        shape = `<ellipse cx="${el.x}" cy="${el.y}" rx="${el.r}" ry="${el.r}" fill="rgb(255 255 255 / .2)" stroke="${accent}" stroke-width="4" class="drawn" style="--dash:700"></ellipse>`;
      } else if (el.type === "line") {
        shape = `<path d="${linePath(el.x1, el.y1, el.x2, el.y2, seed)}" ${common}></path>`;
      } else if (el.type === "arrow") {
        shape = `<path d="${linePath(el.x1, el.y1, el.x2, el.y2, seed)}" ${common}></path><path d="${arrowHead(el.x1, el.y1, el.x2, el.y2)}" ${common}></path>`;
      } else if (el.type === "scribble") {
        const y = el.y + el.h / 2;
        const d = Array.from({ length: 9 }, (_, n) => {
          const x = el.x + (el.w / 8) * n;
          const yy = y + Math.sin(n * 1.7) * el.h * .36;
          return `${n ? "L" : "M"} ${jitter(x, seed + n, 8)} ${jitter(yy, seed + n + 10, 8)}`;
        }).join(" ");
        shape = `<path d="${d}" ${common}></path>`;
      }
      if (label) {
        const hasBox = Number.isFinite(Number(el.x));
        const lx = hasBox ? Number(el.x) + Number(el.w || 0) / 2 : (Number(el.x1 || 0) + Number(el.x2 || 0)) / 2;
        const ly = hasBox ? Number(el.y) + Number(el.h || 0) / 2 + 7 : (Number(el.y1 || 0) + Number(el.y2 || 0)) / 2 - 12;
        shape += `<text x="${lx}" y="${ly}" text-anchor="middle" direction="rtl" fill="#000" font-size="25" font-weight="850">${escapeHtml(label)}</text>`;
      }
      return `<g class="sketch-item" data-sketch-id="${escapeHtml(el.id)}">${shape}</g>`;
    }

    function renderSketch(slide) {
      const accent = slide.theme.accent;
      return `<svg class="sketch" viewBox="0 0 ${SIZE.w} ${SIZE.h}" role="img" aria-label="${escapeHtml(slide.title)}">
        <g class="sketch-camera">${slide.sketch.map((el, i) => sketchElement(el, i, accent)).join("")}</g>
      </svg>`;
    }

    function render() {
      const slide = slides[index];
      const links = (slide.links || []).map(link => `
        <a class="${link.primary ? "primary-link" : ""}" href="${escapeHtml(link.href)}" target="_blank" rel="noreferrer">
          <span>${escapeHtml(link.label)}</span>
        </a>
      `).join("");
      els.stage.style.setProperty("--slide-paper", slide.theme.paper);
      els.stage.style.setProperty("--slide-ink", slide.theme.ink);
      els.stage.style.setProperty("--slide-accent", slide.theme.accent);
      els.stage.innerHTML = `
        <div class="paper-grid"></div>
        ${renderSketch(slide)}
        <div class="slide-copy">
          <div class="kicker">${escapeHtml(slide.kicker)}</div>
          <h1>${escapeHtml(slide.title)}</h1>
          <p class="subtitle">${escapeHtml(slide.subtitle)}</p>
          <ul class="bullets">${slide.bullets.map(item => `<li>${escapeHtml(item)}</li>`).join("")}</ul>
          ${links ? `<div class="link-actions">${links}</div>` : ""}
        </div>
        <div class="slide-number">${String(index + 1).padStart(2, "0")} / ${String(slides.length).padStart(2, "0")}</div>
      `;
      els.notesText.value = slide.notes;
      els.notesMeta.textContent = `שקף ${index + 1}`;
      els.progress.style.setProperty("--progress", `${((index + 1) / slides.length) * 100}%`);
      els.status.textContent = `${index + 1} / ${slides.length}`;
      els.notesPanel.hidden = !notesOpen;
      els.notesBtn.setAttribute("aria-pressed", String(notesOpen));
      renderOverview();
      animateSlide();
    }

    function animateSlide() {
      if (!hasGsap) {
        els.stage.querySelectorAll(".drawn").forEach(el => { el.style.strokeDashoffset = 0; });
        els.stage.querySelectorAll(".sketch-item, .bullets li, .link-actions a").forEach(el => { el.style.opacity = 1; el.style.transform = "none"; });
        return;
      }
      const q = gsap.utils.selector(els.stage);
      gsap.killTweensOf([els.stage, ...q("*")]);
      const tl = gsap.timeline({ defaults: { ease: "power3.out" } });
      tl.fromTo(els.stage, { autoAlpha: 0, y: 28, rotateX: 3, scale: .98, filter: "blur(8px)" }, { autoAlpha: 1, y: 0, rotateX: 0, scale: 1, filter: "blur(0px)", duration: .62 });
      tl.fromTo(q(".kicker"), { autoAlpha: 0, x: 22 }, { autoAlpha: 1, x: 0, duration: .36 }, "-=.32");
      tl.fromTo(q("h1"), { autoAlpha: 0, y: 30 }, { autoAlpha: 1, y: 0, duration: .58 }, "-=.18");
      tl.fromTo(q(".subtitle"), { autoAlpha: 0, y: 18 }, { autoAlpha: 1, y: 0, duration: .42 }, "-=.28");
      tl.fromTo(q(".bullets li"), { autoAlpha: 0, y: 18 }, { autoAlpha: 1, y: 0, duration: .34, stagger: .07 }, "-=.16");
      tl.fromTo(q(".link-actions a"), { autoAlpha: 0, y: 18 }, { autoAlpha: 1, y: 0, duration: .34, stagger: .08 }, "-=.08");
      q(".sketch-item").forEach((item, i) => {
        const strokes = item.querySelectorAll(".drawn");
        const at = .42 + i * .06;
        tl.fromTo(item, { autoAlpha: 0, y: 14, scale: .98 }, { autoAlpha: 1, y: 0, scale: 1, duration: .36 }, at);
        tl.fromTo(strokes, { strokeDashoffset: 1200 }, { strokeDashoffset: 0, duration: .72, ease: "power2.inOut" }, at + .03);
      });
      tl.fromTo(q(".slide-number"), { autoAlpha: 0, y: 12 }, { autoAlpha: 1, y: 0, duration: .24 }, "-=.24");
    }

    function renderOverview() {
      els.overviewGrid.innerHTML = slides.map((slide, i) => `
        <button class="thumb ${i === index ? "is-current" : ""}" data-index="${i}">
          <small>${String(i + 1).padStart(2, "0")} · ${escapeHtml(slide.frameName)}</small>
          <strong>${escapeHtml(slide.title)}</strong>
          <span>${escapeHtml(slide.subtitle)}</span>
        </button>
      `).join("");
      els.overviewGrid.querySelectorAll(".thumb").forEach(btn => {
        btn.addEventListener("click", () => {
          index = Number(btn.dataset.index);
          closeOverview();
          render();
        });
      });
    }

    function go(delta) {
      index = Math.max(0, Math.min(slides.length - 1, index + delta));
      render();
    }
    function openOverview() {
      els.overview.classList.add("is-open");
      els.overview.setAttribute("aria-hidden", "false");
    }
    function closeOverview() {
      els.overview.classList.remove("is-open");
      els.overview.setAttribute("aria-hidden", "true");
      els.stage.focus();
    }
    function showToast(message) {
      els.toast.textContent = message;
      els.toast.classList.add("is-visible");
      clearTimeout(showToast.timer);
      showToast.timer = setTimeout(() => els.toast.classList.remove("is-visible"), 1600);
    }
    function downloadBlob(blob, filename) {
      const a = document.createElement("a");
      a.href = URL.createObjectURL(blob);
      a.download = filename;
      document.body.appendChild(a);
      a.click();
      a.remove();
      setTimeout(() => URL.revokeObjectURL(a.href), 1000);
    }
    function exportJson() {
      downloadBlob(new Blob([JSON.stringify({ deckTitle: "WeatherV1 Next", language: "he", direction: "rtl", slides }, null, 2)], { type: "application/json" }), "weatherv1-hebrew-presentation.json");
      showToast("JSON יוצא.");
    }
    function deckToExcalidraw() {
      const elements = [];
      slides.forEach((slide, i) => {
        const frame = {
          id: `frame-${slide.id}`,
          type: "frame",
          x: i * (SIZE.w + 180),
          y: 0,
          width: SIZE.w,
          height: SIZE.h,
          angle: 0,
          strokeColor: "#000000",
          backgroundColor: "transparent",
          fillStyle: "solid",
          strokeWidth: 2,
          strokeStyle: "solid",
          roughness: 1,
          opacity: 100,
          groupIds: [],
          frameId: null,
          roundness: null,
          seed: 1 + i,
          version: 1,
          versionNonce: 1000 + i,
          isDeleted: false,
          boundElements: null,
          updated: Date.now(),
          link: null,
          locked: false,
          name: slide.frameName
        };
        const textBase = { type: "text", angle: 0, strokeColor: slide.theme.ink, backgroundColor: "transparent", fillStyle: "solid", strokeWidth: 1, strokeStyle: "solid", roughness: 1, opacity: 100, groupIds: [], frameId: frame.id, roundness: null, version: 1, isDeleted: false, boundElements: null, updated: Date.now(), link: null, locked: false, fontFamily: 1, textAlign: "right", verticalAlign: "top", containerId: null, lineHeight: 1.18 };
        elements.push(
          { ...textBase, id: `${frame.id}-kicker`, x: frame.x + 840, y: 76, width: 360, height: 28, seed: 20 + i, versionNonce: 2000 + i, fontSize: 20, text: slide.kicker, originalText: slide.kicker, baseline: 18, strokeColor: slide.theme.accent },
          { ...textBase, id: `${frame.id}-title`, x: frame.x + 720, y: 128, width: 480, height: 86, seed: 30 + i, versionNonce: 3000 + i, fontSize: 58, text: slide.title, originalText: slide.title, baseline: 50 },
          { ...textBase, id: `${frame.id}-subtitle`, x: frame.x + 720, y: 238, width: 480, height: 92, seed: 40 + i, versionNonce: 4000 + i, fontSize: 25, text: slide.subtitle, originalText: slide.subtitle, baseline: 22 },
          ...slide.bullets.map((bullet, b) => ({ ...textBase, id: `${frame.id}-bullet-${b + 1}`, x: frame.x + 760, y: 380 + b * 40, width: 430, height: 32, seed: 50 + b + i, versionNonce: 5000 + b + i, fontSize: 24, text: `• ${bullet}`, originalText: `• ${bullet}`, baseline: 21 }))
        );
        slide.sketch.forEach((el, s) => {
          if (!["box", "frame", "callout"].includes(el.type)) return;
          elements.push({
            id: el.id,
            type: "rectangle",
            x: frame.x + el.x,
            y: frame.y + el.y,
            width: el.w,
            height: el.h,
            angle: 0,
            strokeColor: slide.theme.accent,
            backgroundColor: "transparent",
            fillStyle: "hachure",
            strokeWidth: 2,
            strokeStyle: "solid",
            roughness: 1.6,
            opacity: 100,
            groupIds: [],
            frameId: frame.id,
            roundness: { type: 3 },
            seed: 800 + s,
            version: 1,
            versionNonce: 900 + s,
            isDeleted: false,
            boundElements: null,
            updated: Date.now(),
            link: null,
            locked: false
          });
        });
        elements.push(frame);
      });
      return { type: "excalidraw", version: 2, source: "claude-creative-stack/weatherv1-hebrew-presentation", elements, appState: { viewBackgroundColor: "#F4F3EF", exportEmbedScene: true, currentItemFontFamily: 1 }, files: {} };
    }
    function exportExcalidraw() {
      downloadBlob(new Blob([JSON.stringify(deckToExcalidraw(), null, 2)], { type: "application/json" }), "weatherv1-hebrew-presentation.excalidraw");
      showToast("Excalidraw יוצא.");
    }
    async function exportPng() {
      const svg = `<svg xmlns="http://www.w3.org/2000/svg" width="${SIZE.w}" height="${SIZE.h}" viewBox="0 0 ${SIZE.w} ${SIZE.h}">
        <rect width="1280" height="720" fill="${slides[index].theme.paper}"/>
        <foreignObject x="70" y="50" width="1140" height="620">
          <div xmlns="http://www.w3.org/1999/xhtml" dir="rtl" style="font: 700 28px Heebo, system-ui; color:${slides[index].theme.ink}">
            <div style="color:${slides[index].theme.accent};font-size:22px;font-weight:900">${escapeHtml(slides[index].kicker)}</div>
            <h1 style="font-size:72px;line-height:1;margin:20px 0">${escapeHtml(slides[index].title)}</h1>
            <p style="max-width:620px;font-weight:500">${escapeHtml(slides[index].subtitle)}</p>
            <ul>${slides[index].bullets.map(item => `<li>${escapeHtml(item)}</li>`).join("")}</ul>
          </div>
        </foreignObject>
      </svg>`;
      const blob = new Blob([svg], { type: "image/svg+xml" });
      const url = URL.createObjectURL(blob);
      const img = new Image();
      await new Promise((resolve, reject) => {
        img.onload = resolve;
        img.onerror = reject;
        img.src = url;
      });
      const canvas = document.createElement("canvas");
      canvas.width = SIZE.w * 2;
      canvas.height = SIZE.h * 2;
      const ctx = canvas.getContext("2d");
      ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
      URL.revokeObjectURL(url);
      await new Promise(resolve => canvas.toBlob(blobOut => {
        if (blobOut) downloadBlob(blobOut, `${slides[index].id}.png`);
        resolve();
      }, "image/png"));
      showToast("PNG יוצא.");
    }

    els.prev.addEventListener("click", () => go(-1));
    els.next.addEventListener("click", () => go(1));
    els.overviewBtn.addEventListener("click", openOverview);
    els.closeOverview.addEventListener("click", closeOverview);
    els.notesBtn.addEventListener("click", () => { notesOpen = !notesOpen; render(); });
    els.notesText.addEventListener("input", () => { slides[index].notes = els.notesText.value; });
    els.fullBtn.addEventListener("click", () => {
      if (!document.fullscreenElement) document.documentElement.requestFullscreen?.();
      else document.exitFullscreen?.();
    });
    els.png.addEventListener("click", exportPng);
    els.json.addEventListener("click", exportJson);
    els.excalidraw.addEventListener("click", exportExcalidraw);
    window.addEventListener("keydown", event => {
      if (event.target === els.notesText) return;
      if (event.key === "ArrowLeft" || event.key === "PageDown" || event.key === " ") {
        event.preventDefault();
        go(1);
      } else if (event.key === "ArrowRight" || event.key === "PageUp") {
        event.preventDefault();
        go(-1);
      } else if (event.key.toLowerCase() === "o") {
        openOverview();
      } else if (event.key.toLowerCase() === "n") {
        notesOpen = !notesOpen;
        render();
      } else if (event.key === "Escape") {
        closeOverview();
      }
    });

    window.__weatherV1Presentation = { getSlides: () => slides, deckToExcalidraw };
    render();
    els.stage.focus();
  </script>
</body>
</html>
