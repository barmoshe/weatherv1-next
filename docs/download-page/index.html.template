<!doctype html>
<html lang="he" dir="rtl">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="description" content="Weather V1 — אפליקציה שמקבלת קריינות תחזית, מתמללת ומתכננת סצנות עם רקע מקטלוג V1, ומייצרת בסיס לווידאו תחזית אנכי.">
  <title>Weather V1 — מצגת פתיחה</title>
  <style>
    :root {
      color-scheme: light;
      --v1-red: #ff0000;
      --v1-coral: #f9543e;
      --v1-coral-soft: #fce9e4;
      --v1-cream: #f4f3ef;
      --v1-paper: #ffffff;
      --v1-ink: #000000;
      --v1-muted: #313131;
      --v1-yellow: #f2c231;
      --v1-success: #1fa871;
      --v1-danger: #c8202b;
      --shadow: 8px 8px 0 var(--v1-ink);
      --soft-shadow: 0 18px 46px rgb(0 0 0 / .12);
      --nav-height: 76px;
      /* Mobile pitch tier overrides `--nav-height` + exposes rhythm for panels / anchors */
      --pitch-mobile-nav-buffer: 12px;
      --story-vw: 100vw;
      font-family: Heebo, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    * { box-sizing: border-box; }
    html {
      min-height: 100%;
      scroll-behavior: smooth;
      background: var(--v1-cream);
      overflow-anchor: none;
    }
    body {
      min-height: 100%;
      margin: 0;
      overflow-x: hidden;
      background:
        linear-gradient(90deg, rgb(0 0 0 / .035) 1px, transparent 1px) 0 0 / 28px 28px,
        linear-gradient(0deg, rgb(0 0 0 / .03) 1px, transparent 1px) 0 0 / 28px 28px,
        radial-gradient(circle at 12% 18%, rgb(242 194 49 / .26), transparent 30rem),
        radial-gradient(circle at 86% 68%, rgb(249 84 62 / .18), transparent 36rem),
        var(--v1-cream);
      color: var(--v1-ink);
      font: 16px/1.55 Heebo, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    a { color: inherit; }

    .site-nav {
      position: fixed;
      inset: 12px 12px auto;
      z-index: 50;
      min-height: 58px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      padding: 8px 10px;
      border: 2px solid var(--v1-ink);
      border-radius: 18px;
      background: rgb(249 84 62 / .96);
      box-shadow: 5px 5px 0 var(--v1-ink);
      backdrop-filter: blur(10px);
    }

    .brand {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      min-width: 0;
      text-decoration: none;
      font-weight: 900;
    }

    .brand-mark {
      width: 40px;
      height: 40px;
      flex: 0 0 auto;
      display: grid;
      place-items: center;
      overflow: hidden;
      border: 2px solid var(--v1-ink);
      border-radius: 10px;
      background: var(--v1-paper);
      box-shadow: 3px 3px 0 var(--v1-ink);
    }

    .brand-mark img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      display: block;
    }

    .brand-copy {
      display: grid;
      gap: 1px;
      line-height: 1.05;
    }

    .brand-copy strong {
      white-space: nowrap;
      font-size: 1rem;
    }

    .brand-copy span {
      color: rgb(0 0 0 / .7);
      font-size: .78rem;
      font-weight: 800;
    }

    .nav-actions {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .nav-link,
    .cta {
      min-height: 38px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 0 14px;
      border: 1.5px solid var(--v1-ink);
      border-radius: 12px;
      background: rgb(255 255 255 / .78);
      color: var(--v1-ink);
      box-shadow: 2px 2px 0 var(--v1-ink);
      text-decoration: none;
      font-weight: 900;
      white-space: nowrap;
      cursor: pointer;
      transition: transform 160ms ease, box-shadow 160ms ease, background 160ms ease;
    }

    .cta {
      background: var(--v1-red);
      color: #fff;
    }

    .nav-link:hover,
    .cta:hover {
      transform: translateY(-2px);
      box-shadow: 3px 3px 0 var(--v1-ink);
      background: var(--v1-yellow);
      color: var(--v1-ink);
    }

    .scroll-progress {
      position: fixed;
      inset: auto 18px 14px;
      z-index: 45;
      height: 8px;
      overflow: hidden;
      border: 1.5px solid var(--v1-ink);
      border-radius: 999px;
      background: rgb(255 255 255 / .82);
      box-shadow: 2px 2px 0 var(--v1-ink);
    }

    .scroll-progress span {
      display: block;
      position: absolute;
      inset: 0;
      width: auto;
      height: 100%;
      transform: scaleX(0);
      transform-origin: inline-start;
      background: linear-gradient(90deg, var(--v1-yellow), var(--v1-red));
      will-change: transform;
    }

    .scroll-hint {
      position: fixed;
      inset-inline-start: 18px;
      inset-inline-end: auto;
      inset-block-end: 78px;
      z-index: 46;
      transform: translateY(-100%);
      color: var(--v1-muted);
      font-size: .78rem;
      font-weight: 900;
      pointer-events: none;
      white-space: nowrap;
    }

    .pitch-step-nav {
      position: fixed;
      inset-inline-end: max(14px, env(safe-area-inset-inline-end, 0px));
      inset-inline-start: auto;
      bottom: calc(max(1rem, env(safe-area-inset-bottom, 0px), 8px) + 3.25rem);
      z-index: 48;
      display: flex;
      flex-direction: column;
      align-items: stretch;
      gap: 7px;
      padding: 9px;
      border: 2px solid var(--v1-ink);
      border-radius: 16px;
      background: rgb(255 255 255 / 0.94);
      box-shadow: 4px 4px 0 var(--v1-ink);
      backdrop-filter: blur(14px) saturate(1.15);
      -webkit-backdrop-filter: blur(14px) saturate(1.15);
    }

    .pitch-step-nav button {
      display: grid;
      place-items: center;
      width: 48px;
      height: 48px;
      margin: 0;
      padding: 0;
      border: 2px solid var(--v1-ink);
      border-radius: 11px;
      background: linear-gradient(165deg, rgb(255 255 255 / 1) 0%, rgb(252 252 252 / 1) 55%, rgb(248 248 249 / 1) 100%);
      color: var(--v1-ink);
      box-shadow: 2px 2px 0 rgb(0 0 0 / 0.14);
      cursor: pointer;
      transition:
        transform 160ms ease,
        background 160ms ease,
        box-shadow 160ms ease,
        border-color 160ms ease;
    }

    .pitch-step-nav button .pitch-step-icon {
      display: block;
      flex-shrink: 0;
    }

    #pitch-step-down {
      background: linear-gradient(
        165deg,
        rgb(255 255 255 / 1) 0%,
        rgb(255 247 243 / 1) 48%,
        rgb(252 233 228 / 0.92) 100%
      );
    }

    .pitch-step-nav button:hover,
    .pitch-step-nav button:focus-visible {
      background: var(--v1-yellow);
      border-color: var(--v1-ink);
      box-shadow: 3px 3px 0 var(--v1-ink);
      outline: none;
      transform: translateY(-2px);
    }

    #pitch-step-down:hover,
    #pitch-step-down:focus-visible {
      background: linear-gradient(165deg, var(--v1-yellow), rgb(250 210 75 / 1));
    }

    .pitch-step-nav button:focus-visible {
      outline: 3px solid var(--v1-paper);
      outline-offset: 3px;
    }

    .pitch-step-nav button:active:not(:disabled) {
      transform: translateY(0);
      box-shadow: 1px 1px 0 var(--v1-ink);
    }

    .pitch-step-nav button:disabled {
      opacity: 0.42;
      cursor: not-allowed;
      transform: none;
      box-shadow: 2px 2px 0 rgb(0 0 0 / 0.1);
    }

    .pitch-step-nav button:disabled:hover,
    .pitch-step-nav button:disabled:focus-visible {
      background: linear-gradient(165deg, rgb(255 255 255 / 1) 0%, rgb(252 252 252 / 1) 100%);
      transform: none;
      box-shadow: 2px 2px 0 rgb(0 0 0 / 0.1);
      outline: none;
    }

    #pitch-step-down:disabled:hover,
    #pitch-step-down:disabled:focus-visible {
      background: linear-gradient(
        165deg,
        rgb(255 255 255 / 1) 0%,
        rgb(255 247 243 / 1) 48%,
        rgb(252 233 228 / 0.92) 100%
      );
    }

    .story-shell {
      min-height: 100svh;
      overflow: hidden;
      /* Avoid scroll anchoring jumps when pinned strip height/measures settle. */
      overflow-anchor: none;
    }

    /**
     * Story pin + GSAP scrub: isolate geometry to LTR. `html[dir=rtl]` with ScrollTrigger
     * horizontal maps is brittle (community reports misaligned scrub / anchors); copy stays rtl in .panel-inner.
     */
    main#story {
      direction: ltr;
      unicode-bidi: isolate;
    }

    .story-track {
      display: block;
      width: 100%;
      min-height: 100svh;
    }

    .story-mirror {
      width: 100%;
      min-height: 100%;
    }

    .story-roll {
      display: block;
      width: 100%;
      min-height: 100svh;
    }

    /*
      Horizontal carousel: physical LTR flex on #storyRoll + GSAP translateX.
      main#story stays direction:ltr for ScrollTrigger math; body.scroll-rtlflow mirrors strip+panels for RTL story feel.
      Typography remains rtl in .panel-inner.
    */

    .story-panel {
      width: 100%;
      min-height: 100svh;
      padding: calc(var(--nav-height) + 36px) clamp(20px, 5vw, 72px) 64px;
      display: grid;
      place-items: center;
      background:
        linear-gradient(90deg, rgb(0 0 0 / .028) 1px, transparent 1px) 0 0 / 34px 34px,
        linear-gradient(0deg, rgb(0 0 0 / .022) 1px, transparent 1px) 0 0 / 34px 34px,
        var(--panel-paper, var(--v1-paper));
    }

    .panel-inner {
      width: min(1180px, 100%);
      display: grid;
      grid-template-columns: minmax(0, .9fr) minmax(320px, 1.1fr);
      gap: clamp(24px, 5vw, 78px);
      align-items: center;
      direction: rtl;
      unicode-bidi: isolate;
    }

    .panel-copy {
      min-width: 0;
      display: grid;
      gap: 18px;
      justify-items: start;
    }

    .kicker {
      display: inline-block;
      max-width: 100%;
      border-inline-start: 4px solid currentColor;
      padding-inline-start: 12px;
      color: var(--panel-accent, var(--v1-coral));
      font-size: clamp(.78rem, 1.2vw, .95rem);
      font-weight: 950;
      letter-spacing: .04em;
      text-transform: uppercase;
    }

    h1, h2 {
      margin: 0;
      max-width: 10.5ch;
      color: var(--v1-ink);
      font-size: clamp(3rem, 7vw, 7.4rem);
      line-height: .9;
      letter-spacing: 0;
      text-align: start;
    }

    .lead {
      max-width: 34rem;
      margin: 0;
      color: var(--v1-muted);
      font-size: clamp(1.05rem, 1.8vw, 1.55rem);
      font-weight: 700;
      line-height: 1.35;
    }

    .bullets {
      margin: 8px 0 0;
      padding: 0;
      display: grid;
      gap: 10px;
      list-style: none;
      font-weight: 850;
      font-size: clamp(.95rem, 1.35vw, 1.15rem);
    }

    .bullets li {
      display: grid;
      grid-template-columns: 10px 1fr;
      gap: 10px;
      align-items: start;
    }

    .bullets li::before {
      content: "";
      width: 10px;
      height: 10px;
      margin-top: .52em;
      margin-inline: auto;
      border-radius: 999px;
      background: var(--panel-accent, var(--v1-coral));
      box-shadow: 0 0 0 5px rgb(249 84 62 / .14);
    }

    /* English / Latin snippets inside rtl panels */

    .mixed-ltr {
      direction: ltr;
      unicode-bidi: isolate;
    }

    .panel-visual {
      position: relative;
      min-height: min(58svh, 520px);
      display: grid;
      place-items: center;
    }

    .numbered-sample-visual {
      width: min(100%, 520px);
      min-height: min(52svh, 420px);
      border: 3px solid var(--v1-ink);
      border-radius: 24px;
      background: rgb(255 255 255 / .78);
      box-shadow: var(--shadow);
      display: grid;
      place-items: center;
      padding: 24px;
    }

    .numbered-sample-num {
      font-size: clamp(4rem, 22vmin, 9.5rem);
      font-weight: 950;
      line-height: 1;
      color: var(--panel-accent, var(--v1-coral));
      letter-spacing: -0.06em;
      font-variant-numeric: tabular-nums;
      user-select: none;
    }

    /*
      Product-app pitch layout (studio now; reuse shell + bento for catalog slide later).
      Hooks: [data-pitch-layout="product-app"], .pitch-app-shell, .pitch-bento, .pitch-drop-card
    */
    [data-pitch-layout="product-app"] .panel-copy {
      gap: clamp(12px, 2vw, 18px);
    }

    [data-pitch-layout="product-app"] .kicker {
      font-size: clamp(0.62rem, 0.95vw, 0.76rem);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      border-inline-start-width: 3px;
      padding-inline-start: 10px;
    }

    [data-pitch-layout="product-app"] h2 {
      max-width: min(40ch, 100%);
      font-size: clamp(1.28rem, 2.1vw + 0.45rem, 2.28rem);
      line-height: 1.12;
      letter-spacing: -0.03em;
      font-weight: 820;
    }

    [data-pitch-layout="product-app"] .pitch-lead-well {
      margin: 2px 0 0;
      padding: 12px 14px;
      border-radius: 14px;
      border: 1px solid rgb(0 0 0 / 0.08);
      background: linear-gradient(145deg, rgb(255 255 255 / 0.96), rgb(252 241 238 / 0.65));
      box-shadow: 0 1px 0 rgb(255 255 255 / 0.85) inset;
    }

    [data-pitch-layout="product-app"] .pitch-lead-well .lead {
      margin: 0;
      max-width: none;
      font-size: clamp(0.84rem, 1.12vw + 0.22rem, 1.02rem);
      line-height: 1.52;
      font-weight: 620;
      color: rgb(55 58 68 / 1);
    }

    [data-pitch-layout="product-app"] .bullets {
      margin: 6px 0 0;
      padding: 0;
      list-style: none;
      display: grid;
      gap: 8px;
      counter-reset: pitch-step;
    }

    [data-pitch-layout="product-app"] .bullets li {
      counter-increment: pitch-step;
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 11px;
      align-items: start;
      padding: 10px 12px;
      border-radius: 12px;
      border: 1px solid rgb(0 0 0 / 0.07);
      background: rgb(255 255 255 / 0.78);
      box-shadow: 0 1px 2px rgb(0 0 0 / 0.04);
      font-size: clamp(0.76rem, 1vw, 0.9rem);
      font-weight: 760;
      color: rgb(66 68 78 / 1);
      transition:
        border-color 0.22s ease,
        box-shadow 0.22s ease,
        background 0.22s ease,
        color 0.22s ease;
    }

    [data-pitch-layout="product-app"] .bullets li::before {
      content: counter(pitch-step, decimal-leading-zero);
      width: auto;
      height: auto;
      margin: 0;
      padding: 4px 8px;
      border-radius: 8px;
      font-size: 0.59rem;
      font-weight: 950;
      font-variant-numeric: tabular-nums;
      background: rgb(252 236 232 / 1);
      color: var(--panel-accent, var(--v1-coral));
      border: 1px solid rgb(0 0 0 / 0.08);
      box-shadow: none;
    }

    [data-pitch-layout="product-app"] .bullets li.is-wizard-active {
      border-color: color-mix(in srgb, var(--panel-accent, var(--v1-coral)) 42%, rgb(0 0 0 / 0.14));
      background: color-mix(in srgb, var(--panel-accent, var(--v1-coral)) 9%, rgb(255 255 255 / 0.96));
      color: var(--v1-ink);
      font-weight: 830;
      box-shadow: 0 2px 10px rgb(200 32 43 / 0.08);
    }

    [data-pitch-layout="product-app"] .bullets li.is-wizard-active::before {
      background: var(--panel-accent, var(--v1-coral));
      color: #fff;
      border-color: rgb(0 0 0 / 0.12);
    }

    #pricing .panel-visual,
    #analytics .panel-visual,
    #local-first .panel-visual,
    #render .panel-visual,
    #thinking .panel-visual,
    #studio .panel-visual,
    #catalog .panel-visual {
      min-height: min(52svh, 480px);
      align-items: stretch;
      place-items: stretch;
    }

    #v1-next .panel-visual {
      min-height: min(52svh, 480px);
      place-items: start;
      align-items: start;
      align-content: start;
    }

    @media (min-width: 861px) {
      [data-pitch-layout="product-app"] .panel-inner {
        align-items: start;
      }

      #v1-next .panel-inner,
      #pricing .panel-inner,
      #analytics .panel-inner,
      #local-first .panel-inner,
      #render .panel-inner,
      #thinking .panel-inner,
      #studio .panel-inner,
      #catalog .panel-inner {
        grid-template-columns: minmax(0, 0.85fr) minmax(320px, 1.15fr);
      }

      #v1-next .panel-visual,
      #pricing .panel-visual,
      #analytics .panel-visual,
      #local-first .panel-visual,
      #render .panel-visual,
      #thinking .panel-visual,
      #studio .panel-visual,
      #catalog .panel-visual {
        align-self: stretch;
      }
    }

    #catalog .pitch-lead-well {
      background: linear-gradient(145deg, rgb(255 255 255 / 0.98), rgb(236 241 252 / 0.72));
    }

    #thinking .pitch-lead-well {
      margin-block-end: 0;
      background: linear-gradient(145deg, rgb(255 255 255 / 0.98), rgb(239 242 252 / 0.82));
    }

    #thinking h2 {
      margin-block-end: clamp(10px, 1.4vw, 16px);
    }

    #thinking .bullets {
      margin-block-start: 4px;
      width: 100%;
    }

    #thinking .bullets li {
      width: 100%;
      min-width: 0;
      justify-self: stretch;
    }

    #render .pitch-lead-well {
      background: linear-gradient(145deg, rgb(255 255 255 / 0.98), rgb(253 240 232 / 0.82));
    }

    #local-first .pitch-lead-well {
      background: linear-gradient(145deg, rgb(255 255 255 / 0.98), rgb(238 242 249 / 0.85));
    }

    #v1-next .pitch-lead-well {
      background: linear-gradient(145deg, rgb(255 255 255 / 0.98), rgb(247 243 236 / 0.88));
    }

    #pricing .pitch-pricing-quote {
      margin: 12px 0 0;
      padding: 12px 13px 13px;
      border-radius: 14px;
      border: 1px solid rgb(0 0 0 / 0.07);
      border-inline-start: 4px solid color-mix(in srgb, var(--panel-accent, #0d9488) 55%, rgb(20 60 50));
      background: linear-gradient(
        145deg,
        color-mix(in srgb, var(--panel-accent, #0d9488) 5%, rgb(255 255 255 / 0.97)),
        rgb(255 255 255 / 0.92)
      );
      box-shadow: 0 1px 0 rgb(255 255 255 / 0.65) inset;
    }

    #pricing .pitch-pricing-quote p {
      margin: 0;
      font-size: clamp(0.66rem, 1.9vw, 0.74rem);
      font-weight: 780;
      line-height: 1.52;
      color: rgb(42 48 54 / 1);
    }

    /* —— Pitch: pricing hero (`#pricing`) —— */
    .pitch-pricing-hero {
      width: min(100%, 400px);
      margin-inline: auto;
      direction: rtl;
      unicode-bidi: isolate;
    }

    .pitch-pricing-hero__card {
      padding: 20px 18px 18px;
      border-radius: 22px;
      border: 1px solid rgb(0 0 0 / 0.09);
      background: linear-gradient(
        168deg,
        rgb(255 255 255 / 0.97),
        color-mix(in srgb, var(--panel-accent, #0d9488) 7%, rgb(248 253 250))
      );
      box-shadow:
        0 22px 44px rgb(15 23 42 / 0.06),
        0 0 0 1px rgb(255 255 255 / 0.55) inset;
      display: grid;
      gap: 10px;
      justify-items: center;
      text-align: center;
    }

    .pitch-pricing-hero__eyebrow {
      font-size: 0.58rem;
      font-weight: 820;
      letter-spacing: 0.02em;
      color: rgb(82 88 96 / 1);
    }

    .pitch-pricing-hero__amount {
      font-size: clamp(2rem, 6vw, 2.65rem);
      font-weight: 950;
      font-variant-numeric: tabular-nums;
      letter-spacing: -0.03em;
      line-height: 1;
      color: rgb(28 34 40 / 1);
    }

    .pitch-pricing-hero__currency {
      font-size: 0.55em;
      font-weight: 900;
      margin-inline-start: 0.12em;
    }

    .pitch-pricing-hero__vat {
      font-size: 0.72rem;
      font-weight: 850;
      color: rgb(72 78 86 / 1);
    }

    .pitch-pricing-hero__fineprint {
      margin: 0;
      font-size: 0.54rem;
      font-weight: 780;
      color: rgb(118 122 132 / 1);
    }

    .pitch-pricing-hero__chips {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 8px;
      padding-top: 4px;
      width: 100%;
    }

    .pitch-pricing-hero__chip {
      padding: 6px 11px;
      border-radius: 999px;
      font-size: 0.58rem;
      font-weight: 820;
      background: rgb(255 255 255 / 0.9);
      border: 1px solid rgb(0 0 0 / 0.07);
      color: rgb(56 62 70 / 1);
    }

    /* —— Pitch: V1 next steps checklist (`#v1-next`) —— */
    .pitch-v1-next-visual {
      width: min(100%, 400px);
      margin-inline: auto;
      border-radius: 22px;
      border: 1px solid rgb(0 0 0 / 0.09);
      background: linear-gradient(
        168deg,
        rgb(255 255 255 / 0.96),
        color-mix(in srgb, var(--panel-accent, #78716c) 5%, rgb(252 251 248))
      );
      box-shadow:
        0 22px 44px rgb(15 23 42 / 0.05),
        0 0 0 1px rgb(255 255 255 / 0.55) inset;
      padding: 16px 14px 14px;
      direction: rtl;
      unicode-bidi: isolate;
    }

    .pitch-v1-next-visual__inner {
      display: grid;
      gap: 8px;
    }

    .pitch-v1-next-item {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr);
      align-items: start;
      gap: 10px;
      padding: 9px 11px;
      border-radius: 12px;
      border: 1px solid rgb(0 0 0 / 0.07);
      background: rgb(255 255 255 / 0.88);
      box-shadow: 0 1px 0 rgb(255 255 255 / 0.7) inset;
    }

    .pitch-v1-next-item__ico {
      font-size: 1rem;
      line-height: 1.2;
      filter: grayscale(0.08);
      opacity: 0.92;
    }

    .pitch-v1-next-item__text {
      font-size: 0.66rem;
      font-weight: 800;
      line-height: 1.42;
      color: rgb(42 46 52 / 1);
    }

    .pitch-v1-next-visual__note {
      margin: 12px 0 0;
      padding-top: 10px;
      border-top: 1px dashed rgb(0 0 0 / 0.09);
      font-size: 0.56rem;
      font-weight: 780;
      line-height: 1.45;
      color: rgb(108 112 120 / 1);
      text-align: center;
    }

    /* —— Pitch: local-first pillars (`#local-first`) —— */
    .pitch-local-first-visual {
      position: relative;
      isolation: isolate;
      width: min(100%, 640px);
      margin-inline: auto;
      border-radius: 22px;
      border: 1px solid rgb(0 0 0 / 0.09);
      overflow: hidden;
      direction: rtl;
      unicode-bidi: isolate;
      padding: 18px 14px 20px;
      background: rgb(255 255 255 / 0.55);
      box-shadow:
        0 22px 44px rgb(15 23 42 / 0.06),
        0 0 0 1px rgb(255 255 255 / 0.55) inset;
    }

    .pitch-local-first-visual__bg {
      position: absolute;
      inset: -12%;
      pointer-events: none;
      background:
        radial-gradient(ellipse 78% 50% at 18% 20%, color-mix(in srgb, var(--panel-accent, #475569) 18%, transparent), transparent 58%),
        radial-gradient(ellipse 72% 48% at 88% 88%, color-mix(in srgb, var(--panel-accent, #475569) 12%, transparent), transparent 55%),
        linear-gradient(168deg, rgb(255 255 255 / 0.96), rgb(242 245 250 / 0.82));
    }

    .pitch-local-first-grid {
      position: relative;
      z-index: 1;
      display: grid;
      gap: 12px;
      grid-template-columns: 1fr;
    }

    @media (min-width: 520px) {
      .pitch-local-first-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }

    .pitch-local-first-pillar {
      padding: 12px 12px 14px;
      border-radius: 14px;
      border: 1px solid rgb(0 0 0 / 0.08);
      background: linear-gradient(165deg, rgb(255 255 255 / 0.96), rgb(248 250 253 / 0.92));
      box-shadow: 0 1px 0 rgb(255 255 255 / 0.65) inset;
      display: flex;
      flex-direction: column;
      gap: 8px;
      min-height: 100%;
    }

    .pitch-local-first-pillar__ico {
      font-size: 1.15rem;
      line-height: 1;
      filter: grayscale(0.15);
    }

    .pitch-local-first-pillar__title {
      margin: 0;
      font-size: 0.74rem;
      font-weight: 900;
      letter-spacing: -0.02em;
      color: rgb(38 42 48 / 1);
      line-height: 1.25;
    }

    .pitch-local-first-pillar__body {
      margin: 0;
      font-size: 0.62rem;
      font-weight: 780;
      line-height: 1.48;
      color: rgb(72 78 90 / 1);
    }

    /* —— Pitch: final video output (`#render`) —— */
    .pitch-final-output {
      width: min(100%, 440px);
      margin-inline: auto;
      border-radius: 22px;
      border: 1px solid rgb(0 0 0 / 0.09);
      background: linear-gradient(
        168deg,
        rgb(255 255 255 / 0.97),
        color-mix(in srgb, var(--panel-accent, #c2410c) 6%, rgb(255 252 249))
      );
      box-shadow:
        0 22px 44px rgb(15 23 42 / 0.06),
        0 0 0 1px rgb(255 255 255 / 0.55) inset;
      padding: 18px 16px 20px;
      direction: rtl;
      unicode-bidi: isolate;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 14px;
    }

    .pitch-final-output__head {
      align-self: stretch;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
    }

    .pitch-final-output__title {
      font-size: 0.95rem;
      font-weight: 920;
      letter-spacing: -0.02em;
      color: rgb(38 42 48 / 1);
    }

    .pitch-final-output__badge {
      padding: 5px 10px;
      border-radius: 999px;
      font-size: 0.58rem;
      font-weight: 850;
      font-variant-numeric: tabular-nums;
      background: color-mix(in srgb, var(--panel-accent, #c2410c) 11%, rgb(255 255 255));
      border: 1px solid rgb(0 0 0 / 0.07);
      color: rgb(55 60 68 / 1);
    }

    .pitch-final-output .pitch-device {
      margin-inline: auto;
    }

    .pitch-final-output__actions {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: center;
      gap: 10px;
    }

    .pitch-final-output__btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 40px;
      padding: 0 20px;
      border-radius: 12px;
      font-size: 0.72rem;
      font-weight: 880;
      border: 1px solid rgb(0 0 0 / 0.1);
    }

    .pitch-final-output__btn--primary {
      background: color-mix(in srgb, var(--panel-accent, #c2410c) 88%, rgb(40 40 40));
      color: #fff;
      border-color: rgb(0 0 0 / 0.14);
      box-shadow: 0 6px 16px color-mix(in srgb, var(--panel-accent, #c2410c) 22%, transparent);
    }

    .pitch-final-output__btn--ghost {
      background: rgb(255 255 255 / 0.92);
      color: rgb(42 48 56 / 1);
    }

    /* —— Pitch: cognition-flow diagram (`#thinking`) —— */
    .pitch-thinking-visual {
      position: relative;
      isolation: isolate;
      width: min(100%, 640px);
      margin-inline: auto;
      border-radius: 22px;
      border: 1px solid rgb(0 0 0 / 0.09);
      background: rgb(255 255 255 / 0.52);
      box-shadow:
        0 22px 44px rgb(15 23 42 / 0.06),
        0 0 0 1px rgb(255 255 255 / 0.55) inset;
      overflow: hidden;
      direction: rtl;
      unicode-bidi: isolate;
    }

    .pitch-thinking-visual__bg {
      position: absolute;
      inset: -14%;
      pointer-events: none;
      background:
        radial-gradient(ellipse 88% 58% at 78% 14%, color-mix(in srgb, var(--panel-accent, #4338ca) 22%, transparent), transparent 62%),
        radial-gradient(ellipse 72% 52% at 10% 82%, color-mix(in srgb, var(--panel-accent, #4338ca) 14%, transparent), transparent 58%),
        linear-gradient(168deg, rgb(255 255 255 / 0.96), rgb(241 242 252 / 0.8));
    }

    .pitch-thinking-visual__noise {
      position: absolute;
      inset: 0;
      pointer-events: none;
      opacity: 0.042;
      mix-blend-mode: multiply;
      background-image: repeating-linear-gradient(
        -17deg,
        transparent,
        transparent 2px,
        rgb(0 0 0 / 0.05) 2px,
        rgb(0 0 0 / 0.05) 3px
      );
    }

    .pitch-thinking-flow {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      align-items: stretch;
      gap: 2px;
      padding: 18px 16px 16px;
    }

    .pitch-flow-step {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr);
      align-items: center;
      gap: 11px;
      padding: 11px 13px;
      border-radius: 14px;
      border: 1px solid rgb(0 0 0 / 0.08);
      background: linear-gradient(165deg, rgb(255 255 255 / 0.97), rgb(246 246 252 / 0.9));
      box-shadow: 0 1px 0 rgb(255 255 255 / 0.65) inset;
      font-weight: 820;
      font-size: 0.74rem;
      line-height: 1.35;
      color: rgb(48 52 58 / 1);
    }

    .pitch-flow-step-num {
      display: grid;
      place-items: center;
      width: 26px;
      height: 26px;
      border-radius: 999px;
      font-size: 0.62rem;
      font-weight: 950;
      font-variant-numeric: tabular-nums;
      color: #fff;
      background: color-mix(in srgb, var(--panel-accent, #4338ca) 88%, rgb(15 23 42));
      border: 1px solid rgb(0 0 0 / 0.08);
      flex-shrink: 0;
    }

    .pitch-flow-step-label {
      display: block;
      text-wrap: balance;
    }

    .pitch-flow-step-break {
      display: block;
    }

    .pitch-flow-step--hot {
      border-color: color-mix(in srgb, var(--panel-accent, #4338ca) 38%, rgb(0 0 0 / 0.12));
      box-shadow:
        0 0 0 1px color-mix(in srgb, var(--panel-accent, #4338ca) 22%, transparent),
        0 10px 28px color-mix(in srgb, var(--panel-accent, #4338ca) 18%, transparent);
    }

    .pitch-flow-connector {
      display: flex;
      justify-content: center;
      align-items: stretch;
      height: 26px;
      color: color-mix(in srgb, var(--panel-accent, #4338ca) 72%, rgb(100 116 139));
    }

    .pitch-flow-connector-svg {
      width: 40px;
      height: 100%;
      overflow: visible;
    }

    .pitch-flow-path {
      stroke: currentColor;
      fill: none;
    }

    .pitch-thinking-callout {
      margin-top: 12px;
      padding: 12px 13px 13px;
      border-radius: 15px;
      border: 1px solid color-mix(in srgb, var(--panel-accent, #4338ca) 28%, rgb(0 0 0 / 0.1));
      background: linear-gradient(155deg, rgb(255 255 255 / 0.94), color-mix(in srgb, var(--panel-accent, #4338ca) 7%, rgb(255 255 255)));
      box-shadow:
        0 12px 28px color-mix(in srgb, var(--panel-accent, #4338ca) 12%, rgb(15 23 42 / 0.04)),
        0 0 0 1px rgb(255 255 255 / 0.55) inset;
    }

    .pitch-thinking-callout__title {
      font-size: 0.68rem;
      font-weight: 920;
      letter-spacing: -0.02em;
      color: rgb(30 36 42 / 1);
      margin-bottom: 6px;
    }

    .pitch-thinking-callout__body {
      margin: 0;
      font-size: 0.62rem;
      font-weight: 760;
      line-height: 1.5;
      color: rgb(72 78 88 / 1);
    }

    .pitch-scene-hint-chips {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 7px;
      margin-top: 11px;
    }

    .pitch-scene-chip {
      padding: 6px 12px;
      border-radius: 999px;
      font-size: 0.58rem;
      font-weight: 820;
      background: rgb(255 255 255 / 0.94);
      border: 1px solid color-mix(in srgb, var(--panel-accent, #4338ca) 22%, rgb(0 0 0 / 0.08));
      box-shadow:
        0 1px 2px rgb(0 0 0 / 0.05),
        0 0 0 1px rgb(255 255 255 / 0.65) inset;
      color: rgb(52 58 68 / 1);
    }

    @media (prefers-reduced-motion: reduce) {
      .pitch-flow-path {
        stroke-dashoffset: 0 !important;
      }
    }

    /* —— Shared app chrome (catalog can reuse .pitch-app-shell + toolbar/tabs) —— */
    .pitch-app-shell {
      --pitch-app-r: 20px;
      width: min(100%, 720px);
      margin-inline: auto;
      border-radius: var(--pitch-app-r);
      border: 1px solid rgb(0 0 0 / 0.1);
      background: linear-gradient(
        180deg,
        rgb(255 255 255 / 0.98) 0%,
        rgb(252 250 247 / 1) 42%,
        rgb(255 252 250 / 1) 100%
      );
      box-shadow:
        0 22px 44px rgb(15 23 42 / 0.07),
        0 2px 8px rgb(15 23 42 / 0.05),
        0 0 0 1px rgb(255 255 255 / 0.55) inset;
      overflow: hidden;
      direction: rtl;
      unicode-bidi: isolate;
    }

    .pitch-wizard-track {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: center;
      gap: 6px;
      padding: 9px 10px 8px;
      background: linear-gradient(180deg, rgb(255 255 255 / 0.72), rgb(248 246 243 / 0.35));
      border-bottom: 1px solid rgb(0 0 0 / 0.06);
    }

    .pitch-wiz-step {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 5px 11px;
      border-radius: 999px;
      font-size: 0.61rem;
      font-weight: 820;
      letter-spacing: 0.02em;
      color: rgb(95 96 108 / 1);
      background: rgb(255 255 255 / 0.78);
      border: 1px solid rgb(0 0 0 / 0.07);
      transition:
        color 0.2s ease,
        border-color 0.2s ease,
        box-shadow 0.2s ease,
        transform 0.2s ease;
    }

    .pitch-wiz-step-num {
      font-weight: 950;
      font-variant-numeric: tabular-nums;
      opacity: 0.65;
    }

    .pitch-wiz-step.is-active {
      color: var(--v1-ink);
      border-color: color-mix(in srgb, var(--panel-accent, var(--v1-coral)) 35%, rgb(0 0 0 / 0.12));
      box-shadow: 0 0 0 1px color-mix(in srgb, var(--panel-accent, var(--v1-coral)) 25%, transparent);
      transform: translateY(-1px);
    }

    .pitch-wiz-step.is-active .pitch-wiz-step-num {
      opacity: 1;
      color: var(--panel-accent, var(--v1-coral));
    }

    [data-pitch-layout="product-app"] .pitch-studio-wiz-controls-wrap {
      margin-top: 10px;
      padding: 10px 12px;
      border-radius: 12px;
      border: 1px solid rgb(0 0 0 / 0.08);
      background: rgb(255 255 255 / 0.82);
      box-shadow: 0 1px 2px rgb(0 0 0 / 0.04);
      display: grid;
      gap: 8px;
      max-width: 100%;
    }

    .pitch-studio-wiz-legend {
      font-size: 0.58rem;
      font-weight: 900;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgb(115 118 132 / 1);
    }

    .pitch-studio-wiz-controls {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 8px;
    }

    .pitch-wiz-ctrl {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 36px;
      padding: 0 14px;
      border-radius: 10px;
      border: 1px solid rgb(0 0 0 / 0.12);
      font-size: 0.72rem;
      font-weight: 880;
      cursor: pointer;
      background: rgb(255 255 255 / 0.95);
      color: var(--v1-ink);
      box-shadow: 0 1px 2px rgb(0 0 0 / 0.05);
      transition:
        background 0.15s ease,
        border-color 0.15s ease,
        opacity 0.15s ease;
    }

    .pitch-wiz-ctrl:hover:not(:disabled) {
      border-color: color-mix(in srgb, var(--panel-accent, var(--v1-coral)) 45%, rgb(0 0 0 / 0.12));
      background: color-mix(in srgb, var(--panel-accent, var(--v1-coral)) 6%, rgb(255 255 255 / 1));
    }

    .pitch-wiz-ctrl:disabled {
      opacity: 0.48;
      cursor: not-allowed;
    }

    .pitch-wiz-ctrl--play {
      border-color: color-mix(in srgb, var(--panel-accent, var(--v1-coral)) 35%, rgb(0 0 0 / 0.1));
      color: color-mix(in srgb, var(--panel-accent, var(--v1-coral)) 70%, rgb(38 40 48));
    }

    .pitch-wiz-ctrl--reset {
      margin-inline-start: auto;
    }

    .pitch-app-head {
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      gap: 8px 12px;
      padding: 11px 14px;
      background: linear-gradient(180deg, rgb(252 88 68 / 1), rgb(225 52 48 / 1));
      border-bottom: 1px solid rgb(0 0 0 / 0.14);
      color: #fff;
    }

    .pitch-app-head-brand {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      min-width: 0;
    }

    .pitch-app-pill {
      display: inline-grid;
      place-items: center;
      min-width: 32px;
      height: 30px;
      padding: 0 7px;
      border-radius: 8px;
      border: 1px solid rgb(255 255 255 / 0.35);
      background: rgb(200 32 43 / 1);
      font-size: 0.68rem;
      font-weight: 950;
      letter-spacing: 0.03em;
    }

    .pitch-app-head-title {
      font-size: clamp(0.66rem, 1.1vw, 0.8rem);
      font-weight: 780;
      letter-spacing: 0.02em;
      text-align: center;
      line-height: 1.25;
      text-shadow: 0 1px 2px rgb(0 0 0 / 0.14);
      opacity: 0.97;
    }

    .pitch-app-head-actions {
      justify-self: end;
    }

    .pitch-app-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 32px;
      padding: 0 11px;
      border-radius: 9px;
      border: 1px solid rgb(0 0 0 / 0.35);
      font-size: 0.66rem;
      font-weight: 900;
      cursor: default;
      box-shadow: 0 1px 2px rgb(0 0 0 / 0.12);
    }

    .pitch-app-btn--ghost {
      background: rgb(255 255 255 / 0.95);
      color: var(--v1-ink);
    }

    .pitch-app-btn--dark {
      background: rgb(24 24 27 / 1);
      color: #fff;
    }

    .pitch-app-main {
      padding: 12px 14px 16px;
      display: grid;
      gap: 11px;
    }

    .pitch-app-tabs {
      display: flex;
      flex-wrap: wrap;
      gap: 2px 6px;
      border-bottom: 1px solid rgb(0 0 0 / 0.08);
      padding-bottom: 3px;
    }

    .pitch-app-tab {
      padding: 8px 10px 6px;
      font-size: 0.67rem;
      font-weight: 800;
      color: rgb(118 120 132 / 1);
      border-bottom: 2px solid transparent;
      margin-bottom: -4px;
      cursor: default;
      white-space: nowrap;
    }

    .pitch-app-tab.is-active {
      color: var(--v1-ink);
      font-weight: 950;
      border-bottom-color: var(--panel-accent, var(--v1-red));
    }

    .pitch-app-tab-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 1.1rem;
      height: 1.1rem;
      padding: 0 4px;
      margin-inline-start: 4px;
      border-radius: 999px;
      background: var(--v1-red);
      color: #fff;
      font-size: 0.54rem;
      font-weight: 950;
    }

    .pitch-job-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      flex-wrap: wrap;
    }

    .pitch-job-chip {
      font-size: 0.58rem;
      font-weight: 850;
      letter-spacing: 0.04em;
      padding: 5px 11px;
      border-radius: 999px;
      background: rgb(245 243 238 / 1);
      border: 1px solid rgb(0 0 0 / 0.08);
      color: rgb(82 84 94 / 1);
    }

    .pitch-job-state {
      font-size: 0.58rem;
      font-weight: 850;
      color: var(--panel-accent, var(--v1-coral));
    }

    .pitch-drop-card {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 14px;
      flex-wrap: wrap;
      padding: 13px 15px;
      border-radius: 14px;
      border: 2px dashed color-mix(in srgb, var(--panel-accent, var(--v1-red)) 48%, rgb(0 0 0 / 0.12));
      background: linear-gradient(
        125deg,
        rgb(255 255 255 / 1),
        color-mix(in srgb, var(--panel-accent, var(--v1-coral)) 7%, rgb(255 255 255 / 1))
      );
      transition: box-shadow 0.22s ease, border-color 0.22s ease;
    }

    .pitch-drop-inner {
      display: flex;
      align-items: center;
      gap: 12px;
      min-width: 0;
    }

    .pitch-drop-icon {
      width: 46px;
      height: 46px;
      flex-shrink: 0;
      border-radius: 14px;
      display: grid;
      place-items: center;
      font-size: 1.18rem;
      background: color-mix(in srgb, var(--panel-accent, var(--v1-coral)) 14%, rgb(255 255 255 / 1));
      border: 1px solid rgb(0 0 0 / 0.07);
    }

    .pitch-drop-title {
      font-size: 0.82rem;
      font-weight: 900;
      color: var(--v1-ink);
      margin-bottom: 3px;
    }

    .pitch-drop-hint {
      font-size: 0.69rem;
      font-weight: 700;
      color: rgb(105 106 118 / 1);
      line-height: 1.38;
      max-width: 30ch;
    }

    .pitch-drop-cta {
      flex-shrink: 0;
      padding: 10px 17px;
      border-radius: 11px;
      border: none;
      font-size: 0.74rem;
      font-weight: 950;
      color: #fff;
      background: linear-gradient(180deg, rgb(232 56 48 / 1), rgb(190 36 38 / 1));
      box-shadow: 0 3px 12px rgb(200 32 43 / 0.28);
      cursor: default;
    }

    .pitch-bento {
      display: grid;
      gap: 10px;
      grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.15fr) minmax(0, 0.88fr);
      align-items: stretch;
      min-height: 196px;
    }

    .pitch-bento__rail {
      display: grid;
      grid-template-rows: 1fr 1fr;
      gap: 9px;
      min-height: 0;
    }

    .pitch-mini-card {
      position: relative;
      padding: 26px 10px 10px;
      border-radius: 12px;
      border: 1px solid rgb(0 0 0 / 0.09);
      background: rgb(255 255 255 / 0.92);
      box-shadow: 0 1px 3px rgb(0 0 0 / 0.05);
      display: grid;
      gap: 7px;
      align-content: start;
      min-height: 0;
      transition:
        border-color 0.22s ease,
        box-shadow 0.22s ease;
    }

    .pitch-cell-badge {
      position: absolute;
      inset-inline-start: 9px;
      inset-block-start: 8px;
      padding: 3px 8px;
      border-radius: 999px;
      font-size: 0.53rem;
      font-weight: 900;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      background: rgb(255 244 236 / 1);
      color: rgb(160 72 48 / 1);
      border: 1px solid rgb(0 0 0 / 0.06);
    }

    .pitch-cell-label {
      display: flex;
      align-items: center;
      gap: 5px;
      font-size: 0.71rem;
      font-weight: 900;
      color: var(--v1-ink);
    }

    .pitch-cell-ico {
      font-size: 0.88rem;
      opacity: 0.88;
    }

    .pitch-skel-lines {
      display: grid;
      gap: 6px;
      padding-top: 3px;
    }

    .pitch-skel-line {
      height: 7px;
      border-radius: 5px;
      background: rgb(0 0 0 / 0.065);
      border: 1px solid rgb(0 0 0 / 0.05);
    }

    .pitch-skel-line:nth-child(2) {
      width: 90%;
    }

    .pitch-skel-line:nth-child(3) {
      width: 76%;
    }

    .pitch-skel-line:nth-child(4) {
      width: 84%;
    }

    .pitch-render-zone {
      flex: 1;
      min-height: 56px;
      border-radius: 9px;
      border: 1.5px dashed color-mix(in srgb, var(--panel-accent, var(--v1-coral)) 32%, rgb(0 0 0 / 0.08));
      background: color-mix(in srgb, var(--panel-accent, var(--v1-coral)) 6%, rgb(255 255 255 / 1));
    }

    .pitch-bento__cell--timeline {
      padding: 26px 11px 11px;
      border-radius: 14px;
      border: 1px solid rgb(0 0 0 / 0.09);
      background: rgb(255 255 255 / 0.9);
      box-shadow: 0 1px 3px rgb(0 0 0 / 0.05);
      display: grid;
      gap: 8px;
      align-content: start;
      min-height: 0;
      transition:
        border-color 0.22s ease,
        box-shadow 0.22s ease;
    }

    .pitch-timeline-lanes {
      display: grid;
      gap: 7px;
      padding-top: 4px;
    }

    .pitch-lane {
      height: 10px;
      border-radius: 6px;
      background: color-mix(in srgb, var(--panel-accent, var(--v1-coral)) 22%, rgb(255 255 255 / 1));
      border: 1px solid color-mix(in srgb, var(--panel-accent, var(--v1-coral)) 35%, rgb(0 0 0 / 0.06));
    }

    .pitch-lane:nth-child(2) {
      width: 86%;
    }

    .pitch-lane:nth-child(4) {
      width: 71%;
    }

    .pitch-bento__cell--output {
      padding: 26px 10px 12px;
      border-radius: 14px;
      border: 1px solid rgb(0 0 0 / 0.09);
      background: linear-gradient(165deg, rgb(255 255 255 / 1), rgb(248 246 244 / 1));
      box-shadow: 0 1px 3px rgb(0 0 0 / 0.05);
      display: grid;
      gap: 8px;
      justify-items: center;
      align-content: start;
      transition:
        border-color 0.22s ease,
        box-shadow 0.22s ease;
    }

    .pitch-device {
      width: min(48vw, 158px);
      aspect-ratio: 9 / 16;
      padding: 11px;
      border-radius: 22px;
      border: 2px solid rgb(28 28 32 / 1);
      background: linear-gradient(145deg, rgb(52 52 58 / 1), rgb(22 22 26 / 1));
      box-shadow:
        0 16px 28px rgb(0 0 0 / 0.18),
        0 0 0 1px rgb(255 255 255 / 0.06) inset;
    }

    .pitch-device-screen {
      width: 100%;
      height: 100%;
      border-radius: 14px;
      border: 1px solid rgb(0 0 0 / 0.45);
      background: #0b0b0e;
      display: grid;
      place-content: center;
      place-items: center;
      text-align: center;
      color: rgb(255 255 255 / 0.38);
      font-size: 0.68rem;
      font-weight: 820;
      line-height: 1.35;
    }

    .pitch-device-screen--preview {
      position: relative;
      padding: 0;
      overflow: hidden;
      display: block;
      background: #050508;
    }

    .pitch-device-poster {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .pitch-device-play {
      position: absolute;
      inset: 0;
      display: grid;
      place-items: center;
      font-size: 1.35rem;
      line-height: 1;
      color: rgb(255 255 255 / 0.82);
      text-shadow: 0 2px 12px rgb(0 0 0 / 0.55);
      pointer-events: none;
    }

    .pitch-cell-badge--done {
      background: color-mix(in srgb, rgb(22 163 91 / 1) 12%, rgb(255 255 255 / 1));
      color: rgb(21 100 58 / 1);
      border-color: color-mix(in srgb, rgb(22 163 91 / 1) 28%, rgb(0 0 0 / 0.08));
    }

    .pitch-drop-file {
      margin-top: 5px;
      font-size: 0.62rem;
      font-weight: 750;
      color: rgb(90 92 105 / 1);
      letter-spacing: 0.02em;
    }

    .pitch-transcript-lines {
      display: grid;
      gap: 5px;
      padding-top: 3px;
      max-height: 5.8rem;
      overflow: auto;
      min-height: 0;
    }

    .pitch-transcript-line {
      margin: 0;
      font-size: 0.62rem;
      font-weight: 650;
      line-height: 1.38;
      color: rgb(52 54 64 / 1);
    }

    .pitch-render-zone--done {
      border-style: solid;
      border-color: color-mix(in srgb, rgb(22 163 91 / 1) 35%, rgb(0 0 0 / 0.08));
      background: color-mix(in srgb, rgb(22 163 91 / 1) 8%, rgb(255 255 255 / 1));
      display: grid;
      place-items: center;
    }

    .pitch-render-done-label {
      font-size: 0.62rem;
      font-weight: 850;
      color: rgb(21 100 58 / 1);
    }

    .pitch-timeline-scene {
      display: grid;
      grid-template-columns: 38px minmax(0, 1fr);
      gap: 8px;
      align-items: center;
      padding: 6px 7px;
      border-radius: 9px;
      border: 1px solid rgb(0 0 0 / 0.06);
      background: rgb(255 255 255 / 0.72);
    }

    .pitch-timeline-scene-thumb {
      border-radius: 6px;
      overflow: hidden;
      width: 38px;
      aspect-ratio: 9 / 16;
    }

    .pitch-timeline-thumb-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .pitch-timeline-scene-title {
      font-size: 0.65rem;
      font-weight: 850;
      color: var(--v1-ink);
      line-height: 1.25;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .pitch-timeline-scene-sub {
      font-size: 0.55rem;
      font-weight: 700;
      margin-top: 2px;
      color: rgb(105 106 118 / 1);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    /* Scroll-sync wizard focus */
    .pitch-app-shell[data-highlight="upload"] .pitch-drop-card {
      box-shadow: 0 0 0 2px color-mix(in srgb, var(--panel-accent, var(--v1-coral)) 30%, transparent);
      border-color: color-mix(in srgb, var(--panel-accent, var(--v1-red)) 55%, rgb(0 0 0 / 0.12));
    }

    .pitch-app-shell[data-highlight="transcript"] .pitch-mini-card--transcript {
      border-color: color-mix(in srgb, var(--panel-accent, var(--v1-coral)) 38%, rgb(0 0 0 / 0.1));
      box-shadow: 0 0 0 1px color-mix(in srgb, var(--panel-accent, var(--v1-coral)) 22%, transparent);
    }

    .pitch-app-shell[data-highlight="timeline"] .pitch-bento__cell--timeline {
      border-color: color-mix(in srgb, var(--panel-accent, var(--v1-coral)) 42%, rgb(0 0 0 / 0.1));
      box-shadow:
        0 0 0 1px color-mix(in srgb, var(--panel-accent, var(--v1-coral)) 22%, transparent),
        0 10px 22px rgb(200 32 43 / 0.07);
    }

    .pitch-app-shell[data-highlight="render"] .pitch-mini-card--render {
      border-color: color-mix(in srgb, var(--panel-accent, var(--v1-coral)) 38%, rgb(0 0 0 / 0.1));
      box-shadow: 0 0 0 1px color-mix(in srgb, var(--panel-accent, var(--v1-coral)) 22%, transparent);
    }

    .pitch-app-shell[data-highlight="output"] .pitch-bento__cell--output {
      border-color: color-mix(in srgb, var(--panel-accent, var(--v1-coral)) 38%, rgb(0 0 0 / 0.1));
      box-shadow: 0 0 0 1px color-mix(in srgb, var(--panel-accent, var(--v1-coral)) 18%, transparent);
    }

    .pitch-app-shell[data-highlight="masthead"] .pitch-app-head {
      box-shadow: inset 0 0 0 2px rgb(255 255 255 / 0.28);
    }

    .pitch-app-shell[data-highlight="tabs"] .pitch-app-tabs {
      border-bottom-color: color-mix(in srgb, var(--panel-accent, var(--v1-coral)) 45%, rgb(0 0 0 / 0.08));
    }

    @media (prefers-reduced-motion: no-preference) {
      .pitch-app-shell[data-highlight="timeline"] .pitch-bento__cell--timeline {
        animation: pitch-app-softpulse 3s ease-in-out infinite;
      }

      @keyframes pitch-app-softpulse {
        0%,
        100% {
          box-shadow:
            0 0 0 1px color-mix(in srgb, var(--panel-accent, var(--v1-coral)) 20%, transparent),
            0 8px 18px rgb(200 32 43 / 0.06);
        }

        50% {
          box-shadow:
            0 0 0 3px color-mix(in srgb, var(--panel-accent, var(--v1-coral)) 14%, transparent),
            0 12px 24px rgb(200 32 43 / 0.09);
        }
      }
    }

    @media (max-width: 860px) {
      .pitch-bento {
        grid-template-columns: 1fr;
      }

      .pitch-app-head {
        grid-template-columns: 1fr;
        text-align: center;
      }

      .pitch-app-head-brand {
        justify-content: center;
      }

      .pitch-app-head-actions {
        justify-self: center;
      }

      .pitch-app-head-title {
        grid-column: 1 / -1;
        order: -1;
      }

      .pitch-device {
        width: min(58vw, 188px);
      }

      .pitch-catalog-workspace {
        grid-template-columns: 1fr !important;
      }

      .pitch-catalog-detail {
        max-height: none;
      }

      .pitch-app-shell--catalog {
        width: min(100%, 720px);
        height: auto;
        max-height: none;
      }
    }

    /* Catalog slide — extends shared product-app copy + app shell */
    .pitch-app-shell--catalog {
      display: grid;
      grid-template-rows: auto auto auto minmax(0, 1fr);
      gap: 0;
      box-sizing: border-box;
      width: 820px;
      max-width: 100%;
      height: 380px;
      max-height: min(380px, 52svh);
      margin-inline: auto;
    }

    .pitch-app-shell--catalog .pitch-catalog-workspace {
      min-height: 0;
      overflow: auto;
      align-items: stretch;
    }

    .pitch-app-shell--catalog .pitch-catalog-detail {
      max-height: none;
      align-self: stretch;
      min-height: 0;
      overflow: auto;
    }

    .pitch-catalog-toolbar {
      padding: 12px 14px 10px;
      border-bottom: 1px solid rgb(0 0 0 / 0.08);
      background: linear-gradient(180deg, rgb(255 255 255 / 0.98), rgb(248 250 255 / 0.95));
    }

    .pitch-catalog-toolbar-title {
      margin: 0 0 10px;
      font-size: clamp(0.82rem, 1.3vw, 0.95rem);
      font-weight: 950;
      color: var(--v1-ink);
      letter-spacing: 0.02em;
    }

    .pitch-catalog-toolbar-row {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 8px;
    }

    .pitch-catalog-search-faux {
      flex: 1 1 160px;
      display: flex;
      align-items: center;
      gap: 8px;
      min-height: 38px;
      padding: 0 12px;
      border-radius: 11px;
      border: 1px solid rgb(0 0 0 / 0.1);
      background: rgb(255 255 255 / 0.95);
      box-shadow: 0 1px 2px rgb(0 0 0 / 0.04);
    }

    .pitch-catalog-search-ico {
      opacity: 0.55;
      font-size: 0.85rem;
    }

    .pitch-catalog-search-text {
      font-size: 0.68rem;
      font-weight: 750;
      color: rgb(115 118 132 / 1);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .pitch-catalog-pill {
      padding: 8px 12px;
      border-radius: 999px;
      font-size: 0.62rem;
      font-weight: 850;
      border: 1px solid rgb(0 0 0 / 0.1);
      background: rgb(246 248 252 / 1);
      color: rgb(62 65 78 / 1);
      white-space: nowrap;
    }

    .pitch-catalog-pill--sort {
      cursor: default;
    }

    .pitch-catalog-upload {
      margin-inline-start: auto;
      padding: 9px 14px;
      border-radius: 10px;
      font-size: 0.68rem;
      font-weight: 950;
      color: #fff;
      background: linear-gradient(180deg, color-mix(in srgb, var(--panel-accent, #3d55b8) 92%, #fff), var(--panel-accent, #3d55b8));
      border: 1px solid rgb(0 0 0 / 0.12);
      box-shadow: 0 2px 8px color-mix(in srgb, var(--panel-accent, #3d55b8) 28%, transparent);
      cursor: default;
      white-space: nowrap;
    }

    .pitch-catalog-sync-hint {
      margin: 0;
      padding: 8px 14px 0;
      font-size: 0.58rem;
      font-weight: 780;
      color: rgb(118 122 138 / 1);
      line-height: 1.35;
    }

    .pitch-catalog-filters {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      padding: 10px 14px 12px;
      border-bottom: 1px solid rgb(0 0 0 / 0.06);
    }

    .pitch-filter-chip {
      padding: 5px 11px;
      border-radius: 999px;
      font-size: 0.58rem;
      font-weight: 850;
      letter-spacing: 0.02em;
      background: rgb(255 255 255 / 0.85);
      border: 1px solid rgb(0 0 0 / 0.08);
      color: rgb(72 76 92 / 1);
      cursor: default;
    }

    .pitch-catalog-workspace {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(200px, 0.46fr);
      gap: 12px;
      padding: 12px 14px 16px;
      align-items: start;
    }

    .pitch-catalog-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }

    .pitch-catalog-card {
      border-radius: 12px;
      border: 1px solid rgb(0 0 0 / 0.09);
      background: rgb(255 255 255 / 0.92);
      box-shadow: 0 1px 3px rgb(0 0 0 / 0.05);
      overflow: hidden;
      display: grid;
      grid-template-rows: auto auto;
      gap: 0;
      transition:
        border-color 0.2s ease,
        box-shadow 0.2s ease;
      cursor: default;
    }

    .pitch-catalog-card--selected {
      border-color: color-mix(in srgb, var(--panel-accent, #3d55b8) 42%, rgb(0 0 0 / 0.12));
      box-shadow:
        0 0 0 2px color-mix(in srgb, var(--panel-accent, #3d55b8) 22%, transparent),
        0 6px 14px rgb(15 23 42 / 0.06);
    }

    .pitch-catalog-card-poster {
      height: 44px;
      width: 100%;
      overflow: hidden;
      background: rgb(236 238 246 / 1);
      flex-shrink: 0;
    }

    .pitch-catalog-card-poster-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .pitch-catalog-search-copy {
      display: grid;
      gap: 3px;
      min-width: 0;
      flex: 1;
    }

    .pitch-catalog-search-meta {
      font-size: 0.52rem;
      font-weight: 780;
      color: rgb(115 118 132 / 1);
      line-height: 1.3;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .pitch-filter-chip--mock {
      border-style: dashed;
      background: color-mix(in srgb, var(--panel-accent, #3d55b8) 8%, rgb(255 255 255 / 0.92));
      color: color-mix(in srgb, var(--panel-accent, #3d55b8) 65%, rgb(62 65 78 / 1));
    }

    .pitch-tag--mock {
      border-style: dashed;
      background: rgb(250 248 255 / 1);
      color: rgb(80 72 120 / 1);
      font-weight: 900;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      font-size: 0.5rem;
    }

    .pitch-segment-cell {
      flex: 1;
      min-width: 0;
      display: flex;
      flex-direction: column;
      align-items: stretch;
      gap: 3px;
    }

    .pitch-segment-strip-img {
      width: 100%;
      height: 28px;
      flex: 0 0 auto;
      object-fit: cover;
      border-radius: 8px;
      border: 1px solid rgb(0 0 0 / 0.08);
    }

    .pitch-segment-label {
      font-size: 0.48rem;
      font-weight: 820;
      line-height: 1.2;
      text-align: center;
      color: rgb(88 92 108 / 1);
      text-wrap: balance;
    }

    .pitch-detail-poster-img {
      width: 100%;
      height: 100%;
      min-height: 84px;
      max-height: 100px;
      object-fit: cover;
      display: block;
      border-radius: 10px;
    }

    .pitch-detail-desc {
      margin: 0;
      font-size: 0.6rem;
      font-weight: 720;
      line-height: 1.45;
      color: rgb(68 72 88 / 1);
    }

    .pitch-detail-desc--tight {
      margin-top: 4px;
      margin-bottom: 0;
    }

    .pitch-catalog-card-meta {
      padding: 8px 10px 10px;
      display: grid;
      gap: 2px;
    }

    .pitch-catalog-card-title {
      font-size: 0.68rem;
      font-weight: 900;
      color: var(--v1-ink);
      line-height: 1.25;
    }

    .pitch-catalog-card-meta small {
      font-size: 0.56rem;
      font-weight: 800;
      color: rgb(115 118 132 / 1);
    }

    .pitch-catalog-detail {
      border-radius: 14px;
      border: 1px solid rgb(0 0 0 / 0.09);
      background: rgb(255 255 255 / 0.94);
      box-shadow: 0 2px 10px rgb(15 23 42 / 0.05);
      padding: 12px 12px 14px;
      display: grid;
      gap: 12px;
      max-height: min(52vh, 420px);
      overflow: auto;
    }

    .pitch-catalog-detail-head {
      display: grid;
      gap: 4px;
      padding-bottom: 8px;
      border-bottom: 1px solid rgb(0 0 0 / 0.07);
    }

    .pitch-detail-eyebrow {
      font-size: 0.55rem;
      font-weight: 900;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      color: var(--panel-accent, #3d55b8);
    }

    .pitch-detail-title {
      font-size: 0.76rem;
      font-weight: 900;
      color: var(--v1-ink);
      line-height: 1.25;
    }

    .pitch-detail-block {
      display: grid;
      gap: 6px;
    }

    .pitch-detail-label {
      margin: 0;
      font-size: 0.62rem;
      font-weight: 900;
      color: rgb(72 76 92 / 1);
    }

    .pitch-segment-strip {
      display: flex;
      gap: 6px;
      align-items: stretch;
    }

    .pitch-detail-poster {
      border-radius: 10px;
      border: 1px solid rgb(0 0 0 / 0.1);
      min-height: 84px;
      max-height: 100px;
      overflow: hidden;
      background: rgb(236 238 246 / 1);
    }

    .pitch-skel-lines--compact {
      gap: 5px;
    }

    .pitch-skel-lines--compact .pitch-skel-line:nth-child(2) {
      width: 94%;
    }

    .pitch-skel-lines--compact .pitch-skel-line:nth-child(3) {
      width: 81%;
    }

    .pitch-tag-row {
      display: flex;
      flex-wrap: wrap;
      gap: 5px;
    }

    .pitch-tag {
      padding: 4px 9px;
      border-radius: 999px;
      font-size: 0.55rem;
      font-weight: 850;
      background: rgb(237 241 252 / 1);
      border: 1px solid rgb(0 0 0 / 0.07);
      color: rgb(62 68 88 / 1);
    }

    .pitch-catalog-bridge {
      margin: 4px 0 0;
      padding-top: 10px;
      border-top: 1px dashed rgb(0 0 0 / 0.1);
      font-size: 0.62rem;
      font-weight: 780;
      line-height: 1.45;
      color: rgb(82 86 102 / 1);
    }

    .visual-board,
    .phone-frame,
    .screen-frame,
    .card-stack,
    .download-card,
    .tutorial-panel {
      width: min(100%, 520px);
      border: 2px solid var(--v1-ink);
      border-radius: 22px;
      background: rgb(255 255 255 / .82);
      box-shadow: var(--shadow);
    }

    .visual-board {
      min-height: 380px;
      padding: 28px;
      display: grid;
      gap: 18px;
      align-content: center;
    }

    .pricing-board.visual-board {
      min-height: unset;
      padding: 0;
    }

    .mini-card {
      min-height: 76px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 18px;
      padding: 16px 18px;
      border: 2px solid var(--v1-ink);
      border-radius: 14px;
      background: var(--v1-paper);
      box-shadow: 4px 4px 0 var(--v1-ink);
      font-weight: 900;
    }

    .mini-card small {
      color: var(--v1-muted);
      font-weight: 800;
    }

    .phone-frame {
      width: min(68vw, 270px);
      aspect-ratio: 9 / 16;
      padding: 18px;
      display: grid;
      place-items: center;
      background:
        linear-gradient(180deg, rgb(249 84 62 / .18), transparent),
        var(--v1-paper);
    }

    .phone-screen {
      width: 100%;
      height: 100%;
      display: grid;
      place-items: center;
      border: 2px solid var(--v1-red);
      border-radius: 16px;
      color: var(--v1-ink);
      font-size: 1.4rem;
      font-weight: 950;
      text-align: center;
    }

    .screen-frame {
      min-height: 390px;
      padding: 20px;
      background: var(--v1-paper);
    }

    .screen-top {
      min-height: 52px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 18px;
      padding: 8px 12px;
      border: 2px solid var(--v1-ink);
      border-radius: 14px;
      background: var(--v1-coral);
      font-weight: 950;
    }

    .screen-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
    }

    .screen-tile {
      min-height: 120px;
      padding: 16px;
      border: 2px solid var(--v1-ink);
      border-radius: 14px;
      background: var(--v1-cream);
      box-shadow: 3px 3px 0 var(--v1-ink);
      font-weight: 900;
    }

    .card-stack {
      padding: 24px;
      display: grid;
      gap: 14px;
    }

    .timeline-row {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 14px;
      align-items: center;
      padding: 14px;
      border: 2px solid var(--v1-ink);
      border-radius: 14px;
      background: var(--v1-paper);
      box-shadow: 3px 3px 0 var(--v1-ink);
      font-weight: 900;
    }

    .timeline-dot {
      width: 34px;
      height: 34px;
      display: grid;
      place-items: center;
      border-radius: 999px;
      background: var(--panel-accent, var(--v1-coral));
      color: #fff;
      direction: ltr;
      unicode-bidi: isolate;
    }

    .download-card {
      padding: 26px;
      display: grid;
      gap: 12px;
      background: var(--v1-yellow);
    }

    .download-card h3 {
      margin: 0 0 4px;
      font-size: clamp(1.8rem, 3vw, 2.8rem);
      line-height: 1;
      text-align: start;
    }

    .download-card .mixed-ltr {
      display: inline-block;
    }


    .download-card p {
      margin: 0 0 8px;
      color: var(--v1-muted);
      font-weight: 800;
    }

