<!doctype html>
<html lang="he" dir="rtl">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="description" content="WeatherV1 Next - סטודיו דסקטופ ליצירת סרטוני תחזית אנכיים ללקוחות ולצוותי תוכן.">
  <title>WeatherV1 Next - Pitch</title>
  <style>
    :root {
      color-scheme: light;
      --v1-red: #ff0000;
      --v1-coral: #f9543e;
      --v1-coral-soft: #fce9e4;
      --v1-cream: #f4f3ef;
      --v1-paper: #ffffff;
      --v1-ink: #000000;
      --v1-muted: #313131;
      --v1-yellow: #f2c231;
      --v1-success: #1fa871;
      --v1-danger: #c8202b;
      --shadow: 8px 8px 0 var(--v1-ink);
      --soft-shadow: 0 18px 46px rgb(0 0 0 / .12);
      --nav-height: 76px;
      /* Mobile pitch tier overrides `--nav-height` + exposes rhythm for panels / anchors */
      --pitch-mobile-nav-buffer: 12px;
      --story-vw: 100vw;
      font-family: Heebo, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    * { box-sizing: border-box; }
    html {
      min-height: 100%;
      scroll-behavior: smooth;
      background: var(--v1-cream);
      overflow-anchor: none;
    }
    body {
      min-height: 100%;
      margin: 0;
      overflow-x: hidden;
      background:
        linear-gradient(90deg, rgb(0 0 0 / .035) 1px, transparent 1px) 0 0 / 28px 28px,
        linear-gradient(0deg, rgb(0 0 0 / .03) 1px, transparent 1px) 0 0 / 28px 28px,
        radial-gradient(circle at 12% 18%, rgb(242 194 49 / .26), transparent 30rem),
        radial-gradient(circle at 86% 68%, rgb(249 84 62 / .18), transparent 36rem),
        var(--v1-cream);
      color: var(--v1-ink);
      font: 16px/1.55 Heebo, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    a { color: inherit; }

    .site-nav {
      position: fixed;
      inset: 12px 12px auto;
      z-index: 50;
      min-height: 58px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      padding: 8px 10px;
      border: 2px solid var(--v1-ink);
      border-radius: 18px;
      background: rgb(249 84 62 / .96);
      box-shadow: 5px 5px 0 var(--v1-ink);
      backdrop-filter: blur(10px);
    }

    .brand {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      min-width: 0;
      text-decoration: none;
      font-weight: 900;
    }

    .brand-mark {
      width: 40px;
      height: 40px;
      flex: 0 0 auto;
      display: grid;
      place-items: center;
      overflow: hidden;
      border: 2px solid var(--v1-ink);
      border-radius: 10px;
      background: var(--v1-paper);
      box-shadow: 3px 3px 0 var(--v1-ink);
    }

    .brand-mark img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      display: block;
    }

    .brand-copy {
      display: grid;
      gap: 1px;
      line-height: 1.05;
    }

    .brand-copy strong {
      white-space: nowrap;
      font-size: 1rem;
    }

    .brand-copy span {
      color: rgb(0 0 0 / .7);
      font-size: .78rem;
      font-weight: 800;
    }

    .nav-actions {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .nav-link,
    .cta {
      min-height: 38px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 0 14px;
      border: 1.5px solid var(--v1-ink);
      border-radius: 12px;
      background: rgb(255 255 255 / .78);
      color: var(--v1-ink);
      box-shadow: 2px 2px 0 var(--v1-ink);
      text-decoration: none;
      font-weight: 900;
      white-space: nowrap;
      cursor: pointer;
      transition: transform 160ms ease, box-shadow 160ms ease, background 160ms ease;
    }

    .cta {
      background: var(--v1-red);
      color: #fff;
    }

    .nav-link:hover,
    .cta:hover {
      transform: translateY(-2px);
      box-shadow: 3px 3px 0 var(--v1-ink);
      background: var(--v1-yellow);
      color: var(--v1-ink);
    }

    .scroll-progress {
      position: fixed;
      inset: auto 18px 14px;
      z-index: 45;
      height: 8px;
      overflow: hidden;
      border: 1.5px solid var(--v1-ink);
      border-radius: 999px;
      background: rgb(255 255 255 / .82);
      box-shadow: 2px 2px 0 var(--v1-ink);
    }

    .scroll-progress span {
      display: block;
      position: absolute;
      inset: 0;
      width: auto;
      height: 100%;
      transform: scaleX(0);
      transform-origin: inline-start;
      background: linear-gradient(90deg, var(--v1-yellow), var(--v1-red));
      will-change: transform;
    }

    .scroll-hint {
      position: fixed;
      inset-inline-start: 18px;
      inset-inline-end: auto;
      inset-block-end: 78px;
      z-index: 46;
      transform: translateY(-100%);
      color: var(--v1-muted);
      font-size: .78rem;
      font-weight: 900;
      pointer-events: none;
      white-space: nowrap;
    }

    .story-shell {
      min-height: 100svh;
      overflow: hidden;
      /* Avoid scroll anchoring jumps when pinned strip height/measures settle. */
      overflow-anchor: none;
    }

    /**
     * Story pin + GSAP scrub: isolate geometry to LTR. `html[dir=rtl]` with ScrollTrigger
     * horizontal maps is brittle (community reports misaligned scrub / anchors); copy stays rtl in .panel-inner.
     */
    main#story {
      direction: ltr;
      unicode-bidi: isolate;
    }

    .story-track {
      display: block;
      width: 100%;
      min-height: 100svh;
    }

    .story-mirror {
      width: 100%;
      min-height: 100%;
    }

    .story-roll {
      display: block;
      width: 100%;
      min-height: 100svh;
    }

    /*
      Horizontal carousel: physical LTR flex on #storyRoll + GSAP translateX.
      main#story stays direction:ltr for ScrollTrigger math; body.scroll-rtlflow mirrors strip+panels for RTL story feel.
      Typography remains rtl in .panel-inner.
    */

    .story-panel {
      width: 100%;
      min-height: 100svh;
      padding: calc(var(--nav-height) + 36px) clamp(20px, 5vw, 72px) 64px;
      display: grid;
      place-items: center;
      background:
        linear-gradient(90deg, rgb(0 0 0 / .028) 1px, transparent 1px) 0 0 / 34px 34px,
        linear-gradient(0deg, rgb(0 0 0 / .022) 1px, transparent 1px) 0 0 / 34px 34px,
        var(--panel-paper, var(--v1-paper));
    }

    .panel-inner {
      width: min(1180px, 100%);
      display: grid;
      grid-template-columns: minmax(0, .9fr) minmax(320px, 1.1fr);
      gap: clamp(24px, 5vw, 78px);
      align-items: center;
      direction: rtl;
      unicode-bidi: isolate;
    }

    .panel-copy {
      min-width: 0;
      display: grid;
      gap: 18px;
      justify-items: start;
    }

    .kicker {
      display: inline-block;
      max-width: 100%;
      border-inline-start: 4px solid currentColor;
      padding-inline-start: 12px;
      color: var(--panel-accent, var(--v1-coral));
      font-size: clamp(.78rem, 1.2vw, .95rem);
      font-weight: 950;
      letter-spacing: .04em;
      text-transform: uppercase;
    }

    h1, h2 {
      margin: 0;
      max-width: 10.5ch;
      color: var(--v1-ink);
      font-size: clamp(3rem, 7vw, 7.4rem);
      line-height: .9;
      letter-spacing: 0;
      text-align: start;
    }

    .lead {
      max-width: 34rem;
      margin: 0;
      color: var(--v1-muted);
      font-size: clamp(1.05rem, 1.8vw, 1.55rem);
      font-weight: 700;
      line-height: 1.35;
    }

    .bullets {
      margin: 8px 0 0;
      padding: 0;
      display: grid;
      gap: 10px;
      list-style: none;
      font-weight: 850;
      font-size: clamp(.95rem, 1.35vw, 1.15rem);
    }

    .bullets li {
      display: grid;
      grid-template-columns: 10px 1fr;
      gap: 10px;
      align-items: start;
    }

    .bullets li::before {
      content: "";
      width: 10px;
      height: 10px;
      margin-top: .52em;
      margin-inline: auto;
      border-radius: 999px;
      background: var(--panel-accent, var(--v1-coral));
      box-shadow: 0 0 0 5px rgb(249 84 62 / .14);
    }

    /* English / Latin snippets inside rtl panels */

    .mixed-ltr {
      direction: ltr;
      unicode-bidi: isolate;
    }

    .panel-visual {
      position: relative;
      min-height: min(58svh, 520px);
      display: grid;
      place-items: center;
    }

    .numbered-sample-visual {
      width: min(100%, 520px);
      min-height: min(52svh, 420px);
      border: 3px solid var(--v1-ink);
      border-radius: 24px;
      background: rgb(255 255 255 / .78);
      box-shadow: var(--shadow);
      display: grid;
      place-items: center;
      padding: 24px;
    }

    .numbered-sample-num {
      font-size: clamp(4rem, 22vmin, 9.5rem);
      font-weight: 950;
      line-height: 1;
      color: var(--panel-accent, var(--v1-coral));
      letter-spacing: -0.06em;
      font-variant-numeric: tabular-nums;
      user-select: none;
    }

    .visual-board,
    .phone-frame,
    .screen-frame,
    .card-stack,
    .download-card,
    .tutorial-panel {
      width: min(100%, 520px);
      border: 2px solid var(--v1-ink);
      border-radius: 22px;
      background: rgb(255 255 255 / .82);
      box-shadow: var(--shadow);
    }

    .visual-board {
      min-height: 380px;
      padding: 28px;
      display: grid;
      gap: 18px;
      align-content: center;
    }

    .pricing-board.visual-board {
      min-height: unset;
      padding: 0;
    }

    .mini-card {
      min-height: 76px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 18px;
      padding: 16px 18px;
      border: 2px solid var(--v1-ink);
      border-radius: 14px;
      background: var(--v1-paper);
      box-shadow: 4px 4px 0 var(--v1-ink);
      font-weight: 900;
    }

    .mini-card small {
      color: var(--v1-muted);
      font-weight: 800;
    }

    .phone-frame {
      width: min(68vw, 270px);
      aspect-ratio: 9 / 16;
      padding: 18px;
      display: grid;
      place-items: center;
      background:
        linear-gradient(180deg, rgb(249 84 62 / .18), transparent),
        var(--v1-paper);
    }

    .phone-screen {
      width: 100%;
      height: 100%;
      display: grid;
      place-items: center;
      border: 2px solid var(--v1-red);
      border-radius: 16px;
      color: var(--v1-ink);
      font-size: 1.4rem;
      font-weight: 950;
      text-align: center;
    }

    .screen-frame {
      min-height: 390px;
      padding: 20px;
      background: var(--v1-paper);
    }

    .screen-top {
      min-height: 52px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 18px;
      padding: 8px 12px;
      border: 2px solid var(--v1-ink);
      border-radius: 14px;
      background: var(--v1-coral);
      font-weight: 950;
    }

    .screen-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
    }

    .screen-tile {
      min-height: 120px;
      padding: 16px;
      border: 2px solid var(--v1-ink);
      border-radius: 14px;
      background: var(--v1-cream);
      box-shadow: 3px 3px 0 var(--v1-ink);
      font-weight: 900;
    }

    .card-stack {
      padding: 24px;
      display: grid;
      gap: 14px;
    }

    .timeline-row {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 14px;
      align-items: center;
      padding: 14px;
      border: 2px solid var(--v1-ink);
      border-radius: 14px;
      background: var(--v1-paper);
      box-shadow: 3px 3px 0 var(--v1-ink);
      font-weight: 900;
    }

    .timeline-dot {
      width: 34px;
      height: 34px;
      display: grid;
      place-items: center;
      border-radius: 999px;
      background: var(--panel-accent, var(--v1-coral));
      color: #fff;
      direction: ltr;
      unicode-bidi: isolate;
    }

    .download-card {
      padding: 26px;
      display: grid;
      gap: 12px;
      background: var(--v1-yellow);
    }

    .download-card h3 {
      margin: 0 0 4px;
      font-size: clamp(1.8rem, 3vw, 2.8rem);
      line-height: 1;
      text-align: start;
    }

    .download-card .mixed-ltr {
      display: inline-block;
    }


    .download-card p {
      margin: 0 0 8px;
      color: var(--v1-muted);
      font-weight: 800;
    }

    .download-links {
      display: grid;
      gap: 10px;
    }

    .download-links--hero {
      gap: 8px;
    }

    .hero-downloads {
      margin-top: 6px;
      width: 100%;
      max-width: 36rem;
    }

    .hero-downloads-title {
      margin: 0 0 10px;
      font-weight: 950;
      font-size: clamp(1rem, 1.35vw, 1.14rem);
    }

    .download-links--hero a {
      min-height: 46px;
      font-size: 0.9rem;
    }

    /* Intro: bullets + hero download card + phone preview fits one viewport */
    #intro.story-panel {
      padding-block: calc(var(--nav-height) + 14px) 24px;
      padding-inline: clamp(14px, 3.8vw, 52px);
    }

    #intro .panel-inner {
      align-items: stretch;
      gap: clamp(10px, 2.5vw, 32px);
      grid-template-columns: minmax(0, 1.08fr) minmax(min(160px, 18vw), 0.38fr);
      box-sizing: border-box;
      max-height: calc(100svh - var(--nav-height) - 40px);
    }

    #intro .panel-copy {
      gap: clamp(8px, 1.5vw, 14px);
      min-height: 0;
      align-self: center;
    }

    #intro h1 {
      font-size: clamp(1.7rem, 4.8vw, 4rem);
      max-width: 12ch;
      line-height: 0.98;
    }

    #intro .lead {
      font-size: clamp(0.88rem, 1.25vw, 1.22rem);
      max-width: 28rem;
      line-height: 1.28;
      display: -webkit-box;
      -webkit-line-clamp: 4;
      line-clamp: 4;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    #intro .bullets {
      margin-top: 0;
      gap: 5px;
      font-size: clamp(0.8rem, 1.05vw, 0.98rem);
    }

    #intro .bullets li::before {
      margin-top: 0.45em;
    }

    #intro .hero-downloads {
      margin-top: 2px;
      max-width: none;
      width: 100%;
    }

    #intro .hero-downloads-title {
      margin: 0 0 5px;
      font-size: clamp(0.78rem, 1vw, 0.94rem);
    }

    #intro .download-links--hero {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5px;
    }

    #intro .download-links--hero a {
      min-height: 34px;
      padding: 0 8px 0 10px;
      font-size: 0.72rem;
      border-radius: 10px;
      box-shadow: 2px 2px 0 var(--v1-ink);
      gap: 8px;
    }

    #intro .panel-visual {
      min-height: 0;
      max-height: min(46svh, 320px);
      align-self: center;
    }

    #intro .phone-frame {
      width: min(118px, 18vw);
      max-height: min(42svh, 300px);
      padding: 10px;
    }

    #intro .phone-screen {
      font-size: clamp(0.78rem, 1.2vw, 1rem);
    }

    @media (max-height: 720px) {
      #intro .panel-inner {
        max-height: calc(100svh - var(--nav-height) - 28px);
      }

      #intro h1 {
        font-size: clamp(1.45rem, 4.2vh, 2.75rem);
      }

      #intro .lead {
        -webkit-line-clamp: 3;
      }

      #intro .panel-visual {
        max-height: min(38svh, 260px);
      }

      #intro .phone-frame {
        max-height: min(36svh, 240px);
      }
    }

    .excal-embed-wrap {
      width: min(100%, 520px);
      display: grid;
      gap: 10px;
      justify-items: stretch;
    }

    .excal-embed {
      width: 100%;
      aspect-ratio: 520 / 390;
      margin: 0;
      overflow: hidden;
      border-radius: inherit;
    }

    .excal-drawbox {
      width: min(100%, 520px);
      border: 2px solid var(--v1-ink);
      border-radius: 22px;
      background: rgb(255 255 255 / .88);
      box-shadow: var(--shadow);
      overflow: hidden;
      direction: ltr;
      unicode-bidi: isolate;
    }

    .excal-caption {
      margin: 0;
      color: var(--v1-muted);
      font-weight: 750;
      font-size: 0.84rem;
      line-height: 1.35;
      max-width: 520px;
    }

    .excal-caption a {
      font-weight: 850;
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    .pricing-board {
      padding: 0;
      min-height: 0;
      gap: 0;
      overflow: hidden;
      align-content: start;
    }

    .pricing-head,
    .pricing-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 12px 16px;
      border-bottom: 2px solid var(--v1-ink);
      font-weight: 850;
    }

    .pricing-head {
      background: rgb(226 232 255 / .85);
      font-weight: 950;
      font-size: 0.9rem;
    }

    .pricing-row small {
      color: var(--v1-muted);
      font-weight: 800;
    }

    .token-chip {
      margin: 10px;
      padding: 10px 12px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      border: 2px dashed var(--v1-ink);
      border-radius: 12px;
      font-weight: 900;
      font-size: 0.88rem;
    }

    .tutorial-panel {
      padding: 20px;
      display: grid;
      gap: 14px;
      border: 2px solid var(--v1-ink);
      border-radius: 22px;
      background: rgb(255 255 255 / .9);
      box-shadow: var(--shadow);
    }

    .tutorial-list {
      margin: 0;
      padding: 0;
      list-style: none;
      display: grid;
      gap: 10px;
    }

    .tutorial-item {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 12px;
      align-items: start;
      padding: 12px;
      border: 2px solid var(--v1-ink);
      border-radius: 14px;
      background: var(--v1-cream);
      box-shadow: 3px 3px 0 var(--v1-ink);
    }

    .tutorial-num {
      width: 30px;
      height: 30px;
      display: grid;
      place-items: center;
      border-radius: 999px;
      background: var(--panel-accent, var(--v1-success));
      color: #fff;
      font-weight: 950;
      font-size: 0.95rem;
    }

    .tutorial-body {
      display: grid;
      gap: 4px;
      min-width: 0;
    }

    .tutorial-body strong {
      font-size: 1rem;
    }

    .tutorial-body span {
      color: var(--v1-muted);
      font-weight: 750;
      font-size: 0.9rem;
      line-height: 1.35;
    }

    .tutorial-tip {
      margin: 0;
      padding: 10px 12px;
      border-radius: 12px;
      border: 1.5px solid var(--v1-ink);
      background: rgb(255 255 255 / .75);
      font-size: 0.82rem;
      font-weight: 750;
      color: var(--v1-muted);
      line-height: 1.4;
    }

    .download-links a {
      min-height: 50px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 14px;
      padding: 0 16px;
      border: 2px solid var(--v1-ink);
      border-radius: 14px;
      background: rgb(255 255 255 / .9);
      box-shadow: 3px 3px 0 var(--v1-ink);
      text-decoration: none;
      font-weight: 950;
    }

    .download-links a.primary {
      background: var(--v1-red);
      color: #fff;
    }

    .download-links a::after {
      content: "\2196";
      direction: ltr;
      unicode-bidi: isolate;
    }

    .builder-credit {
      position: fixed;
      inset-inline-start: 18px;
      inset-block-end: 32px;
      z-index: 48;
      direction: ltr;
      unicode-bidi: isolate;
      display: inline-flex;
      align-items: center;
      gap: .25rem;
      padding: .22rem .5rem;
      border: 1.5px solid var(--v1-ink);
      border-radius: 999px;
      background: rgb(255 255 255 / .72);
      color: var(--v1-ink);
      box-shadow: 1.5px 1.5px 0 var(--v1-ink);
      text-decoration: none;
      font-size: .68rem;
      font-weight: 850;
      letter-spacing: .01em;
      line-height: 1;
      white-space: nowrap;
      transform: translateY(0);
      cursor: pointer;
      transition: transform 0.15s ease, background-color 0.15s ease, box-shadow 0.15s ease;
    }

    .builder-credit:hover,
    .builder-credit:focus-visible {
      background: var(--v1-yellow);
      box-shadow: 2px 2px 0 var(--v1-ink);
      outline: 3px solid var(--v1-paper);
      outline-offset: 2px;
      transform: translateY(-2px);
    }

    .builder-credit span:first-child {
      font-size: .58rem;
      font-weight: 700;
      letter-spacing: .08em;
      text-transform: uppercase;
      opacity: .72;
    }

    .builder-credit span[aria-hidden="true"] {
      opacity: 0.52;
    }

    .builder-credit strong {
      font-weight: 900;
    }

    @media (min-width: 861px) {
      html.pitch-vertical-desktop {
        scroll-snap-type: y proximity;
      }

      body.pitch-vertical .scroll-hint {
        display: none;
      }

