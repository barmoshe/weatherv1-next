<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>WeatherV1 — Download</title>
    <style>
      :root {
        color-scheme: light dark;
        --bg: oklch(0.16 0.02 260);
        --fg: oklch(0.96 0.01 260);
        --muted: oklch(0.72 0.02 260);
        --card: oklch(0.22 0.03 260);
        --accent: oklch(0.72 0.14 230);
        --accent-fg: oklch(0.14 0.02 260);
        font-family: system-ui, sans-serif;
      }
      @media (prefers-color-scheme: light) {
        :root {
          --bg: oklch(0.98 0.01 260);
          --fg: oklch(0.18 0.02 260);
          --muted: oklch(0.45 0.02 260);
          --card: oklch(1 0 0);
          --accent: oklch(0.55 0.16 250);
          --accent-fg: oklch(0.99 0 0);
        }
      }
      body {
        margin: 0;
        min-height: 100dvh;
        display: grid;
        place-items: center;
        padding: 1.5rem;
        background: var(--bg);
        color: var(--fg);
        line-height: 1.5;
      }
      main {
        width: min(28rem, 100%);
        padding: 1.75rem;
        border-radius: 1rem;
        background: var(--card);
        box-shadow: 0 0.5rem 2rem oklch(0 0 0 / 0.25);
      }
      h1 {
        font-size: 1.35rem;
        font-weight: 650;
        margin: 0 0 0.35rem;
        letter-spacing: -0.02em;
      }
      p.lead {
        margin: 0 0 1.25rem;
        color: var(--muted);
        font-size: 0.95rem;
      }
      .actions {
        display: flex;
        flex-direction: column;
        gap: 0.65rem;
      }
      a.btn {
        display: block;
        text-align: center;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.95rem;
        padding: 0.75rem 1rem;
        border-radius: 0.5rem;
        background: var(--accent);
        color: var(--accent-fg);
        transition: transform 0.15s ease, opacity 0.15s ease;
      }
      a.btn:hover {
        opacity: 0.92;
        transform: translateY(-1px);
      }
      a.btn:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
      }
      a.subtle {
        display: block;
        margin-top: 1.1rem;
        text-align: center;
        font-size: 0.85rem;
        color: var(--muted);
      }
    </style>
  </head>
  <body>
    <main>
      <h1>WeatherV1 desktop</h1>
      <p class="lead">Latest installers from this repo’s GitHub Release (requires a published <code>v*</code> tag build).</p>
      <div class="actions">
        <a
          class="btn"
          href="https://github.com/__REPO__/releases/latest/download/WeatherV1-macOS.zip"
          >Download for macOS (.zip)</a
        >
        <a
          class="btn"
          href="https://github.com/__REPO__/releases/latest/download/WeatherV1-Setup.exe"
          >Download for Windows (Setup)</a
        >
      </div>
      <a class="subtle" href="https://github.com/__REPO__/releases">All releases</a>
    </main>
  </body>
</html>
