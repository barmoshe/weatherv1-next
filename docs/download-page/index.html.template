          { id: "pipe-a1", type: "arrow", x1: 160, y1: 180, x2: 222, y2: 180 },
          { id: "pipe-a2", type: "arrow", x1: 372, y1: 180, x2: 425, y2: 180 },
          { id: "pipe-a3", type: "arrow", x1: 582, y1: 180, x2: 634, y2: 180 },
          { id: "pipe-a4", type: "arrow", x1: 648, y1: 232, x2: 524, y2: 366 },
          { id: "pipe-a5", type: "arrow", x1: 362, y1: 410, x2: 246, y2: 458 }
        ]
      },
      {
        id: "studio-home",
        frameName: "מסך סטודיו ראשי",
        kicker: "מסכים",
        title: "הסטודיו הראשי",
        subtitle: "{{כאן נכניס צילום מסך של הדשבורד הראשי}}",
        bullets: ["Masthead", "Tabs", "Hero Strip", "Progress"],
        notes: "שקף placeholder לצילום מסך: מסך הבית של הסטודיו.",
        theme: THEMES.cream,
