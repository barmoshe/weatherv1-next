          <div class="visual-board" style="box-shadow:none;border:0;width:100%;min-height:260px;padding:0">
            <div class="mini-card"><span>קבצים מקומיים</span><small>שליטה</small></div>
            <div class="mini-card"><span>עבודת וידאו</span><small>אמינות</small></div>
            <div class="mini-card"><span>תהליך חוזר</span><small>שגרה</small></div>
          </div>
        </div>`;
      }
      if (type === "value") {
        return `<div class="card-stack">
          <div class="timeline-row"><span class="timeline-dot">✓</span><span>יותר סרטונים בפחות זמן</span></div>
          <div class="timeline-row"><span class="timeline-dot">✓</span><span>פורמט מזוהה ואחיד</span></div>
          <div class="timeline-row"><span class="timeline-dot">✓</span><span>פחות עבודה טכנית ללקוח</span></div>
        </div>`;
      }
      if (type === "excalidrawDemo") {
        const src = "download-page/assets/pitch-sample-animated.svg";
        return `<div class="excal-embed-wrap">
          <div class="excal-drawbox" lang="en" dir="ltr">
            <object class="excal-embed" type="image/svg+xml" data="${escapeHtml(src)}" title="דוגמת שרטוט מהיר ללקוח" aria-label="דוגמת שרטוט מהיר ללקוח"></object>
          </div>
          <p class="excal-caption">ניתן להחליף ב־SVG שייצא מהכלי הציבורי <a href="https://dai-shi.github.io/excalidraw-animate" target="_blank" rel="noreferrer">excalidraw-animate</a> (<a href="https://github.com/dai-shi/excalidraw-animate" target="_blank" rel="noreferrer">מקור</a>).</p>
        </div>`;
      }
      if (type === "introPipeline") {
        return `<div class="intro-pipeline-diagram intro-pipeline-excal" dir="rtl">
          <svg class="intro-pipeline-edge-layer intro-pipeline-edge-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 22" preserveAspectRatio="none" aria-hidden="true">
            <defs>
              <linearGradient id="introPipelineFlowStroke" gradientUnits="userSpaceOnUse" x1="100" y1="0" x2="0" y2="0">
                <stop offset="0%" stop-color="#f9543e"/>
                <stop offset="55%" stop-color="#e84232"/>
                <stop offset="100%" stop-color="#c8202b"/>
              </linearGradient>
            </defs>
            <path class="intro-pipeline-edge intro-pipeline-edge--1" pathLength="1" vector-effect="non-scaling-stroke" fill="none" stroke="url(#introPipelineFlowStroke)" stroke-width="2.75" stroke-linecap="round" d="M 91.667 11 C 88.25 14.75 79.42 14.83 75 11"/>
            <path class="intro-pipeline-edge intro-pipeline-edge--2" pathLength="1" vector-effect="non-scaling-stroke" fill="none" stroke="url(#introPipelineFlowStroke)" stroke-width="2.75" stroke-linecap="round" d="M 75 11 C 71.08 14.92 62.92 14.92 58.333 11"/>
            <path class="intro-pipeline-edge intro-pipeline-edge--3" pathLength="1" vector-effect="non-scaling-stroke" fill="none" stroke="url(#introPipelineFlowStroke)" stroke-width="2.75" stroke-linecap="round" d="M 58.333 11 C 54.42 14.92 46.58 14.92 41.667 11"/>
            <path class="intro-pipeline-edge intro-pipeline-edge--4" pathLength="1" vector-effect="non-scaling-stroke" fill="none" stroke="url(#introPipelineFlowStroke)" stroke-width="2.75" stroke-linecap="round" d="M 41.667 11 C 37.75 14.92 29.92 14.92 25 11"/>
            <path class="intro-pipeline-edge intro-pipeline-edge--5" pathLength="1" vector-effect="non-scaling-stroke" fill="none" stroke="url(#introPipelineFlowStroke)" stroke-width="2.75" stroke-linecap="round" d="M 25 11 C 21.08 14.92 12.92 14.92 8.333 11"/>
          </svg>
          <span class="intro-pipeline-node intro-pipeline-node--a intro-pipeline-node-slot intro-pipeline-node-slot--1">קריינות</span>
          <span class="intro-pipeline-node intro-pipeline-node--b intro-pipeline-node-slot intro-pipeline-node-slot--2">תמלול</span>
          <span class="intro-pipeline-node intro-pipeline-node--c intro-pipeline-node-slot intro-pipeline-node-slot--3">תוכנית סצנות</span>
          <span class="intro-pipeline-node intro-pipeline-node--d intro-pipeline-node-slot intro-pipeline-node-slot--4">התאמת סגמנטים</span>
          <span class="intro-pipeline-node intro-pipeline-node--e intro-pipeline-node-slot intro-pipeline-node-slot--5">רינדור</span>
          <span class="intro-pipeline-node intro-pipeline-node--f intro-pipeline-node-slot intro-pipeline-node-slot--6">צפייה בתוצאה</span>
        </div>`;
      }
      return `<div class="visual-board"><div class="mini-card"><span>${escapeHtml(section.title)}</span><small>Placeholder</small></div></div>`;
    }

    /** Normalise merge key for `desktopCluster`; empty = no cluster. */
    function normalizeDesktopCluster(section) {
      const v = section.desktopCluster;
      if (typeof v !== "string") return "";
      return v.trim();
    }

    /**
     * Cells for the horizontal scrub: singletons, or 2+ consecutive slides with the same `desktopCluster`
     * merged into one lane with an inner vertical scroll stack.
     */
    function buildStoryCells(sections) {
      const out = [];
      let i = 0;
      while (i < sections.length) {
        const cid = normalizeDesktopCluster(sections[i]);
        if (cid) {
          const grouped = [];
          while (i < sections.length && normalizeDesktopCluster(sections[i]) === cid) {
            grouped.push({ section: sections[i], globalIdx: i });
            i++;
          }
          if (grouped.length >= 2) {
            out.push({ type: "cluster", cid, grouped });
          } else {
            out.push({ type: "single", section: grouped[0].section, globalIdx: grouped[0].globalIdx });
          }
        } else {
          out.push({ type: "single", section: sections[i], globalIdx: i });
          i++;
        }
      }
      return out;
    }

    function hasMobileSummary(section) {
      const s = section.mobileSummary;
      return typeof s === "string" && s.trim() !== "";
    }

    function leadBlocksHtml(section, pitchProductLayout) {
      const ms = hasMobileSummary(section) ? escapeHtml(section.mobileSummary.trim()) : "";
      const leadEsc = escapeHtml(section.lead);
      if (pitchProductLayout) {
        if (ms) {
          return `<div class="pitch-lead-well"><p class="lead lead-desktop-only">${leadEsc}</p><p class="lead panel-mobile-summary">${ms}</p></div>`;
        }
        return `<div class="pitch-lead-well"><p class="lead">${leadEsc}</p></div>`;
      }
      if (ms) {
        return `<p class="lead lead-desktop-only">${leadEsc}</p><p class="lead panel-mobile-summary">${ms}</p>`;
      }
      return `<p class="lead">${leadEsc}</p>`;
    }

    function isPitchProductSection(section) {
      return (
        section.id === "studio" ||
        section.id === "catalog" ||
        section.id === "local-first" ||
        section.id === "analytics" ||
        section.id === "pricing" ||
        section.id === "v1-next"
      );
    }

    function bulletsMarkup(section) {
      if (section.id === "intro" && section.visual === "introPipeline") return "";

      const mobileList = Array.isArray(section.mobileBullets) ? section.mobileBullets : null;
      const hasMobileBullets = mobileList && mobileList.length > 0;

      if (section.id === "studio" && section.bullets.length > 0) {
        const wizardItems = section.bullets
          .map(
            (item, i) =>
              `<li data-studio-phase-bullet="${["upload", "transcript", "planning", "render"][i] || "upload"}">${escapeHtml(item)}</li>`
          )
          .join("");
        if (hasMobileBullets) {
          const mob = mobileList.map(item => `<li>${escapeHtml(item)}</li>`).join("");
          return `<ul class="bullets bullets--studio-wizard bullets-desktop-only">${wizardItems}</ul><ul class="bullets panel-mobile-bullets">${mob}</ul>`;
        }
        return `<ul class="bullets bullets--studio-wizard">${wizardItems}</ul>`;
      }

      if (section.bullets.length === 0) return "";

      const desktopItems = section.bullets.map(item => `<li>${escapeHtml(item)}</li>`).join("");
      if (hasMobileBullets) {
        const mob = mobileList.map(item => `<li>${escapeHtml(item)}</li>`).join("");
        return `<ul class="bullets bullets-desktop-only">${desktopItems}</ul><ul class="bullets panel-mobile-bullets">${mob}</ul>`;
      }
      return `<ul class="bullets">${desktopItems}</ul>`;
    }

    function singlePanelSectionHtml(section, globalIdx, rollIdx) {
      const heroDownloads = section.id === "intro" ? heroDownloadsBlock() : "";
      const visualAria = section.visual === "excalidrawDemo" ? "" : " aria-hidden=\"true\"";
      const copyClass = section.id === "intro" ? "panel-copy panel-copy--intro" : "panel-copy";
      const heading =
        section.id === "intro"
          ? `<h1>${escapeHtml(section.title)}</h1>`
          : `<h2>${escapeHtml(section.title)}</h2>`;
      const visualBlock =
        section.id === "intro" || section.id === "v1-next"
          ? ""
          : `<div class="panel-visual"${visualAria}>${visualMarkup(section.visual, section)}</div>`;
      const introPipelineBlock =
        section.id === "intro" && section.visual === "introPipeline"
          ? `<figure class="intro-pipeline-wrap" role="group" aria-label="זרימת ייצור: קריינות, תמלול, תכנון והתאמה מהקטלוג, רינדור והורדה">${visualMarkup("introPipeline", section)}</figure>`
          : "";
      const bulletsBlock = bulletsMarkup(section);
      const pitchProductLayout = isPitchProductSection(section);
      const pricingPullquoteBlock =
        section.id === "pricing"
          ? `<blockquote class="pitch-pricing-quote"><p>${escapeHtml(
              "נבנתה אפליקציה שמחברת בין קריינות תחזית, תמלול, תכנון סצנות, קטלוג וידאו ורינדור בסיסי לסרטון אנכי."
            )}</p></blockquote>`
          : "";
      const studioWizardToolbar =
        section.id === "studio"
          ? `<div class="pitch-studio-wiz-controls-wrap" role="note" aria-labelledby="pitch-studio-wiz-legend">
            <p id="pitch-studio-wiz-legend" class="pitch-studio-wiz-hint">בחרו שלב בשורת ההתקדמות במוקאפ כדי לראות איך התחזית נבנית — ללא הפעלה אוטומטית.</p>
          </div>`
          : "";
      const pitchLayoutAttr = pitchProductLayout ? ` data-pitch-layout="product-app"` : "";
      const panelLayoutAttr =
        section.id === "intro" || section.id === "v1-next"
          ? ""
          : ` data-panel-layout="${escapeHtml(section.panelLayout || "split-balanced")}"`;
      const leadBlock = leadBlocksHtml(section, pitchProductLayout);
      return `<section
        class="story-panel"
        id="${escapeHtml(section.id)}"
        style="--panel-paper:${section.theme.paper};--panel-accent:${section.theme.accent}"
        data-index="${globalIdx}"
        data-roll-index="${rollIdx}"
        data-transition="${escapeHtml(panelTransition(section))}"${pitchLayoutAttr}${panelLayoutAttr}
      >
        <div class="panel-inner">
          <div class="${copyClass}">
            <div class="kicker">${escapeHtml(section.kicker)}</div>
            ${heading}
            ${leadBlock}
            ${introPipelineBlock}
            ${bulletsBlock}
            ${pricingPullquoteBlock}
            ${studioWizardToolbar}
            ${heroDownloads}
          </div>
          ${visualBlock}
        </div>
      </section>`;
    }

    /** One horizontal column containing vertically stacked `.story-subslide`s. */
    function clusteredPanelSectionHtml(cid, grouped, rollIdx) {
      const safeId = cid.replace(/[^a-zA-Z0-9_-]/g, "-");
      const first = grouped[0].section;
      const slides = grouped
        .map(({ section: sec, globalIdx }) => {
          const visualAria = sec.visual === "excalidrawDemo" ? "" : " aria-hidden=\"true\"";
          const bulletsBlock = bulletsMarkup(sec);
          const visualBlock =
            sec.id === "v1-next"
              ? ""
              : `<div class="panel-visual"${visualAria}>${visualMarkup(sec.visual, sec)}</div>`;
          const panelLayoutAttr =
            sec.id === "v1-next"
              ? ""
              : ` data-panel-layout="${escapeHtml(sec.panelLayout || "split-balanced")}"`;
          const pitchProductLayout = isPitchProductSection(sec);
          const leadBlock = leadBlocksHtml(sec, pitchProductLayout);
          return `
      <article
        class="story-subslide"
        id="${escapeHtml(sec.id)}"
        style="--panel-paper:${sec.theme.paper};--panel-accent:${sec.theme.accent}"
        data-section-index="${globalIdx}"
        ${panelLayoutAttr}
        data-transition="${escapeHtml(panelTransition(sec))}"
      >
        <div class="panel-inner">
          <div class="panel-copy">
            <div class="kicker">${escapeHtml(sec.kicker)}</div>
            <h2>${escapeHtml(sec.title)}</h2>
            ${leadBlock}
            ${bulletsBlock}
          </div>
          ${visualBlock}
        </div>
      </article>`;
        })
        .join("");

      return `<section
        class="story-panel story-panel--vcluster"
        id="${escapeHtml("cluster-" + safeId)}"
        data-desktop-cluster="${escapeHtml(cid)}"
        data-index="${grouped[0].globalIdx}"
        data-roll-index="${rollIdx}"
        data-transition="${escapeHtml(panelTransition(first))}"
        aria-label="פרק עם גלילה אנכית פנימית"
      >
        <div class="story-vstack">
          ${slides}
        </div>
      </section>`;
    }

    function buildStoryRollHtml(sections) {
      const cells = buildStoryCells(sections);
      return cells
        .map((cell, rollIdx) => {
          if (cell.type === "cluster") return clusteredPanelSectionHtml(cell.cid, cell.grouped, rollIdx);
          return singlePanelSectionHtml(cell.section, cell.globalIdx, rollIdx);
        })
        .join("");
    }

    trackRoll.innerHTML = buildStoryRollHtml(storySections);

    (function initIntroPipelineDiagramInview() {
      let observer = null;
      const teardown = () => {
        if (observer) {
          observer.disconnect();
          observer = null;
        }
      };

      const sync = () => {
        teardown();
        const intro = document.getElementById("intro");
        const diagram = intro?.querySelector(".intro-pipeline-diagram.intro-pipeline-excal");
        if (!intro || !diagram) return;

        diagram.classList.remove("intro-pipeline-diagram--inview");

        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
          diagram.classList.add("intro-pipeline-diagram--inview");
          return;
        }

        const markIntroIfIntersectingViewport = () => {
          const r = intro.getBoundingClientRect();
          const vh = window.innerHeight || document.documentElement.clientHeight || 1;
          if (r.bottom > 10 && r.top < vh - 10) diagram.classList.add("intro-pipeline-diagram--inview");
        };

        markIntroIfIntersectingViewport();

        observer = new IntersectionObserver(
          ents => {
            for (let i = 0; i < ents.length; i++) {
              if (ents[i].isIntersecting) diagram.classList.add("intro-pipeline-diagram--inview");
            }
          },
          { root: null, rootMargin: "-4% 0px -52% 0px", threshold: [0.04, 0.12] }
        );
        observer.observe(intro);
      };

      sync();
      const mqReduce = window.matchMedia("(prefers-reduced-motion: reduce)");
      if (typeof mqReduce.addEventListener === "function") mqReduce.addEventListener("change", sync);
      else if (typeof mqReduce.addListener === "function") mqReduce.addListener(sync);

      window.addEventListener(
        "hashchange",
        () => {
          const intro = document.getElementById("intro");
          const diagram = intro?.querySelector(".intro-pipeline-diagram.intro-pipeline-excal");
          if (!intro || !diagram || window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
          const r = intro.getBoundingClientRect();
          const vh = window.innerHeight || document.documentElement.clientHeight || 1;
          if (r.bottom > 10 && r.top < vh - 10) diagram.classList.add("intro-pipeline-diagram--inview");
        },
        { passive: true }
      );
    })();

    (function initMobileDesktopCta() {
      const btn = document.getElementById("pitch-copy-page-url");
      const status = document.getElementById("pitch-desktop-cta-status");
      const mailEl = document.getElementById("pitch-open-email-link");
      if (!btn || !status) return;

      const pageUrl = () =>
        `${location.origin}${location.pathname}${location.search || ""}${location.hash || ""}`;

      const setMailtoHref = () => {
        if (!mailEl) return;
        const subj = encodeURIComponent("Weather V1 — מצגת");
        const body = encodeURIComponent(`קישור למצגת המלאה במחשב:\n\n${pageUrl()}\n`);
        mailEl.setAttribute("href", `mailto:?subject=${subj}&body=${body}`);
      };
      setMailtoHref();
      window.addEventListener("hashchange", setMailtoHref, { passive: true });

      let clearStatusT = 0;
      btn.addEventListener("click", () => {
        const url = pageUrl();
        const ok = text => {
          status.textContent = text;
          window.clearTimeout(clearStatusT);
          clearStatusT = window.setTimeout(() => {
            status.textContent = "";
          }, 3800);
        };

        if (navigator.clipboard && typeof navigator.clipboard.writeText === "function") {
          navigator.clipboard.writeText(url).then(() => ok("הקישור הועתק — פתחו במחשב")).catch(() =>
            ok("העתקה נכשלה — נסו «שליחה באימייל»")
          );
          return;
        }
        ok("העתקה זמינה רק בדפדפן מעודכן — נסו «שליחה באימייל»");
      });
    })();

    const pitchStepUp = document.getElementById("pitch-step-up");
    const pitchStepDown = document.getElementById("pitch-step-down");

    function collectPitchSteps() {
      const out = [];
      document.querySelectorAll("#storyRoll > .story-panel").forEach(panel => {
        if (panel.classList.contains("story-panel--vcluster")) {
          const vstack = panel.querySelector(":scope > .story-vstack");
          if (!vstack) return;
          vstack.querySelectorAll(":scope > .story-subslide").forEach(sub => {
            out.push({ el: sub, panel, vstack });
          });
        } else {
          out.push({ el: panel, panel, vstack: null });
        }
      });
      return out;
    }

    function isHorizontalStoryDesktop() {
      return (
        window.matchMedia("(min-width: 861px)").matches &&
        document.body.classList.contains("is-scrollstory") &&
        !document.body.classList.contains("pitch-vertical") &&
        !!mainScrollTrigger
      );
    }

    function getActivePitchStepIndex(steps) {
      if (!steps.length) return 0;
      if (isHorizontalStoryDesktop()) {
        const rollPanels = gsap.utils.toArray("#storyRoll > .story-panel");
        const st = mainScrollTrigger;
        const n = rollPanels.length;
        if (n < 1) return 0;
        const denom = Math.max(1, n - 1);
        const rollIdx = Math.min(n - 1, Math.max(0, Math.round(st.progress * denom)));
        const activePanel = rollPanels[rollIdx];
        const cand = steps.map((s, i) => ({ s, i })).filter(x => x.s.panel === activePanel);
        if (!cand.length) return 0;
        if (cand.length === 1) return cand[0].i;
        const vstack = cand[0].s.vstack;
        if (!vstack) return cand[0].i;
        const vr = vstack.getBoundingClientRect();
        const midY = vr.top + vr.height / 2;
        let bestI = cand[0].i;
        let bestD = Infinity;
        cand.forEach(({ s, i }) => {
          const r = s.el.getBoundingClientRect();
          const d = Math.abs(r.top + r.height / 2 - midY);
          if (d < bestD) {
            bestD = d;
            bestI = i;
          }
        });
        return bestI;
      }

      const cy = window.innerHeight / 2;
      let best = 0;
      let bestD = Infinity;
      steps.forEach((s, i) => {
        const r = s.el.getBoundingClientRect();
        if (!r.height && !r.width) return;
        const d = Math.abs(r.top + r.height / 2 - cy);
        if (d < bestD) {
          bestD = d;
          best = i;
        }
      });
      return best;
    }

    function syncPitchStepHash(step) {
      if (!step || !step.el.id) return;
      const h = "#" + step.el.id;
      if (location.hash === h) return;
      try {
        history.replaceState(null, "", h);
      } catch (_) {}
    }

    function centerSubslideInVstack(step) {
      if (!step || !step.el.classList.contains("story-subslide") || !step.vstack) return;
      const v = step.vstack;
      const sub = step.el;
      const maxS = Math.max(0, v.scrollHeight - v.clientHeight);
      const desired = sub.offsetTop - (v.clientHeight - sub.offsetHeight) / 2;
      v.scrollTop = Math.max(0, Math.min(maxS, desired));
    }

    function updatePitchStepNavButtons(idx, total) {
      if (pitchStepUp) pitchStepUp.disabled = idx <= 0;
      if (pitchStepDown) pitchStepDown.disabled = idx >= total - 1;
    }

    function goToPitchStepIndex(targetIdx) {
      const steps = collectPitchSteps();
      if (!steps.length) return;
      const idx = Math.min(steps.length - 1, Math.max(0, targetIdx));
      const step = steps[idx];
      const behavior = reduceMotion ? "auto" : "smooth";

      if (!isHorizontalStoryDesktop()) {
        step.el.scrollIntoView({ block: "center", inline: "nearest", behavior });
        syncPitchStepHash(step);
        updatePitchStepNavButtons(idx, steps.length);
        return;
      }

      const st = mainScrollTrigger;
      if (!st) {
        step.el.scrollIntoView({ block: "center", inline: "nearest", behavior: "auto" });
        syncPitchStepHash(step);
        updatePitchStepNavButtons(idx, steps.length);
        return;
      }

      const rollPanels = gsap.utils.toArray("#storyRoll > .story-panel");
      const denom = Math.max(1, rollPanels.length - 1);
      const rollIdx = Number(step.panel.dataset.rollIndex ?? step.panel.dataset.index ?? 0);
      const progress = denom ? rollIdx / denom : 0;
      const top = st.start + (st.end - st.start) * progress;

      const finish = () => {
        centerSubslideInVstack(step);
        if (window.ScrollTrigger) ScrollTrigger.refresh();
        syncPitchStepHash(step);
        updatePitchStepNavButtons(idx, steps.length);
      };

      window.scrollTo({ top, behavior: "auto" });
      requestAnimationFrame(() => {
        requestAnimationFrame(finish);
      });
    }

    function goToPitchStepDelta(delta) {
      const steps = collectPitchSteps();
      if (!steps.length) return;
      const cur = getActivePitchStepIndex(steps);
      goToPitchStepIndex(cur + delta);
    }

    function onPitchStepKeydown(ev) {
      const t = ev.target;
      if (t && t.closest && t.closest("input, textarea, select, [contenteditable='true']")) return;
      if (ev.defaultPrevented) return;
      if (ev.key === "ArrowUp") {
        ev.preventDefault();
        goToPitchStepDelta(-1);
      } else if (ev.key === "ArrowDown") {
        ev.preventDefault();
        goToPitchStepDelta(1);
      }
    }

    function refreshPitchStepNavUi() {
      const steps = collectPitchSteps();
      if (!steps.length) return;
      const idx = getActivePitchStepIndex(steps);
      updatePitchStepNavButtons(idx, steps.length);
    }

    let pitchStepNavInitialized = false;
    function initPitchStepNav() {
      if (pitchStepNavInitialized) return;
      if (!pitchStepUp || !pitchStepDown) return;
      pitchStepNavInitialized = true;
      pitchStepUp.addEventListener("click", () => goToPitchStepDelta(-1));
      pitchStepDown.addEventListener("click", () => goToPitchStepDelta(1));
      document.addEventListener("keydown", onPitchStepKeydown);
      window.addEventListener("scroll", refreshPitchStepNavUi, { passive: true });
      refreshPitchStepNavUi();
    }

    /** Studio wizard: four explicit phases, click + keyboard; no GSAP/RAF tour. */
    const STUDIO_PHASES = ["upload", "transcript", "planning", "render"];
    const STUDIO_HIGHLIGHT_FOR_PHASE = {
      upload: "upload",
      transcript: "transcript",
      planning: "segments",
      render: "output",
    };

    let studioWizardPhase = "upload";

    function setStudioPhase(phase) {
      if (!STUDIO_PHASES.includes(phase)) return;
      studioWizardPhase = phase;
      const shell = document.querySelector("#studio .pitch-app-shell");
      if (shell) {
        shell.dataset.studioPhase = phase;
        shell.dataset.highlight = STUDIO_HIGHLIGHT_FOR_PHASE[phase] || phase;
      }
      updateStudioWizardSteps(phase);
      updateStudioStoryBullets(phase);
    }

    function updateStudioWizardSteps(activePhase) {
      const activeIndex = STUDIO_PHASES.indexOf(activePhase);

      document.querySelectorAll("#studio .pitch-wiz-step").forEach(button => {
        const raw = button.getAttribute("data-studio-phase-button") || "";
        const index = STUDIO_PHASES.indexOf(raw);

        const isActive = raw === activePhase;
        const isComplete = index >= 0 && index < activeIndex;

        button.classList.toggle("is-active", isActive);
        button.classList.toggle("is-complete", isComplete);

        if (isActive) button.setAttribute("aria-current", "step");
        else button.removeAttribute("aria-current");
      });
    }

    function updateStudioStoryBullets(activePhase) {
      const panel = document.getElementById("studio");
      if (!panel) return;

      panel.querySelectorAll(".bullets--studio-wizard li[data-studio-phase-bullet]").forEach(li => {
        const b = li.getAttribute("data-studio-phase-bullet") || "";
        li.classList.toggle("is-wizard-active", b === activePhase);
      });
    }

    function teardownStudioWizardHighlight() {
      if (typeof studioWizardCleanup === "function") {
        studioWizardCleanup();
        studioWizardCleanup = null;
      }

      studioWizardPhase = "upload";

      const shell = document.querySelector("#studio .pitch-app-shell");
      if (shell) {
        shell.dataset.studioPhase = "upload";
        shell.dataset.highlight = "upload";
      }

      updateStudioWizardSteps("upload");
      updateStudioStoryBullets("upload");
    }

    function initStudioWizardHighlight() {
      teardownStudioWizardHighlight();
      const root = document.getElementById("studio");
      if (!root) return;

      const onClick = event => {
        const button = event.target.closest("[data-studio-phase-button]");
        if (!button || !root.contains(button)) return;
        const phase = button.getAttribute("data-studio-phase-button");
        if (!phase || !STUDIO_PHASES.includes(phase)) return;
        setStudioPhase(phase);
      };

      const onKeydown = event => {
        const activeElement = document.activeElement;
        if (
          !activeElement ||
          !activeElement.matches("[data-studio-phase-button]") ||
          !root.contains(activeElement)
        ) {
          return;
        }

        const currentIndex = STUDIO_PHASES.indexOf(studioWizardPhase);
        if (currentIndex < 0) return;

        if (event.key !== "ArrowRight" && event.key !== "ArrowLeft") return;

        event.preventDefault();

        const direction = event.key === "ArrowRight" ? 1 : -1;
        const nextIndex = Math.max(0, Math.min(STUDIO_PHASES.length - 1, currentIndex + direction));
        const nextPhase = STUDIO_PHASES[nextIndex];
        setStudioPhase(nextPhase);

        root.querySelector(`[data-studio-phase-button="${nextPhase}"]`)?.focus();
      };

      root.addEventListener("click", onClick);
      root.addEventListener("keydown", onKeydown);
      studioWizardCleanup = () => {
        root.removeEventListener("click", onClick);
        root.removeEventListener("keydown", onKeydown);
      };

      setStudioPhase("upload");
    }

    function setProgress(value) {
      const clamped = Math.max(0, Math.min(1, value));
      progressFill.style.transform = `scaleX(${clamped})`;
    }

    function teardownHorizontalStory() {
      teardownStudioWizardHighlight();
      teardownVerticalClusterWheelCaptures();
      teardownHorizontalPanelReveals();
      teardownVerticalPanelReveals();
      if (horizontalTween) {
        horizontalTween.kill();
        horizontalTween = null;
      }
      mainScrollTrigger = null;
    }

    /** Panel reveal tweens targets in this selector; Studio wizard `.pitch-wiz-step` is included alongside `.panel-visual > *`. */
    const PANEL_REVEAL_SEL =
      ".kicker, h1, h2, .pitch-lead-well .lead, .lead, .panel-mobile-summary, .bullets li, .pitch-pricing-quote, .pitch-wiz-step, .pitch-catalog-card, .pitch-catalog-detail, .intro-pipeline-node, .intro-pipeline-edge, .hero-downloads, .panel-visual > *";

    /**
     * verticalStack = desktop TTB pitch; false = entrances during horizontal-pin (`ScrollTrigger.horizontal` + containerAnimation).
     * `panel.dataset.transition`: rtl | ttb-showcase | ttb-subtle
     */
    function panelRevealTweenVars(panel, verticalStack) {
      const mode = panel.dataset.transition || "ttb-subtle";
      const carousel = verticalStack !== true;

      if (mode === "rtl") {
        return {
          x: carousel ? 52 : 44,
          y: 0,
          duration: verticalStack ? 0.55 : 0.58,
          stagger: carousel ? 0.06 : 0.05,
          ease: verticalStack ? "power2.out" : "power3.out",
        };
      }

      const showcase = mode === "ttb-showcase";

      if (carousel) {
        return {
          x: 0,
          y: showcase ? 46 : 20,
          duration: showcase ? 0.7 : 0.48,
          stagger: showcase ? 0.095 : 0.035,
          ease: showcase ? "power3.out" : "power2.out",
        };
      }

      return {
        x: 0,
        y: showcase ? 50 : 32,
        duration: showcase ? 0.62 : 0.52,
        stagger: showcase ? 0.08 : 0.045,
        ease: showcase ? "power3.out" : "power2.out",
      };
    }

    function teardownHorizontalPanelReveals() {
      horizontalPanelRevealAnims.forEach(anim => {
        if (!anim) return;
        const st = anim.scrollTrigger;
        if (st) st.kill(false);
        anim.kill();
      });
      horizontalPanelRevealAnims = [];
    }

    function teardownVerticalPanelReveals() {
      verticalPanelRevealAnims.forEach(anim => {
        if (!anim) return;
        const st = anim.scrollTrigger;
        if (st) st.kill(false);
        anim.kill();
      });
      verticalPanelRevealAnims = [];
    }

    function teardownVerticalClusterWheelCaptures() {
      verticalClusterWheelCleanups.forEach(fn => {
        try {
          fn();
        } catch (_) {}
      });
      verticalClusterWheelCleanups = [];
    }

    function clusterInnerWheelGuard(ev) {
      if (!document.body.classList.contains("is-scrollstory") || document.body.classList.contains("pitch-vertical")) return;
      if (window.matchMedia("(max-width: 860px)").matches) return;
      const sc = ev.currentTarget;
      if (!(sc instanceof HTMLElement)) return;

      const tol = 2;
      const dy = ev.deltaY;
      const st = sc.scrollTop;
      const max = Math.max(0, sc.scrollHeight - sc.clientHeight);
      const canDown = dy > 0 && st < max - tol;
      const canUp = dy < 0 && st > tol;
      if (canDown || canUp) ev.preventDefault();
      if (canDown || canUp) sc.scrollTop = Math.min(max, Math.max(0, st + dy));
    }

    function attachHorizontalVerticalClusters() {
      teardownVerticalClusterWheelCaptures();
      if (reduceMotion) return;
      document.querySelectorAll(".story-panel--vcluster .story-vstack").forEach(box => {
        box.addEventListener("wheel", clusterInnerWheelGuard, { passive: false });
        verticalClusterWheelCleanups.push(() => box.removeEventListener("wheel", clusterInnerWheelGuard));
        box.addEventListener("scroll", refreshPitchStepNavUi, { passive: true });
        verticalClusterWheelCleanups.push(() => box.removeEventListener("scroll", refreshPitchStepNavUi));
      });
    }

    /** Panel `from(...)` entrances driven by scrub strip tween (requires `horizontal: true` + `containerAnimation`). */
    function initHorizontalPanelReveals(containerTween) {
      teardownHorizontalPanelReveals();
      if (!window.gsap || !window.ScrollTrigger || !containerTween || reduceMotion) return;

      gsap.utils.toArray("#storyRoll .story-panel").forEach(panel => {
        const revealRoot = panel.classList.contains("story-panel--vcluster")
          ? panel.querySelector(".story-subslide")
          : panel;
        if (!revealRoot) return;
        const targets = revealRoot.querySelectorAll(PANEL_REVEAL_SEL);
        if (!targets.length) return;
        const vars = panel.classList.contains("story-panel--vcluster")
          ? panelRevealTweenVars(revealRoot, false)
          : panelRevealTweenVars(panel, false);
        const anim = gsap.from(targets, {
          ...vars,
          immediateRender: false,
          scrollTrigger: {
            trigger: panel,
            horizontal: true,
            containerAnimation: containerTween,
            start: "left 92%",
            end: "left 38%",
            once: true,
            invalidateOnRefresh: true,
          },
        });
        horizontalPanelRevealAnims.push(anim);
      });
      ScrollTrigger.refresh();
    }

    let scrollTriggerSizingHooked = false;

    /** Re-measure after paint + window.load so pin/end match final scrollWidth (avoids empty slides). */
    function queueScrollTriggerSizingPass() {
      const run = () => {
        if (!window.ScrollTrigger) return;
        syncStoryViewportWidthCss();
        if (horizontalTween) horizontalTween.invalidate();
        ScrollTrigger.refresh(true);
        const st = horizontalTween && horizontalTween.scrollTrigger;
        const onlyIntroOrNoHash =
          !location.hash || location.hash === "#" || location.hash === "#intro";
        /** scrollY pinned at section start should map to ~progress 0; high progress ⇒ scrub state machine bug (often RTL + snap). */
        const pinnedAtStartBroken =
          st &&
          typeof st.start === "number" &&
          document.body.classList.contains("is-scrollstory") &&
          !document.body.classList.contains("pitch-vertical") &&
          onlyIntroOrNoHash &&
          window.scrollY <= st.start + 40 &&
          st.progress > 0.85;
        const stuckAtEndDesktop =
          st &&
          document.body.classList.contains("is-scrollstory") &&
          !document.body.classList.contains("pitch-vertical") &&
          !location.hash &&
          window.scrollY < 12 &&
          st.progress > 0.92;
        if (pinnedAtStartBroken || stuckAtEndDesktop) {
          window.scrollTo(0, 0);
          horizontalTween.invalidate();
          ScrollTrigger.refresh(true);
        }
      };
      requestAnimationFrame(() => {
        requestAnimationFrame(run);
      });
      if (scrollTriggerSizingHooked) return;
      scrollTriggerSizingHooked = true;
      const afterLoad = () => {
        requestAnimationFrame(() => {
          requestAnimationFrame(run);
        });
      };
      if (document.readyState === "complete") afterLoad();
      else window.addEventListener("load", afterLoad, { once: true });
    }

    function initVerticalPanelReveals() {
      teardownVerticalPanelReveals();
      gsap.registerPlugin(ScrollTrigger);
      gsap.utils.toArray(".story-panel").forEach(panel => {
        if (panel.classList.contains("story-panel--vcluster")) {
          gsap.utils
            .toArray(panel.querySelectorAll(":scope > .story-vstack > .story-subslide"))
            .forEach(subslide => {
              const targets = subslide.querySelectorAll(PANEL_REVEAL_SEL);
              if (!targets.length) return;
              const anim = gsap.from(targets, {
                ...panelRevealTweenVars(subslide, true),
                immediateRender: false,
                scrollTrigger: {
                  trigger: subslide,
                  start: "top 86%",
                  once: true,
                },
              });
              verticalPanelRevealAnims.push(anim);
            });
          return;
        }
        const targetsPanel = panel.querySelectorAll(PANEL_REVEAL_SEL);
        if (!targetsPanel.length) return;
        const anim = gsap.from(targetsPanel, {
          ...panelRevealTweenVars(panel, true),
          immediateRender: false,
          scrollTrigger: {
            trigger: panel,
            start: "top 86%",
            once: true,
          },
        });
        verticalPanelRevealAnims.push(anim);
      });
    }

    function initScrollStory() {
      teardownHorizontalStory();
      teardownPassiveProgress();
      document.body.classList.remove("is-scrollstory", "scroll-rtlflow", "pitch-vertical");
      document.documentElement.classList.remove("pitch-vertical-desktop");

      const cfg = authorStoryMotion();
      const isDesktop = matchMedia("(min-width: 861px)").matches;
      const hasGsap = window.gsap && window.ScrollTrigger;

      if (!hasGsap || reduceMotion) {
        addPassiveProgress();
        initStudioWizardHighlight();
        refreshPitchStepNavUi();
        return;
      }

      if (cfg.verticalDesktop && isDesktop) {
        document.body.classList.add("pitch-vertical");
        document.documentElement.classList.add("pitch-vertical-desktop");
        addPassiveProgress();
        initVerticalPanelReveals();
        initStudioWizardHighlight();
        refreshPitchStepNavUi();
        return;
      }

      if (!isDesktop) {
        addPassiveProgress();
        initStudioWizardHighlight();
        refreshPitchStepNavUi();
        return;
      }

      gsap.registerPlugin(ScrollTrigger);
      try {
        if ("scrollRestoration" in history) history.scrollRestoration = "manual";
      } catch (_) {}
      scrollTo(0, 0);

      syncStoryViewportWidthCss();
      document.body.classList.add("is-scrollstory");
      if (cfg.rtlFlow) document.body.classList.add("scroll-rtlflow");

      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          try {
            syncStoryViewportWidthCss();
            void trackRoll.offsetWidth;
            const panels = gsap.utils.toArray("#storyRoll .story-panel");
            const maxSpan = Math.max(1, panels.length - 1);
            /**
             * Vertical scroll distance for the pinned horizontal scrub.
             * Must stay in sync with real strip width: if this is too small, scrollY≈0 still maps to progress≈1
             * and only the last panel fills the viewport.
             */
            const getLanePx = () => {
              void trackRoll.offsetWidth;
              if (storyTrackEl) {
                const r = storyTrackEl.getBoundingClientRect();
                const w = Math.round(r.width || storyTrackEl.clientWidth || 0);
                if (w > 0) return w;
              }
              return Math.max(1, Math.round(window.innerWidth || document.documentElement.clientWidth || 1));
            };
            const getMaxScroll = () => {
              syncStoryViewportWidthCss();
              void trackRoll.offsetWidth;
              const lane = getLanePx();
              let measured = trackRoll.scrollWidth - lane;
              if (!Number.isFinite(measured)) measured = 0;
              measured = Math.max(0, measured);
              /** Wide cold load often yields a tiny but non‑zero measured (e.g. 50px) → pin range shrinks → progress clamps to 1 → only final slide. Always take at least (n−1)·lane (GSAP horizontal-scroll pattern). */
              const fallback = maxSpan * lane;
              return Math.max(1, measured, fallback);
            };

            /*
              RTL mode (body.scroll-rtlflow) mirrors .story-mirror + each .story-panel (text un-mirrors).
              Horizontal scrub must stay x: 0 → -getMaxScroll(): if we "swap" from/to, progress 0 maps to
              translateX(-full) and the viewport lands on the last DOM panel first.
            */

            horizontalTween = gsap.fromTo(
              trackRoll,
              { x: 0 },
              {
                x: () => -getMaxScroll(),
                ease: "none",
                scrollTrigger: {
                  invalidateOnRefresh: true,
                  trigger: "#story",
                  pin: true,
                  scrub: 1,
                  /*
                    ScrollTrigger snap frequently mis-resolves during first refresh with RTL/page restore,
                    pinning scroll to the last segment while URL/#intro expects progress 0. Re-enable snap
                    only after a proven stable pattern if step snapping is needed.
                  */
                  snap: false,
                  end: () => "+=" + getMaxScroll(),
                  onUpdate: self => setProgress(self.progress),
                },
              }
            );

            mainScrollTrigger = horizontalTween.scrollTrigger;

            ScrollTrigger.refresh();
            window.scrollTo(0, 0);
            queueScrollTriggerSizingPass();
            requestAnimationFrame(() => {
              window.scrollTo(0, 0);
              ScrollTrigger.refresh();
              initHorizontalPanelReveals(horizontalTween);
              attachHorizontalVerticalClusters();
              refreshPitchStepNavUi();
              initStudioWizardHighlight();
            });
          } catch (err) {
            console.warn("[scrollstory]", err);
          }
        });
      });
    }

    function addPassiveProgress() {
      teardownPassiveProgress();
      const update = () => {
        const max = Math.max(1, document.documentElement.scrollHeight - innerHeight);
        setProgress(scrollY / max);
      };
      window.addEventListener("scroll", update, { passive: true });
      passiveProgressCleanup = () => window.removeEventListener("scroll", update);
      update();
    }

    document.querySelectorAll('a[href^="#"]').forEach(link => {
      link.addEventListener("click", event => {
        const href = link.getAttribute("href");
        const targetId = href && href.startsWith("#") ? decodeURIComponent(href.slice(1)) : "";
        if (!href || href === "#" || !targetId) return;
        const targetElement = document.getElementById(targetId);
        if (!targetElement) return;
        event.preventDefault();
        const anchorPanel = targetElement.closest(".story-panel");
        if (mainScrollTrigger && document.body.classList.contains("is-scrollstory") && !document.body.classList.contains("pitch-vertical") && anchorPanel?.classList.contains("story-panel")) {
          const vst = anchorPanel.querySelector(":scope > .story-vstack");
          if (targetElement.classList.contains("story-subslide") && vst) {
            vst.scrollTo({ top: targetElement.offsetTop, behavior: "auto" });
          }
          const rollPanels = gsap.utils.toArray("#storyRoll > .story-panel");
          const denom = Math.max(1, rollPanels.length - 1);
          const rollIdx = Number(anchorPanel.dataset.rollIndex ?? anchorPanel.dataset.index ?? 0);
          const progress = denom ? rollIdx / denom : 0;
          const top = mainScrollTrigger.start + (mainScrollTrigger.end - mainScrollTrigger.start) * progress;
          scrollTo({ top, behavior: "auto" });
          return;
        }
        targetElement.scrollIntoView({ behavior: reduceMotion ? "auto" : "smooth", block: "start", inline: "start" });
      });
    });

    initScrollStory();

    initPitchStepNav();

    syncStoryViewportWidthCss();
    window.addEventListener("resize", () => {
      syncStoryViewportWidthCss();
      if (window.ScrollTrigger) ScrollTrigger.refresh();
      refreshPitchStepNavUi();
    });

    const desktopStoryMq = window.matchMedia("(min-width: 861px)");
    const onViewportStoryTierChange = () => {
      syncStoryViewportWidthCss();
      initScrollStory();
      requestAnimationFrame(() => {
        requestAnimationFrame(refreshPitchStepNavUi);
      });
    };
    if (typeof desktopStoryMq.addEventListener === "function") {
      desktopStoryMq.addEventListener("change", onViewportStoryTierChange);
    } else if (typeof desktopStoryMq.addListener === "function") {
      desktopStoryMq.addListener(onViewportStoryTierChange);
    }
  </script>
</body>
</html>
