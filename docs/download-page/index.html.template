        subtitle: "{{כאן נוסיף פירוט לפי הארכיטקטורה בפועל}}",
        bullets: ["Audio → Whisper", "Scene Planner → v1Drive", "ffmpeg → MP4"],
        notes: "להשתמש בשקף הזה כעוגן הטכני של המצגת.",
        theme: THEMES.tech,
        sketch: [
          { id: "pipe-audio", type: "circle", x: 118, y: 180, r: 42, label: "Audio" },
          { id: "pipe-whisper", type: "box", x: 226, y: 135, w: 145, h: 90, label: "Whisper" },
          { id: "pipe-plan", type: "diamond", x: 432, y: 126, w: 150, h: 108, label: "Planner" },
