# Template only — copy to `Pulumi.prod.yaml` and run
#   pulumi --cwd infra/cloudflare stack init prod
#   pulumi --cwd infra/cloudflare stack select prod
#   pulumi --cwd infra/cloudflare config set …
#
# Pulumi will not load this file as a stack until it is renamed.
#
# Per `docs/CLOUDFLARE_MCP_IMPROVEMENT_PLAN.md` §2, the prod stack should:
# - use a distinct bucket and Worker script name from `dev`
# - use a minimum-scoped Cloudflare API token (the `cloudflareApiToken`
#   key the Worker uses at request time can be a different token from the
#   `cloudflare:apiToken` Pulumi uses to mutate resources)
# - rotate `appPassword` on a regular cadence
#
# Replace every `REPLACE_ME` value before promoting. Secrets must be set
# via `pulumi config set --secret <key> <value>` so Pulumi encrypts them
# under the new stack's salt — do NOT paste plaintext secrets into this
# file.

config:
  weatherv1-cloudflare:accountId: REPLACE_ME
  weatherv1-cloudflare:bucketName: weatherv1-media-prod
  weatherv1-cloudflare:tenantId: default
  weatherv1-cloudflare:workerName: weatherv1-r2-gateway-prod
  weatherv1-cloudflare:allowedOrigin: '*'
  weatherv1-cloudflare:workersDevSubdomain: REPLACE_ME
  weatherv1-cloudflare:appUsername: REPLACE_ME

  # Set the four secrets via `pulumi config set --secret`. The placeholders
  # below are documentation only — Pulumi expects a `secure:` block, not a
  # plain string, for any value listed under `pulumi config get --show-secrets`.
  # weatherv1-cloudflare:appPassword:        secure: <generated by pulumi>
  # weatherv1-cloudflare:cloudflareApiToken: secure: <generated by pulumi>
  # weatherv1-cloudflare:r2ParentAccessKeyId: secure: <generated by pulumi>
  # cloudflare:apiToken:                     secure: <generated by pulumi>

  # Optional — set only if you intend to bind a custom domain.
  # weatherv1-cloudflare:zoneId: REPLACE_ME
  # weatherv1-cloudflare:routePattern: r2-prod.example.com/*

  # Optional — pin R2 region + storage class. `weur` for European tenants.
  # weatherv1-cloudflare:r2Location: weur
  # weatherv1-cloudflare:r2StorageClass: Standard
