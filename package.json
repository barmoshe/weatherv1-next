{
  "name": "weatherv1-next",
  "version": "0.1.0",
  "description": "WeatherV1 local desktop video production app",
  "author": "Barmoshe",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "standalone:prep": "node scripts/prepare-standalone.cjs",
    "electron:dev": "node scripts/run-electron.cjs .",
    "electron:build": "next build && npm run standalone:prep && electron-forge package",
    "electron:make": "next build && npm run standalone:prep && electron-forge make"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "openai": "^4",
    "zod": "^3",
    "@tanstack/react-query": "^5",
    "proper-lockfile": "^4",
    "uuid": "^9",
    "formidable": "^3",
    "ffmpeg-static": "^5",
    "ffprobe-static": "^3",
    "update-electron-app": "^3",
    "electron-squirrel-startup": "^1"
  },
  "devDependencies": {
    "@types/formidable": "^3",
    "@types/node": "^20",
    "@types/proper-lockfile": "^4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^9",
    "@vitejs/plugin-react": "^4",
    "typescript": "^5",
    "vitest": "^2",
    "@testing-library/react": "^16",
    "@testing-library/jest-dom": "^6",
    "jsdom": "^25",
    "@vitest/coverage-v8": "^2",
    "electron": "^33",
    "@electron-forge/cli": "^7",
    "@electron-forge/maker-zip": "^7",
    "@electron-forge/maker-squirrel": "^7",
    "@electron-forge/plugin-auto-unpack-natives": "^7",
    "@electron-forge/publisher-github": "^7",
    "@electron-forge/shared-types": "^7"
  }
}
